---
import ThemeLayout from '../layouts/ThemeLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<ThemeLayout title="Kontakt">
  <Nav />
  <main>
    <section class="page-hero">
      <div class="container-inner">
        <span class="eyebrow">Kontakt</span>
        <h1>Find os</h1>
      </div>
    </section>
    <section class="section-py">
      <div class="container-inner contact-grid">
        <div class="info-col" data-reveal>
          <div class="info-card">
            <h3>Salon Rosé</h3>
            <address>
              Bredgade 24<br/>
              1260 København K
            </address>
            <a href="tel:+4532123456">+45 32 12 34 56</a>
            <a href="mailto:hej@salonrose.dk">hej@salonrose.dk</a>
          </div>
          <div class="hours-card">
            <h4>Åbningstider</h4>
            <ul>
              <li><span>Mandag</span><span>9:00–18:00</span></li>
              <li><span>Tirsdag</span><span>9:00–18:00</span></li>
              <li><span>Onsdag</span><span>9:00–18:00</span></li>
              <li><span>Torsdag</span><span>9:00–19:00</span></li>
              <li><span>Fredag</span><span>9:00–18:00</span></li>
              <li><span>Lørdag</span><span>9:00–15:00</span></li>
              <li><span>Søndag</span><span>Lukket</span></li>
            </ul>
          </div>
          <a href="/booking" class="btn-primary" style="display:block;text-align:center;margin-top:1.25rem;">Book en tid online</a>
        </div>
        <div class="form-col" data-reveal>
          <h2>Skriv til os</h2>
          <form id="contact-form" novalidate>
            <div class="form-group">
              <label for="c-name">Dit navn *</label>
              <input type="text" id="c-name" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="c-email">E-mail *</label>
              <input type="email" id="c-email" required autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="c-subject">Emne</label>
              <select id="c-subject">
                <option>Generel henvendelse</option>
                <option>Booking / Tider</option>
                <option>Priser & services</option>
                <option>Andet</option>
              </select>
            </div>
            <div class="form-group">
              <label for="c-message">Besked *</label>
              <textarea id="c-message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn-primary" style="width:100%;padding:0.875rem;">Send besked</button>
            <div class="success-msg" id="success-msg">✓ Tak for din besked — vi vender tilbage hurtigst muligt.</div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</ThemeLayout>

<style>
  .page-hero { padding: 5rem 0 3rem; background: var(--color-bg-warm); border-bottom: 1px solid var(--color-border); }
  .page-hero .eyebrow { color: var(--color-accent); }
  .page-hero h1 { font-size: clamp(2rem, 5vw, 3rem); }
  .contact-grid { display: grid; grid-template-columns: 340px 1fr; gap: 4rem; align-items: start; }
  .info-card { background: var(--color-primary); color: #fff; border-radius: var(--radius-card); padding: 1.75rem; margin-bottom: 1.25rem; }
  .info-card h3 { color: #fff; font-size: 1.15rem; margin-bottom: 1rem; }
  .info-card address { font-style: normal; line-height: 1.7; color: rgba(255,255,255,0.75); font-size: 0.9rem; margin-bottom: 1rem; display: block; }
  .info-card a { display: block; color: var(--color-accent); text-decoration: none; font-size: 0.9rem; margin-bottom: 0.3rem; }
  .hours-card { border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 1.25rem; }
  .hours-card h4 { font-family: var(--font-body); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-secondary); margin-bottom: 0.875rem; }
  .hours-card ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .hours-card li { display: flex; justify-content: space-between; font-size: 0.875rem; }
  .form-col h2 { font-size: 1.75rem; margin-bottom: 1.75rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 1.1rem; }
  label { font-size: 0.83rem; font-weight: 600; }
  input, select, textarea { padding: 0.7rem 1rem; border: 1.5px solid var(--color-border); border-radius: var(--radius-md); font-family: var(--font-body); font-size: 0.95rem; transition: border-color 150ms; }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--color-primary); }
  textarea { resize: vertical; }
  .success-msg { display: none; margin-top: 1rem; padding: 1rem; background: var(--color-primary-light); color: var(--color-primary); border-radius: var(--radius-md); font-weight: 500; font-size: 0.875rem; }
  .success-msg.visible { display: block; }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; } }
</style>
<script>
  document.getElementById('contact-form').addEventListener('submit', e => {
    e.preventDefault();
    document.getElementById('success-msg').classList.add('visible');
    e.target.reset();
  });
</script>
