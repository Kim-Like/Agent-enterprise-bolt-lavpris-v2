---
import ThemeLayout from '../layouts/ThemeLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import staff from '../data/staff.json';
---
<ThemeLayout title="Om Salon Rosé">
  <Nav />
  <main>
    <section class="page-hero">
      <div class="container-inner">
        <span class="eyebrow">Om os</span>
        <h1>En salon med<br/>sjæl og sans</h1>
      </div>
    </section>
    <section class="section-py">
      <div class="container-inner about-grid">
        <div class="about-img" data-reveal>
          <img src="https://images.pexels.com/photos/3993449/pexels-photo-3993449.jpeg?auto=compress&cs=tinysrgb&w=900" alt="Salon Rosé" />
        </div>
        <div class="about-text" data-reveal>
          <span class="eyebrow">Vores historie</span>
          <h2>Åbnet i 2010 med én vision</h2>
          <p>Salon Rosé opstod ud af Amalies drøm om at skabe et sted, der føles som en fristad — et sted hvor frisøroplevelsen er både personlig, hyggelig og professionel.</p>
          <p>Vi tror på, at et besøg hos frisøren skal efterlade dig som den bedste udgave af dig selv. Ikke bare i håret, men i humøret.</p>
          <p>Siden 2010 har vi betjent tusindvis af kunder i Indre By og bygget en fast og trofast kundekreds, der vender tilbage — ikke kun for håret, men for stemningen.</p>
        </div>
      </div>
    </section>
    <section class="values-section section-py section-warm">
      <div class="container-inner">
        <div class="section-header" data-reveal>
          <span class="eyebrow">Vores værdier</span>
          <h2>Det vi tror på</h2>
        </div>
        <div class="values-grid">
          {[
            { icon: '✦', t: 'Personlighed', b: 'Vi husker dig. Dit hår, dine præferencer og din livssituation.' },
            { icon: '✦', t: 'Bæredygtighed', b: 'Vi bruger udelukkende miljøcertificerede produkter fra L\'Oréal Professionnel.' },
            { icon: '✦', t: 'Faglighed', b: 'Alle vores stylister er løbende på efteruddannelse og internationale workshops.' },
            { icon: '✦', t: 'Tryghed', b: 'Gratis konsultation til nye kunder. Altid. Ingen forpligtelse.' },
          ].map((v, i) => (
            <div class="value-item" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <span class="value-icon">{v.icon}</span>
              <h4>{v.t}</h4>
              <p>{v.b}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    <section class="team-section section-py">
      <div class="container-inner">
        <div class="section-header" data-reveal>
          <span class="eyebrow">Holdet</span>
          <h2>Mød vores stylister</h2>
        </div>
        <div class="team-grid">
          {staff.map((m, i) => (
            <div class="staff-card" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <img src={m.img} alt={m.name} loading="lazy" />
              <div class="staff-body">
                <h3>{m.name}</h3>
                <p class="staff-title">{m.title}</p>
                <p class="staff-bio">{m.bio}</p>
                <div class="staff-specs">
                  {m.specialties.map(s => <span>{s}</span>)}
                </div>
                <a href="/booking" class="book-btn">Book hos {m.name.split(' ')[0]}</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</ThemeLayout>

<style>
  .page-hero { padding: 5rem 0 3rem; background: var(--color-bg-warm); border-bottom: 1px solid var(--color-border); }
  .page-hero .eyebrow { color: var(--color-accent); }
  .page-hero h1 { font-size: clamp(2rem, 5vw, 3rem); }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .about-img img { width: 100%; border-radius: var(--radius-2xl); aspect-ratio: 4/5; object-fit: cover; }
  .about-text h2 { font-size: clamp(1.6rem, 3.5vw, 2.5rem); margin-bottom: 1.25rem; }
  .about-text p { color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 1rem; }
  .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .value-item { text-align: center; }
  .value-icon { display: block; font-size: 1.5rem; color: var(--color-accent); margin-bottom: 0.875rem; }
  .value-item h4 { font-size: 1.05rem; margin-bottom: 0.5rem; }
  .value-item p { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0; line-height: 1.6; }
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .staff-card { background: var(--color-bg-page); border: 1px solid var(--color-border); border-radius: var(--radius-card); overflow: hidden; }
  .staff-card img { width: 100%; aspect-ratio: 1; object-fit: cover; object-position: top; }
  .staff-body { padding: 1.5rem; }
  .staff-body h3 { font-size: 1.2rem; margin-bottom: 0.2rem; }
  .staff-title { font-size: 0.8rem; color: var(--color-accent); font-weight: 600; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .staff-bio { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 1rem; }
  .staff-specs { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 1.25rem; }
  .staff-specs span { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: var(--radius-full); background: var(--color-primary-light); color: var(--color-primary); }
  .book-btn { display: block; text-align: center; padding: 0.6rem; background: var(--color-primary); color: #fff; border-radius: var(--radius-full); text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: background 150ms; }
  .book-btn:hover { background: var(--color-primary-hover); }
  @media (max-width: 900px) { .about-grid { grid-template-columns: 1fr; gap: 2.5rem; } .values-grid { grid-template-columns: repeat(2, 1fr); } .team-grid { grid-template-columns: 1fr; } }
</style>
