---
const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/gallery', label: 'Galleri' },
  { href: '/about', label: 'Om Salonnen' },
  { href: '/contact', label: 'Kontakt' },
];
---
<header id="salon-header">
  <div class="container-inner header-inner">
    <button class="hamburger" id="salon-hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <a href="/" class="logo" aria-label="Salon Rosé — hjem">
      <span class="logo-r">R</span>
      <span>Salon Rosé</span>
    </a>
    <nav class="desktop-nav">
      <ul role="list">
        {navLinks.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>
    <a href="/booking" class="btn-primary nav-book">Book tid</a>
  </div>
  <nav class="mobile-nav" id="salon-mobile-nav" aria-hidden="true">
    <ul role="list">
      {navLinks.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      <li><a href="/booking" class="btn-primary" style="display:block;text-align:center;margin-top:0.75rem;">Book tid</a></li>
    </ul>
  </nav>
</header>

<style>
  #salon-header { background: var(--color-bg-page); border-bottom: 1px solid var(--color-border); position: sticky; top: 0; z-index: 100; }
  .header-inner { display: flex; align-items: center; gap: 2rem; padding-top: 1rem; padding-bottom: 1rem; }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; font-family: var(--font-heading); font-weight: 500; font-size: 1.2rem; color: var(--color-text-primary); letter-spacing: 0.02em; }
  .logo-r { width: 1.875rem; height: 1.875rem; background: var(--color-primary); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-weight: 600; font-size: 0.875rem; }
  .desktop-nav { margin-left: auto; }
  .desktop-nav ul { display: flex; gap: 0; list-style: none; margin: 0; padding: 0; }
  .desktop-nav a { padding: 0.4rem 0.875rem; text-decoration: none; font-size: 0.875rem; color: var(--color-text-secondary); transition: color 150ms; }
  .desktop-nav a:hover { color: var(--color-primary); }
  .nav-book { font-size: 0.85rem; padding: 0.6rem 1.25rem; }
  .hamburger { display: none; flex-direction: column; gap: 5px; width: 2rem; height: 2rem; background: none; border: none; cursor: pointer; padding: 4px; }
  .hamburger span { display: block; width: 100%; height: 1.5px; background: var(--color-text-primary); border-radius: 2px; transition: transform 200ms, opacity 200ms; }
  .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
  .mobile-nav { display: none; padding: 0.75rem 1.5rem 1.25rem; border-top: 1px solid var(--color-border); }
  .mobile-nav.open { display: block; }
  .mobile-nav ul { list-style: none; margin: 0; padding: 0; }
  .mobile-nav li a { display: block; padding: 0.7rem 0; text-decoration: none; color: var(--color-text-primary); border-bottom: 1px solid var(--color-border); font-size: 0.95rem; }
  @media (max-width: 768px) { .desktop-nav, .nav-book { display: none; } .hamburger { display: flex; } }
</style>
<script>
  const hamburger = document.getElementById('salon-hamburger');
  const mobileNav = document.getElementById('salon-mobile-nav');
  hamburger.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    mobileNav.classList.toggle('open', !open);
    mobileNav.setAttribute('aria-hidden', String(open));
  });
</script>
