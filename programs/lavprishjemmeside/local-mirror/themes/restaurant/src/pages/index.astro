---
import ThemeLayout from '../layouts/ThemeLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import menu from '../data/menu.json';
const popular = menu.filter(m => m.popular).slice(0, 4);
function formatPrice(ore) { return (ore / 100).toLocaleString('da-DK', { style: 'currency', currency: 'DKK', minimumFractionDigits: 0 }); }
---
<ThemeLayout title="Autentisk Grillrestaurant">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-media">
        <img src="https://images.pexels.com/photos/1639562/pexels-photo-1639562.jpeg?auto=compress&cs=tinysrgb&w=1600" alt="" role="presentation" />
        <div class="hero-overlay"></div>
      </div>
      <div class="container-inner hero-content">
        <span class="hero-eyebrow">BRASA · København V</span>
        <h1>Grilltradition<br/>med sjæl</h1>
        <p>Autentisk grillmad tilberedt over åben ild fra verdens bedste råvarer.</p>
        <div class="hero-ctas">
          <a href="/takeaway" class="btn-primary">Bestil takeaway</a>
          <a href="/menu" class="hero-link">Se menuen →</a>
        </div>
      </div>
      <div class="hero-info-strip">
        <div class="container-inner hero-info-inner">
          <span>🕐 Man–Tors 17–22 · Fre–Lør 17–23 · Søn 16–21</span>
          <span>📍 Istedgade 88, 1650 KBH V</span>
          <span>📞 +45 33 12 34 56</span>
        </div>
      </div>
    </section>

    <!-- About strip -->
    <section class="about-strip section-py section-warm">
      <div class="container-inner about-grid">
        <div class="about-text" data-reveal>
          <span class="eyebrow">Om BRASA</span>
          <h2>Ild, røg og<br/>autentiske smagsoplevelser</h2>
          <p>BRASA opstod ud af en passion for den ældste tilberedningsmetode: ilden. Vi bruger udelukkende bæredygtigt producerede råvarer fra lokale leverandører og tilbereder alt over åben ild og i stegovn.</p>
          <a href="/about" class="btn-dark" style="margin-top:1.5rem;">Læs vores historie</a>
        </div>
        <div class="about-images" data-reveal>
          <img class="img-main" src="https://images.pexels.com/photos/67468/pexels-photo-67468.jpeg?auto=compress&cs=tinysrgb&w=800" alt="BRASA køkken" />
          <img class="img-accent" src="https://images.pexels.com/photos/1640777/pexels-photo-1640777.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Ret fra menuen" />
        </div>
      </div>
    </section>

    <!-- Popular items -->
    <section class="section-py">
      <div class="container-inner">
        <div class="section-header" data-reveal>
          <span class="eyebrow">Gæsternes favoritter</span>
          <h2>Populær fra menuen</h2>
        </div>
        <div class="menu-grid">
          {popular.map((item, i) => (
            <div class="menu-card" data-reveal style={`--reveal-delay:${i * 80}ms`}>
              <div class="menu-card-img">
                <img src={item.image} alt={item.name} loading="lazy" />
                {item.popular && <span class="popular-badge">Populær</span>}
              </div>
              <div class="menu-card-body">
                <div class="menu-card-header">
                  <h3>{item.name}</h3>
                  <span class="price">{formatPrice(item.price)}</span>
                </div>
                <p>{item.description}</p>
                <a href="/takeaway" class="order-link">Bestil →</a>
              </div>
            </div>
          ))}
        </div>
        <div class="section-cta" data-reveal>
          <a href="/menu" class="btn-dark" style="margin-right:1rem;">Se hele menuen</a>
          <a href="/takeaway" class="btn-primary">Bestil takeaway</a>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="section-py section-dark">
      <div class="container-inner">
        <div class="experience-grid">
          <div data-reveal>
            <span class="eyebrow">Oplevelsen</span>
            <h2>Mere end bare mad</h2>
            <p>Hos BRASA handler det om den samlede oplevelse. Det levende køkken, duften af røg og grillet kød, lyden af sizzle og det afslappede miljø.</p>
            <p>Vi prioriterer personlig service og en menu der ændrer sig med sæsonen og råvaretilgængelighed.</p>
          </div>
          <div class="feature-list" data-reveal>
            {[
              { icon: '🔥', t: 'Åben ildgrill', b: 'Traditionel grillmad tilberedt direkte over kul' },
              { icon: '🌱', t: 'Bæredygtige råvarer', b: 'Lokale leverandører og sæsonbetonede ingredienser' },
              { icon: '🍷', t: 'Naturvin & cocktails', b: 'Kurateret liste af naturvine og husmixede drinks' },
              { icon: '🛵', t: 'Takeaway & levering', b: 'Afhent eller få leveret til din dør' },
            ].map((f, i) => (
              <div class="feature-item" data-reveal style={`--reveal-delay:${i * 80}ms`}>
                <span class="feature-icon">{f.icon}</span>
                <div><strong>{f.t}</strong><p>{f.b}</p></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Takeaway CTA -->
    <section class="takeaway-cta section-py">
      <div class="container-inner" style="text-align:center;">
        <span class="eyebrow" data-reveal>Takeaway</span>
        <h2 data-reveal>Spis BRASA hjemme</h2>
        <p data-reveal>Bestil online og afhent færdigt om 30–45 minutter. Levering tilgængelig inden for 3 km.</p>
        <div data-reveal style="margin-top:1.75rem;display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
          <a href="/takeaway" class="btn-primary" style="font-size:1rem;padding:0.9rem 2.5rem;">Bestil nu</a>
          <a href="/menu" class="btn-dark" style="font-size:1rem;padding:0.9rem 2.5rem;">Se menuen</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</ThemeLayout>

<style>
  .hero { position: relative; min-height: 90vh; display: flex; flex-direction: column; justify-content: flex-end; }
  .hero-media { position: absolute; inset: 0; }
  .hero-media img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(28,26,23,0.85) 0%, rgba(28,26,23,0.5) 50%, rgba(28,26,23,0.2) 100%); }
  .hero-content { position: relative; z-index: 2; padding-bottom: 4rem; padding-top: 10rem; max-width: 640px; }
  .hero-eyebrow { color: var(--color-accent); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 1.25rem; display: block; }
  .hero-content h1 { font-size: clamp(3rem, 8vw, 5.5rem); color: #fff; margin-bottom: 1.25rem; }
  .hero-content p { font-size: 1.1rem; color: rgba(245,240,232,0.8); margin-bottom: 2.25rem; max-width: 480px; }
  .hero-ctas { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .hero-link { color: rgba(245,240,232,0.9); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
  .hero-link:hover { color: var(--color-accent); }
  .hero-info-strip { position: relative; z-index: 2; background: var(--color-accent); padding: 0.75rem 0; }
  .hero-info-inner { display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; }
  .hero-info-inner span { color: #fff; font-size: 0.8rem; font-weight: 600; }
  .section-header { text-align: center; margin-bottom: 2.75rem; }
  .section-header h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: 0; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .about-text h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: 1.25rem; }
  .about-text p { color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 1rem; }
  .about-images { position: relative; }
  .img-main { width: 100%; border-radius: var(--radius-2xl); aspect-ratio: 4/5; object-fit: cover; }
  .img-accent { position: absolute; bottom: -2rem; right: -1.5rem; width: 48%; border-radius: var(--radius-xl); border: 4px solid #fff; box-shadow: var(--shadow-lg); aspect-ratio: 1; object-fit: cover; }
  .menu-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .menu-card { border: 1px solid var(--color-border); border-radius: var(--radius-card); overflow: hidden; transition: transform 240ms, box-shadow 240ms; background: var(--color-bg-page); }
  .menu-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .menu-card-img { position: relative; aspect-ratio: 4/3; overflow: hidden; }
  .menu-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms; }
  .menu-card:hover .menu-card-img img { transform: scale(1.05); }
  .popular-badge { position: absolute; top: 0.75rem; left: 0.75rem; background: var(--color-accent); color: #fff; font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: var(--radius-full); letter-spacing: 0.06em; text-transform: uppercase; }
  .menu-card-body { padding: 1.25rem; }
  .menu-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; gap: 0.5rem; }
  .menu-card-body h3 { font-size: 1rem; }
  .price { font-weight: 700; color: var(--color-accent); white-space: nowrap; font-size: 1rem; }
  .menu-card-body p { font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1rem; line-height: 1.6; }
  .order-link { font-size: 0.85rem; font-weight: 700; color: var(--color-accent); text-decoration: none; }
  .order-link:hover { text-decoration: underline; }
  .section-cta { text-align: center; margin-top: 2.5rem; }
  .experience-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .section-dark .experience-grid h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: 1.25rem; }
  .section-dark .experience-grid p { color: rgba(245,240,232,0.7); line-height: 1.8; margin-bottom: 1rem; }
  .feature-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .feature-item { display: flex; gap: 1.25rem; align-items: flex-start; }
  .feature-icon { font-size: 1.5rem; flex-shrink: 0; }
  .feature-item strong { display: block; color: var(--color-text-on-dark); font-size: 0.95rem; margin-bottom: 0.2rem; }
  .feature-item p { font-size: 0.85rem; color: rgba(245,240,232,0.6); margin: 0; }
  .takeaway-cta { background: var(--color-accent-light); }
  .takeaway-cta h2 { font-size: clamp(1.75rem, 4vw, 2.75rem); margin-bottom: 0.75rem; }
  .takeaway-cta p { color: var(--color-text-secondary); }
  @media (max-width: 1024px) { .menu-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 900px) { .about-grid, .experience-grid { grid-template-columns: 1fr; gap: 2.5rem; } .img-accent { display: none; } }
</style>
