---
import ThemeLayout from '../../layouts/ThemeLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import menu from '../../data/menu.json';
const categories = [
  { id: 'all', label: 'Hele menuen' },
  { id: 'koed', label: 'Kød fra grillen' },
  { id: 'fisk', label: 'Fisk & Skaldyr' },
  { id: 'vegetar', label: 'Vegetar' },
  { id: 'smaeretter', label: 'Småretter' },
  { id: 'dessert', label: 'Dessert' },
  { id: 'drikkevarer', label: 'Drikkevarer' },
];
function formatPrice(ore) { return (ore / 100).toLocaleString('da-DK', { style: 'currency', currency: 'DKK', minimumFractionDigits: 0 }); }
---
<ThemeLayout title="Menu — BRASA">
  <Nav />
  <main>
    <section class="page-hero">
      <div class="container-inner">
        <span class="eyebrow">Vores menu</span>
        <h1>Tilberedt over åben ild</h1>
        <p>Alt tilberedt fra bunden af sæsonens bedste råvarer. Menuen opdateres løbende.</p>
      </div>
    </section>

    <section class="menu-section section-py">
      <div class="container-inner">
        <div class="menu-filters" id="menu-filters">
          {categories.map(c => (
            <button class:list={['filter-btn', { active: c.id === 'all' }]} data-filter={c.id}>
              {c.label}
            </button>
          ))}
        </div>

        {categories.filter(c => c.id !== 'all').map(cat => (
          <div class="menu-category" data-category={cat.id} id={`cat-${cat.id}`}>
            <div class="cat-header" data-reveal>
              <h2>{cat.label}</h2>
            </div>
            <div class="items-list">
              {menu.filter(item => item.category === cat.id && item.available).map((item, i) => (
                <div class="menu-item" data-category={item.category} data-reveal style={`--reveal-delay:${i * 60}ms`}>
                  <div class="item-img">
                    <img src={item.image} alt={item.name} loading="lazy" />
                  </div>
                  <div class="item-body">
                    <div class="item-top">
                      <div>
                        <h3>{item.name}</h3>
                        <div class="item-tags">
                          {item.tags.map(t => <span class="tag">{t}</span>)}
                          {item.popular && <span class="tag tag-popular">Populær</span>}
                        </div>
                      </div>
                      <span class="item-price">{formatPrice(item.price)}</span>
                    </div>
                    <p>{item.description}</p>
                    <a href="/takeaway" class="item-order-link">Bestil takeaway →</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}

        <div class="menu-notes" data-reveal>
          <p>Allergener: Kontakt os venligst, hvis du har specifikke allergi- eller kostvaner, og vi vil gøre vores bedste for at imødekomme dine behov.</p>
          <p>Priserne er vejledende og kan ændres uden varsel. Alle priser er inkl. moms.</p>
        </div>
      </div>
    </section>

    <section class="takeaway-bar">
      <div class="container-inner takeaway-bar-inner">
        <div>
          <strong>Klar til at bestille?</strong>
          <span>Afhent om 30–45 min eller få leveret til døren.</span>
        </div>
        <a href="/takeaway" class="btn-primary">Bestil takeaway nu</a>
      </div>
    </section>
  </main>
  <Footer />
</ThemeLayout>

<style>
  .page-hero { padding: 6rem 0 3.5rem; background: var(--color-bg-dark); color: var(--color-text-on-dark); }
  .page-hero .eyebrow { color: var(--color-accent); border-color: rgba(212,144,26,0.3); background: rgba(212,144,26,0.12); }
  .page-hero h1 { font-size: clamp(2.25rem, 5vw, 3.5rem); color: var(--color-text-on-dark); margin-bottom: 0.75rem; }
  .page-hero p { color: rgba(245,240,232,0.7); max-width: 480px; }
  .menu-filters { display: flex; gap: 0.5rem; margin-bottom: 3rem; flex-wrap: wrap; }
  .filter-btn { padding: 0.5rem 1.25rem; border: 1px solid var(--color-border); border-radius: var(--radius-full); background: transparent; cursor: pointer; font-family: var(--font-body); font-size: 0.875rem; font-weight: 600; color: var(--color-text-secondary); transition: all 200ms ease; }
  .filter-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .filter-btn.active { background: var(--color-accent); color: #fff; border-color: var(--color-accent); }
  .menu-category { margin-bottom: 3.5rem; }
  .menu-category.hidden { display: none; }
  .cat-header { padding-bottom: 1rem; border-bottom: 2px solid var(--color-accent); margin-bottom: 1.5rem; }
  .cat-header h2 { font-size: clamp(1.25rem, 3vw, 1.75rem); margin: 0; }
  .items-list { display: flex; flex-direction: column; gap: 0; }
  .menu-item { display: grid; grid-template-columns: 120px 1fr; gap: 1.5rem; padding: 1.25rem 0; border-bottom: 1px solid var(--color-border); }
  .menu-item:last-child { border-bottom: none; }
  .item-img { width: 120px; height: 90px; border-radius: var(--radius-lg); overflow: hidden; flex-shrink: 0; }
  .item-img img { width: 100%; height: 100%; object-fit: cover; }
  .item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 0.4rem; }
  .item-body h3 { font-size: 1.05rem; margin-bottom: 0.3rem; }
  .item-tags { display: flex; gap: 0.3rem; flex-wrap: wrap; margin-bottom: 0.375rem; }
  .tag { font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: var(--radius-full); background: var(--color-bg-warm); color: var(--color-text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .tag-popular { background: rgba(212,144,26,0.15); color: var(--color-accent); }
  .item-price { font-size: 1.1rem; font-weight: 700; color: var(--color-accent); white-space: nowrap; }
  .item-body p { font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 0.5rem; }
  .item-order-link { font-size: 0.8rem; font-weight: 700; color: var(--color-accent); text-decoration: none; }
  .item-order-link:hover { text-decoration: underline; }
  .menu-notes { padding: 1.5rem; background: var(--color-bg-warm); border-radius: var(--radius-card); margin-top: 2rem; }
  .menu-notes p { font-size: 0.8rem; color: var(--color-text-secondary); margin-bottom: 0.375rem; }
  .menu-notes p:last-child { margin: 0; }
  .takeaway-bar { background: var(--color-bg-dark); padding: 1.5rem 0; }
  .takeaway-bar-inner { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .takeaway-bar strong { display: block; color: var(--color-text-on-dark); margin-bottom: 0.2rem; }
  .takeaway-bar span { color: rgba(245,240,232,0.65); font-size: 0.875rem; }
  @media (max-width: 640px) {
    .menu-item { grid-template-columns: 1fr; }
    .item-img { width: 100%; height: 180px; }
    .takeaway-bar-inner { flex-direction: column; text-align: center; }
  }
</style>
<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const categories = document.querySelectorAll('.menu-category');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      categories.forEach(cat => {
        if (filter === 'all' || cat.dataset.category === filter) {
          cat.classList.remove('hidden');
        } else {
          cat.classList.add('hidden');
        }
      });
    });
  });
</script>
