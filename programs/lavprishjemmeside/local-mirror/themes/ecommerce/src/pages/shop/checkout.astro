---
import ThemeLayout from '../../layouts/ThemeLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<ThemeLayout title="Kassen">
  <Nav />
  <main>
    <section class="section-py">
      <div class="container-inner checkout-layout">
        <div class="checkout-form-wrap">
          <a href="/shop/cart" class="back-link">← Tilbage til kurv</a>
          <h1>Kassen</h1>
          <form id="checkout-form" novalidate>
            <h3>Dine oplysninger</h3>
            <div class="form-row">
              <div class="form-group">
                <label for="co-fname">Fornavn *</label>
                <input type="text" id="co-fname" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label for="co-lname">Efternavn *</label>
                <input type="text" id="co-lname" required autocomplete="family-name" />
              </div>
            </div>
            <div class="form-group">
              <label for="co-email">E-mail *</label>
              <input type="email" id="co-email" required autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="co-phone">Telefon</label>
              <input type="tel" id="co-phone" autocomplete="tel" />
            </div>
            <h3 style="margin-top:2rem;">Leveringsadresse</h3>
            <div class="form-group">
              <label for="co-address">Adresse *</label>
              <input type="text" id="co-address" required autocomplete="street-address" />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="co-postal">Postnr. *</label>
                <input type="text" id="co-postal" required autocomplete="postal-code" maxlength="4" />
              </div>
              <div class="form-group">
                <label for="co-city">By *</label>
                <input type="text" id="co-city" required autocomplete="address-level2" />
              </div>
            </div>
            <h3 style="margin-top:2rem;">Betaling</h3>
            <div class="payment-options">
              <label class="payment-opt">
                <input type="radio" name="payment" value="card" checked />
                <span>💳 Kort (Visa/Mastercard)</span>
              </label>
              <label class="payment-opt">
                <input type="radio" name="payment" value="mobilepay" />
                <span>📱 MobilePay</span>
              </label>
            </div>
            <button type="submit" class="btn-primary" style="width:100%;padding:1rem;font-size:1rem;margin-top:2rem;">Gennemfør ordre</button>
          </form>
        </div>
        <div class="order-summary" id="order-summary">
          <h3>Din ordre</h3>
          <div id="order-items"></div>
          <div class="summary-divider"></div>
          <div class="summary-row"><span>Subtotal</span><span id="co-subtotal">—</span></div>
          <div class="summary-row"><span>Fragt</span><span id="co-shipping">—</span></div>
          <div class="summary-row total"><span>Total</span><span id="co-total">—</span></div>
        </div>
      </div>
    </section>

    <!-- Success state -->
    <section class="success-section" id="success-section" style="display:none;">
      <div class="container-inner" style="max-width:560px;text-align:center;padding:5rem 1.5rem;">
        <div class="success-icon">✓</div>
        <h1>Ordren er modtaget!</h1>
        <p>Tak for din ordre. Du modtager en bekræftelse på din e-mail om et øjeblik.</p>
        <p class="order-num" id="success-order-num"></p>
        <a href="/shop" class="btn-primary" style="display:inline-flex;margin-top:2rem;">Fortsæt med at shoppe</a>
      </div>
    </section>
  </main>
  <Footer />
</ThemeLayout>

<style>
  .back-link { font-size: 0.85rem; color: var(--color-text-secondary); text-decoration: none; display: inline-block; margin-bottom: 1.5rem; }
  .back-link:hover { color: var(--color-primary); }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 2rem; }
  .checkout-layout { display: grid; grid-template-columns: 1fr 360px; gap: 4rem; align-items: start; }
  h3 { font-size: 1.1rem; margin-bottom: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 1.1rem; }
  label { font-size: 0.85rem; font-weight: 600; }
  input { padding: 0.7rem 1rem; border: 1.5px solid var(--color-border); border-radius: var(--radius-md); font-family: var(--font-body); font-size: 0.95rem; transition: border-color 150ms; }
  input:focus { outline: none; border-color: var(--color-primary); }
  .payment-options { display: flex; flex-direction: column; gap: 0.625rem; }
  .payment-opt { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border: 1.5px solid var(--color-border); border-radius: var(--radius-md); cursor: pointer; transition: border-color 150ms; font-size: 0.9rem; }
  .payment-opt input { width: auto; padding: 0; margin: 0; }
  .payment-opt:has(input:checked) { border-color: var(--color-primary); background: var(--color-primary-light); }
  .order-summary { background: var(--color-neutral-50); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 1.5rem; position: sticky; top: 100px; }
  .order-item { display: flex; gap: 0.875rem; align-items: center; margin-bottom: 1rem; font-size: 0.875rem; }
  .order-item img { width: 52px; height: 52px; object-fit: cover; border-radius: var(--radius-sm); flex-shrink: 0; }
  .order-item-name { font-weight: 600; }
  .order-item-qty { color: var(--color-text-secondary); }
  .order-item-price { margin-left: auto; font-weight: 600; }
  .summary-divider { border-top: 1px solid var(--color-border); margin: 1rem 0; }
  .summary-row { display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 0.5rem; color: var(--color-text-secondary); }
  .summary-row.total { font-weight: 700; font-size: 1.05rem; color: var(--color-text-primary); padding-top: 0.625rem; border-top: 1px solid var(--color-border); }
  .success-icon { width: 5rem; height: 5rem; background: var(--color-primary-light); color: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1.5rem; }
  .order-num { font-size: 0.875rem; color: var(--color-text-secondary); margin-top: 0.5rem; }
  @media (max-width: 900px) { .checkout-layout { grid-template-columns: 1fr; } }
</style>
<script>
  const FREE_SHIPPING = 50000;
  const SHIPPING_FEE = 4900;
  function fmt(ore) { return (ore / 100).toLocaleString('da-DK', { style: 'currency', currency: 'DKK', minimumFractionDigits: 0 }); }

  function renderSummary() {
    const cart = (() => { try { return JSON.parse(localStorage.getItem('verde_cart') || '{"items":[]}'); } catch { return { items: [] }; } })();
    const items = cart.items || [];
    const container = document.getElementById('order-items');
    container.innerHTML = items.map(item => `
      <div class="order-item">
        <img src="${item.image || ''}" alt="${item.name}" onerror="this.style.display='none'" />
        <div>
          <p class="order-item-name">${item.name}</p>
          <p class="order-item-qty">Antal: ${item.quantity}</p>
        </div>
        <span class="order-item-price">${fmt(item.price * item.quantity)}</span>
      </div>`).join('');
    const subtotal = items.reduce((s, i) => s + i.price * i.quantity, 0);
    const shipping = subtotal >= FREE_SHIPPING ? 0 : SHIPPING_FEE;
    document.getElementById('co-subtotal').textContent = fmt(subtotal);
    document.getElementById('co-shipping').textContent = shipping === 0 ? 'Gratis' : fmt(shipping);
    document.getElementById('co-total').textContent = fmt(subtotal + shipping);
  }
  renderSummary();

  document.getElementById('checkout-form').addEventListener('submit', e => {
    e.preventDefault();
    const form = e.target;
    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach(input => {
      input.style.borderColor = '';
      if (!input.value.trim()) { input.style.borderColor = '#DC2626'; valid = false; }
    });
    if (!valid) return;
    localStorage.removeItem('verde_cart');
    window.dispatchEvent(new CustomEvent('cart:updated', { detail: { items: [] } }));
    document.querySelector('.checkout-layout').style.display = 'none';
    const success = document.getElementById('success-section');
    success.style.display = 'block';
    const orderNum = 'ORD-' + Date.now().toString().slice(-6);
    document.getElementById('success-order-num').textContent = 'Ordrenummer: ' + orderNum;
  });
</script>
