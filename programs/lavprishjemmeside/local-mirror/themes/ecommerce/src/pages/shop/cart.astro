---
import ThemeLayout from '../../layouts/ThemeLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<ThemeLayout title="Din kurv">
  <Nav />
  <main>
    <section class="section-py">
      <div class="container-inner cart-page">
        <h1>Din kurv</h1>
        <div class="cart-layout" id="cart-layout">
          <div class="cart-items" id="cart-items">
            <div class="empty-state" id="empty-state" style="display:none;">
              <p>Din kurv er tom</p>
              <a href="/shop" class="btn-primary" style="display:inline-flex;margin-top:1rem;">Gå til shoppen →</a>
            </div>
          </div>
          <div class="cart-summary" id="cart-summary">
            <h3>Ordresammendrag</h3>
            <div class="summary-row"><span>Subtotal</span><span id="subtotal">—</span></div>
            <div class="summary-row shipping"><span>Fragt</span><span id="shipping-cost">—</span></div>
            <div class="shipping-progress" id="shipping-progress"></div>
            <div class="summary-row total"><span>Total</span><span id="total-price">—</span></div>
            <a href="/shop/checkout" class="btn-primary" style="width:100%;display:flex;justify-content:center;margin-top:1.25rem;" id="checkout-btn">Gå til kassen →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</ThemeLayout>

<style>
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 2rem; }
  .cart-layout { display: grid; grid-template-columns: 1fr 340px; gap: 3rem; align-items: start; }
  .cart-item { display: grid; grid-template-columns: 80px 1fr auto; gap: 1rem; align-items: center; padding: 1rem 0; border-bottom: 1px solid var(--color-border); }
  .cart-item img { width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-md); }
  .item-name { font-weight: 600; font-size: 0.95rem; margin-bottom: 0.25rem; }
  .item-price { font-size: 0.85rem; color: var(--color-text-secondary); }
  .qty-row { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; }
  .qty-btn { width: 1.75rem; height: 1.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background: none; cursor: pointer; font-size: 0.9rem; transition: background 150ms; }
  .qty-btn:hover { background: var(--color-neutral-100); }
  .qty-val { font-size: 0.9rem; font-weight: 600; min-width: 1.5rem; text-align: center; }
  .remove-btn { background: none; border: none; cursor: pointer; color: var(--color-text-secondary); font-size: 0.8rem; padding: 0.25rem; transition: color 150ms; }
  .remove-btn:hover { color: #DC2626; }
  .cart-summary { background: var(--color-neutral-50); border: 1px solid var(--color-border); border-radius: var(--radius-card); padding: 1.5rem; position: sticky; top: 100px; }
  .cart-summary h3 { font-size: 1.1rem; margin-bottom: 1.25rem; }
  .summary-row { display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 0.75rem; color: var(--color-text-secondary); }
  .summary-row.total { font-size: 1.1rem; font-weight: 700; color: var(--color-text-primary); border-top: 1px solid var(--color-border); padding-top: 0.75rem; margin-top: 0.25rem; }
  .shipping-progress { background: var(--color-neutral-200); border-radius: var(--radius-full); height: 4px; margin: 0.25rem 0 0.75rem; overflow: hidden; }
  .shipping-progress-bar { height: 100%; background: var(--color-primary); border-radius: var(--radius-full); transition: width 400ms ease; }
  .free-shipping-msg { font-size: 0.78rem; color: var(--color-primary); margin-bottom: 0.5rem; }
  @media (max-width: 768px) { .cart-layout { grid-template-columns: 1fr; } }
</style>
<script>
  const FREE_SHIPPING_THRESHOLD = 50000;
  const SHIPPING_FEE = 4900;

  function fmt(ore) { return (ore / 100).toLocaleString('da-DK', { style: 'currency', currency: 'DKK', minimumFractionDigits: 0 }); }

  function render() {
    const cart = (() => { try { return JSON.parse(localStorage.getItem('verde_cart') || '{"items":[]}'); } catch { return { items: [] }; } })();
    const items = cart.items || [];
    const itemsContainer = document.getElementById('cart-items');
    const emptyState = document.getElementById('empty-state');

    if (items.length === 0) {
      emptyState.style.display = 'block';
      document.getElementById('checkout-btn').style.display = 'none';
    } else {
      emptyState.style.display = 'none';
      document.getElementById('checkout-btn').style.display = 'flex';
      const existing = itemsContainer.querySelectorAll('.cart-item');
      existing.forEach(el => el.remove());
      items.forEach(item => {
        const div = document.createElement('div');
        div.className = 'cart-item';
        div.dataset.id = item.id;
        div.innerHTML = `
          <img src="${item.image || ''}" alt="${item.name}" onerror="this.style.display='none'" />
          <div>
            <p class="item-name">${item.name}</p>
            <p class="item-price">${fmt(item.price)} pr. stk.</p>
            <div class="qty-row">
              <button class="qty-btn" data-action="minus" data-id="${item.id}">−</button>
              <span class="qty-val">${item.quantity}</span>
              <button class="qty-btn" data-action="plus" data-id="${item.id}">+</button>
            </div>
          </div>
          <div style="text-align:right;">
            <strong>${fmt(item.price * item.quantity)}</strong>
            <br/><button class="remove-btn" data-id="${item.id}" aria-label="Fjern ${item.name}">Fjern</button>
          </div>`;
        itemsContainer.appendChild(div);
      });
    }

    const subtotal = items.reduce((s, i) => s + i.price * i.quantity, 0);
    const shipping = subtotal >= FREE_SHIPPING_THRESHOLD ? 0 : SHIPPING_FEE;
    const total = subtotal + shipping;
    document.getElementById('subtotal').textContent = fmt(subtotal);
    document.getElementById('shipping-cost').textContent = shipping === 0 ? 'Gratis' : fmt(shipping);
    document.getElementById('total-price').textContent = fmt(total);

    const pct = Math.min((subtotal / FREE_SHIPPING_THRESHOLD) * 100, 100);
    const progressHtml = `<div class="shipping-progress-bar" style="width:${pct}%"></div>`;
    document.getElementById('shipping-progress').innerHTML = progressHtml;
  }

  render();

  document.getElementById('cart-items').addEventListener('click', e => {
    const btn = e.target.closest('[data-action],[data-id].remove-btn');
    if (!btn) return;
    const id = btn.dataset.id;
    const cart = JSON.parse(localStorage.getItem('verde_cart') || '{"items":[]}');
    if (btn.classList.contains('remove-btn')) {
      cart.items = cart.items.filter(i => i.id !== id);
    } else {
      const item = cart.items.find(i => i.id === id);
      if (!item) return;
      if (btn.dataset.action === 'plus') item.quantity++;
      else if (btn.dataset.action === 'minus') { item.quantity--; if (item.quantity <= 0) cart.items = cart.items.filter(i => i.id !== id); }
    }
    localStorage.setItem('verde_cart', JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
    render();
  });

  window.addEventListener('cart:updated', render);
</script>
