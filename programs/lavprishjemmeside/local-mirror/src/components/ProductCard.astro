---
import PriceDisplay from './PriceDisplay.astro';

interface Props {
  id: number;
  name: string;
  slug: string;
  short_desc?: string;
  price_ore: number;
  compare_ore?: number;
  primary_image?: string;
  category_slug?: string;
  is_featured?: boolean;
  stock?: number;
  track_stock?: boolean;
}

const {
  id, name, slug, short_desc, price_ore, compare_ore,
  primary_image, is_featured, stock, track_stock,
} = Astro.props;

const href = `/shop/produkt/${slug}/`;
const isLow = track_stock && stock !== undefined && stock > 0 && stock <= 5;
const isOut = track_stock && stock !== undefined && stock === 0;
const imgSrc = primary_image || '/favicon.svg';
---

<article class="product-card" data-product-id={id}>
  <a href={href} class="product-card-img-link" tabindex="-1" aria-hidden="true">
    <img
      src={imgSrc}
      alt={name}
      width="400"
      height="400"
      loading="lazy"
      decoding="async"
      class="product-card-img"
    />
  </a>

  <div class="product-card-badges">
    {is_featured && (
      <span class="pc-badge pc-badge-featured">Anbefalet</span>
    )}
    {compare_ore && compare_ore > price_ore && (
      <span class="pc-badge pc-badge-sale">Tilbud</span>
    )}
    {isOut && (
      <span class="pc-badge pc-badge-out">Udsolgt</span>
    )}
    {isLow && !isOut && (
      <span class="pc-badge pc-badge-low">Få tilbage</span>
    )}
  </div>

  <div class="product-card-body">
    <a href={href} class="product-card-name-link">
      <h3 class="product-card-name">{name}</h3>
    </a>
    {short_desc && (
      <p class="product-card-desc">{short_desc}</p>
    )}
    <div class="product-card-footer">
      <PriceDisplay ore={price_ore} compareOre={compare_ore} showVat={true} />
      <button
        type="button"
        class="add-to-cart-btn product-card-cta"
        data-product-id={id}
        data-product-name={name}
        data-price-ore={price_ore}
        data-slug={slug}
        disabled={isOut}
        aria-label={`Tilføj ${name} til kurv`}
      >
        {isOut ? 'Udsolgt' : 'Tilføj'}
      </button>
    </div>
  </div>
</article>

<style>
.product-card {
  position: relative;
  display: flex;
  flex-direction: column;
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  background: var(--color-bg-card, var(--color-bg-page));
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 200ms ease;
}
.product-card:hover { box-shadow: var(--shadow-md); }
.product-card-img-link {
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--color-neutral-100);
}
.product-card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 300ms ease;
}
.product-card:hover .product-card-img { transform: scale(1.05); }
.product-card-badges {
  position: absolute;
  top: 8px;
  left: 8px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.pc-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 9999px;
  color: #fff;
}
.pc-badge-featured { background: var(--color-primary); color: var(--color-text-on-primary); }
.pc-badge-sale { background: var(--color-danger, #e53e3e); }
.pc-badge-out { background: #6b7280; }
.pc-badge-low { background: #f97316; }
.product-card-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 16px;
  flex: 1;
}
.product-card-name-link { display: block; text-decoration: none; }
.product-card-name {
  font-weight: 600;
  font-size: 0.9375rem;
  color: var(--color-text-primary);
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color 150ms;
  margin: 0;
}
.product-card:hover .product-card-name { color: var(--color-primary); }
.product-card-desc {
  font-size: 0.8125rem;
  color: var(--color-text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}
.product-card-footer {
  margin-top: auto;
  padding-top: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.product-card-cta {
  flex-shrink: 0;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: var(--color-text-on-primary);
  padding: 6px 12px;
  font-size: 0.8125rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: opacity 150ms;
}
.product-card-cta:hover:not(:disabled) { opacity: 0.9; }
.product-card-cta:disabled { opacity: 0.4; cursor: not-allowed; }
</style>
