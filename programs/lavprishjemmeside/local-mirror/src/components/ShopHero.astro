---
/**
 * ShopHero — shop landing page hero section.
 *
 * AI component schema: see api/src/component-docs/shop-hero.md
 */
interface Props {
  heading: string;
  subheading?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageUrl?: string;
  imageAlt?: string;
  badge?: string;
}

const {
  heading,
  subheading,
  ctaLabel = 'Se alle produkter',
  ctaHref = '/shop/',
  secondaryLabel,
  secondaryHref,
  imageUrl,
  imageAlt = '',
  badge,
} = Astro.props;
---

<section class="shop-hero">
  <div class="shop-hero-inner">

    <div class="shop-hero-text" data-reveal>
      {badge && (
        <span class="shop-hero-badge">{badge}</span>
      )}
      <h1 class="shop-hero-heading">{heading}</h1>
      {subheading && (
        <p class="shop-hero-subheading">{subheading}</p>
      )}
      <div class="shop-hero-actions">
        <a href={ctaHref} class="shop-hero-cta-primary">{ctaLabel}</a>
        {secondaryLabel && secondaryHref && (
          <a href={secondaryHref} class="shop-hero-cta-secondary">{secondaryLabel}</a>
        )}
      </div>
    </div>

    {imageUrl && (
      <div class="shop-hero-img-wrap" data-reveal>
        <img
          src={imageUrl}
          alt={imageAlt}
          width="600"
          height="500"
          loading="eager"
          decoding="async"
          class="shop-hero-img"
        />
      </div>
    )}
  </div>
</section>

<style>
.shop-hero {
  position: relative;
  overflow: hidden;
  background: var(--color-bg-subtle, var(--color-neutral-100));
}
.shop-hero-inner {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 64px var(--container-padding-x);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48px;
}
@media (min-width: 768px) {
  .shop-hero-inner {
    flex-direction: row;
    padding-top: 96px;
    padding-bottom: 96px;
  }
}
.shop-hero-text {
  flex: 1;
  text-align: center;
}
@media (min-width: 768px) {
  .shop-hero-text { text-align: left; }
}
.shop-hero-badge {
  display: inline-block;
  margin-bottom: 16px;
  border-radius: 9999px;
  border: 1px solid var(--color-primary);
  padding: 4px 16px;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-primary);
}
.shop-hero-heading {
  font-size: clamp(2rem, 5vw, 3.75rem);
  font-weight: 800;
  line-height: 1.15;
  color: var(--color-text-primary);
  margin: 0;
}
.shop-hero-subheading {
  margin: 16px 0 0;
  font-size: 1.125rem;
  color: var(--color-text-secondary);
  max-width: 32rem;
  margin-left: auto;
  margin-right: auto;
}
@media (min-width: 768px) {
  .shop-hero-subheading { margin-left: 0; margin-right: 0; }
}
.shop-hero-actions {
  margin-top: 32px;
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
}
@media (min-width: 768px) {
  .shop-hero-actions { justify-content: flex-start; }
}
.shop-hero-cta-primary {
  display: inline-flex;
  min-height: 48px;
  align-items: center;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  padding: 12px 24px;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-on-primary);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
  transition: opacity 150ms;
}
.shop-hero-cta-primary:hover { opacity: 0.9; }
.shop-hero-cta-secondary {
  display: inline-flex;
  min-height: 48px;
  align-items: center;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  padding: 12px 24px;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-primary);
  text-decoration: none;
  transition: background 150ms;
}
.shop-hero-cta-secondary:hover { background: var(--color-neutral-100); }
.shop-hero-img-wrap {
  flex: 1;
  width: 100%;
  max-width: 32rem;
}
.shop-hero-img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-xl, var(--radius-lg));
  box-shadow: var(--shadow-lg);
  object-fit: cover;
  aspect-ratio: 6 / 5;
}
</style>
