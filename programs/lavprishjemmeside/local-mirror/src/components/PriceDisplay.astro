---
/**
 * PriceDisplay — Danish price formatting component.
 * Prices stored as øre (integers). 9995 = 99,95 kr.
 */
interface Props {
  ore: number;
  compareOre?: number;
  showVat?: boolean;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { ore, compareOre, showVat = false, size = 'md', class: cls = '' } = Astro.props;

function formatDkk(ore: number): string {
  return (ore / 100).toFixed(2).replace('.', ',') + ' kr.';
}

const isDiscounted = compareOre && compareOre > ore;
---

<span class:list={['price-display', `price-display--${size}`, cls]}>
  <span class:list={['price-display__current', isDiscounted ? 'price-display__current--sale' : '']}>
    {formatDkk(ore)}
  </span>
  {isDiscounted && (
    <span class="price-display__compare">
      {formatDkk(compareOre!)}
    </span>
  )}
  {showVat && (
    <span class="price-display__vat">inkl. moms</span>
  )}
</span>

<style>
.price-display {
  display: inline-flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8px;
}
.price-display__current {
  font-weight: 600;
  color: var(--color-text-primary);
}
.price-display__current--sale {
  color: var(--color-danger, #e53e3e);
}
.price-display__compare {
  color: var(--color-text-secondary);
  text-decoration: line-through;
  font-size: 0.875rem;
  font-weight: 400;
}
.price-display__vat {
  color: var(--color-text-secondary);
  font-size: 0.75rem;
  font-weight: 400;
}
.price-display--sm { font-size: 0.875rem; }
.price-display--md { font-size: 1rem; }
.price-display--lg { font-size: 1.5rem; font-weight: 700; }
</style>
