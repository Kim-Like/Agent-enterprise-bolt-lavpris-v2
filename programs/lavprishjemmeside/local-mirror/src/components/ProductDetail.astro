---
import PriceDisplay from './PriceDisplay.astro';

interface Variant {
  id: number;
  name: string;
  price_ore: number | null;
  stock: number;
  is_active: boolean;
}
interface ProductImage {
  id: number;
  url: string;
  alt?: string;
  is_primary?: boolean;
}

interface Props {
  id: number;
  name: string;
  slug: string;
  description?: string;
  short_desc?: string;
  price_ore: number;
  compare_ore?: number;
  variants?: Variant[];
  images?: ProductImage[];
  stock?: number;
  track_stock?: boolean;
  category_name?: string;
  category_slug?: string;
  weight_g?: number;
  apiUrl: string;
}

const {
  id, name, description, short_desc, price_ore, compare_ore,
  variants = [], images = [], stock = 0, track_stock = true,
  category_name, category_slug, apiUrl,
} = Astro.props;

const primaryImage = images.find(i => i.is_primary) || images[0];
const hasVariants = variants.length > 0;
const isOut = track_stock && !hasVariants && stock === 0;
const stockStatusClass = isOut ? 'pd-stock-out' : 'pd-stock-in';
const stockStatusText = isOut
  ? 'Udsolgt'
  : track_stock && stock && stock <= 5
    ? `Kun ${stock} tilbage på lager`
    : 'På lager';
---

<article class="product-detail">
  {category_name && (
    <nav class="pd-breadcrumb" aria-label="Brødkrumme">
      <a href="/shop/" class="pd-breadcrumb-link">Shop</a>
      <span class="pd-breadcrumb-sep">›</span>
      {category_slug && (
        <>
          <a href={`/shop/${category_slug}/`} class="pd-breadcrumb-link">{category_name}</a>
          <span class="pd-breadcrumb-sep">›</span>
        </>
      )}
      <span class="pd-breadcrumb-current">{name}</span>
    </nav>
  )}

  <div class="pd-layout">
    <div class="pd-images">
      <div class="pd-main-img-wrap">
        <img
          id="main-product-image"
          src={primaryImage?.url || '/favicon.svg'}
          alt={primaryImage?.alt || name}
          width="600"
          height="600"
          loading="eager"
          decoding="async"
          class="pd-main-img"
        />
      </div>
      {images.length > 1 && (
        <div class="pd-thumbs">
          {images.map(img => (
            <button
              type="button"
              class="product-thumb pd-thumb"
              data-src={img.url}
              data-alt={img.alt || name}
              aria-label={`Vis billede: ${img.alt || name}`}
            >
              <img src={img.url} alt={img.alt || name} width="64" height="64" class="pd-thumb-img" loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </div>

    <div class="pd-info">
      <div>
        <h1 class="pd-name">{name}</h1>
        {short_desc && <p class="pd-short-desc">{short_desc}</p>}
      </div>

      <div class="pd-price-row">
        <PriceDisplay ore={price_ore} compareOre={compare_ore} showVat={true} size="lg" id="detail-price" />
      </div>

      <div id="stock-status" class:list={['pd-stock', stockStatusClass]}>
        {stockStatusText}
      </div>

      {hasVariants && (
        <div class="pd-variants">
          <label class="pd-field-label" for="variant-select">Vælg variant:</label>
          <select id="variant-select" class="pd-select">
            <option value="">Vælg...</option>
            {variants.filter(v => v.is_active).map(v => (
              <option
                value={v.id}
                data-price={v.price_ore ?? price_ore}
                data-stock={v.stock}
                disabled={v.stock === 0}
              >
                {v.name}{v.stock === 0 ? ' (udsolgt)' : ''}
              </option>
            ))}
          </select>
        </div>
      )}

      <div class="pd-qty-row">
        <label class="pd-field-label" for="qty-input">Antal:</label>
        <div class="pd-qty-control">
          <button type="button" id="qty-minus" class="pd-qty-btn" aria-label="Minimer antal">−</button>
          <input id="qty-input" type="number" value="1" min="1" max="99" class="pd-qty-input" />
          <button type="button" id="qty-plus" class="pd-qty-btn" aria-label="Forøg antal">+</button>
        </div>
      </div>

      <button
        type="button"
        id="add-to-cart-detail"
        class="pd-add-btn"
        disabled={isOut}
        data-product-id={id}
        data-product-name={name}
        data-price-ore={price_ore}
      >
        {isOut ? 'Udsolgt' : 'Tilføj til kurv'}
      </button>

      {description && (
        <div class="pd-description">
          <h2 class="pd-desc-title">Beskrivelse</h2>
          <div class="pd-desc-body" set:html={description} />
        </div>
      )}
    </div>
  </div>
</article>

<style>
.product-detail {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 48px var(--container-padding-x);
}
.pd-breadcrumb {
  margin-bottom: 24px;
  font-size: 0.875rem;
  color: var(--color-text-secondary);
}
.pd-breadcrumb-link {
  color: inherit;
  text-decoration: none;
  transition: color 150ms;
}
.pd-breadcrumb-link:hover { color: var(--color-primary); }
.pd-breadcrumb-sep { margin: 0 8px; }
.pd-breadcrumb-current { color: var(--color-text-primary); }
.pd-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
}
@media (min-width: 1024px) {
  .pd-layout { grid-template-columns: 1fr 1fr; }
}
.pd-main-img-wrap {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--radius-lg);
  background: var(--color-neutral-100);
  margin-bottom: 12px;
}
.pd-main-img { width: 100%; height: 100%; object-fit: cover; }
.pd-thumbs {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 4px;
}
.pd-thumb {
  flex-shrink: 0;
  width: 64px;
  height: 64px;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 2px solid transparent;
  padding: 0;
  cursor: pointer;
  background: none;
  transition: border-color 150ms;
}
.pd-thumb:hover { border-color: var(--color-primary); }
.pd-thumb-img { width: 100%; height: 100%; object-fit: cover; }
.pd-info {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.pd-name {
  font-size: 1.875rem;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
  margin: 0;
}
.pd-short-desc {
  margin: 8px 0 0;
  color: var(--color-text-secondary);
}
.pd-price-row {
  padding: 12px 0;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.pd-stock { font-size: 0.875rem; font-weight: 500; }
.pd-stock-in { color: #16a34a; }
.pd-stock-out { color: #dc2626; }
.pd-field-label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8px;
}
.pd-select {
  width: 100%;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  padding: 8px 12px;
  font-size: 0.875rem;
  outline: none;
  transition: border-color 150ms, box-shadow 150ms;
}
.pd-select:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
}
.pd-qty-row { display: flex; align-items: center; gap: 12px; }
.pd-qty-control {
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.pd-qty-btn {
  padding: 8px 12px;
  font-size: 1.125rem;
  line-height: 1;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-primary);
  transition: background 150ms;
}
.pd-qty-btn:hover { background: var(--color-neutral-100); }
.pd-qty-input {
  width: 56px;
  text-align: center;
  border: none;
  padding: 8px 0;
  font-size: 0.875rem;
  outline: none;
  background: transparent;
}
.pd-add-btn {
  width: 100%;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: var(--color-text-on-primary);
  padding: 16px 24px;
  font-size: 1rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  transition: opacity 150ms;
}
.pd-add-btn:hover:not(:disabled) { opacity: 0.9; }
.pd-add-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.pd-description {
  padding-top: 16px;
  border-top: 1px solid var(--color-border);
}
.pd-desc-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 0 8px;
}
.pd-desc-body {
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
</style>

<script>
  import { addToCart } from '../scripts/cart.js';

  const btn = document.getElementById('add-to-cart-detail') as HTMLButtonElement | null;
  const variantSelect = document.getElementById('variant-select') as HTMLSelectElement | null;
  const qtyInput = document.getElementById('qty-input') as HTMLInputElement | null;
  const qtyMinus = document.getElementById('qty-minus');
  const qtyPlus = document.getElementById('qty-plus');
  const mainImg = document.getElementById('main-product-image') as HTMLImageElement | null;

  document.querySelectorAll('.product-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => {
      const src = (thumb as HTMLElement).dataset.src;
      const alt = (thumb as HTMLElement).dataset.alt;
      if (mainImg && src) { mainImg.src = src; mainImg.alt = alt || ''; }
    });
  });

  qtyMinus?.addEventListener('click', () => {
    if (!qtyInput) return;
    const v = parseInt(qtyInput.value) || 1;
    if (v > 1) qtyInput.value = String(v - 1);
  });
  qtyPlus?.addEventListener('click', () => {
    if (!qtyInput) return;
    const v = parseInt(qtyInput.value) || 1;
    if (v < 99) qtyInput.value = String(v + 1);
  });

  variantSelect?.addEventListener('change', () => {
    const opt = variantSelect.selectedOptions[0];
    const stockEl = document.getElementById('stock-status');
    const variantStock = parseInt(opt?.dataset.stock || '99');

    if (stockEl) {
      if (!opt?.value) {
        stockEl.textContent = '';
      } else if (variantStock === 0) {
        stockEl.textContent = 'Udsolgt';
        stockEl.className = 'pd-stock pd-stock-out';
      } else if (variantStock <= 5) {
        stockEl.textContent = `Kun ${variantStock} tilbage`;
        stockEl.className = 'pd-stock';
        (stockEl as HTMLElement).style.color = '#ea580c';
      } else {
        stockEl.textContent = 'På lager';
        stockEl.className = 'pd-stock pd-stock-in';
      }
    }

    if (btn) btn.disabled = variantStock === 0 || !opt?.value;
  });

  btn?.addEventListener('click', () => {
    const productId = parseInt(btn.dataset.productId || '0');
    const name = btn.dataset.productName || '';
    let priceOre = parseInt(btn.dataset.priceOre || '0');
    let variantId: number | null = null;
    let variantName: string | null = null;

    if (variantSelect?.value) {
      variantId = parseInt(variantSelect.value);
      variantName = variantSelect.selectedOptions[0]?.text.replace(' (udsolgt)', '') || null;
      const variantPrice = parseInt(variantSelect.selectedOptions[0]?.dataset.price || '0');
      if (variantPrice > 0) priceOre = variantPrice;
    }

    const qty = Math.max(1, parseInt(qtyInput?.value || '1'));

    addToCart({ product_id: productId, variant_id: variantId, quantity: qty, name, variant_name: variantName, price_ore: priceOre });

    const orig = btn.textContent;
    btn.textContent = 'Tilføjet til kurv ✓';
    btn.disabled = true;
    setTimeout(() => {
      btn.textContent = orig;
      btn.disabled = false;
    }, 1800);
  });
</script>
