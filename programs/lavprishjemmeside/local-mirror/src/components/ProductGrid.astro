---
/**
 * ProductGrid — responsive 2-4 column product grid.
 *
 * AI component schema: see api/src/component-docs/product-grid.md
 */
import ProductCard from './ProductCard.astro';

interface Product {
  id: number;
  name: string;
  slug: string;
  short_desc?: string;
  price_ore: number;
  compare_ore?: number;
  primary_image?: string;
  category_slug?: string;
  is_featured?: boolean;
  stock?: number;
  track_stock?: boolean;
}

interface Props {
  products: Product[];
  title?: string;
  description?: string;
  columns?: 2 | 3 | 4;
  showEmpty?: boolean;
  emptyText?: string;
}

const {
  products = [],
  title,
  description,
  columns = 3,
  showEmpty = true,
  emptyText = 'Ingen produkter fundet.',
} = Astro.props;
---

<section class="product-grid-section">
  {(title || description) && (
    <div class="product-grid-header">
      {title && <h2 class="product-grid-title">{title}</h2>}
      {description && <p class="product-grid-desc">{description}</p>}
    </div>
  )}

  {products.length > 0 ? (
    <ul class:list={['product-grid', `product-grid-cols-${columns}`]} role="list">
      {products.map(product => (
        <li>
          <ProductCard {...product} />
        </li>
      ))}
    </ul>
  ) : showEmpty ? (
    <div class="product-grid-empty">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <p>{emptyText}</p>
    </div>
  ) : null}
</section>

<style>
.product-grid-header {
  margin-bottom: 32px;
  text-align: center;
}
.product-grid-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}
.product-grid-desc {
  margin: 8px 0 0;
  color: var(--color-text-secondary);
}
.product-grid {
  display: grid;
  gap: 24px;
  list-style: none;
  margin: 0;
  padding: 0;
}
.product-grid-cols-2 { grid-template-columns: repeat(1, 1fr); }
.product-grid-cols-3 { grid-template-columns: repeat(1, 1fr); }
.product-grid-cols-4 { grid-template-columns: repeat(1, 1fr); }
@media (min-width: 640px) {
  .product-grid-cols-2 { grid-template-columns: repeat(2, 1fr); }
  .product-grid-cols-3 { grid-template-columns: repeat(2, 1fr); }
  .product-grid-cols-4 { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .product-grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
  .product-grid-cols-4 { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 1280px) {
  .product-grid-cols-4 { grid-template-columns: repeat(4, 1fr); }
}
.product-grid-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 0;
  color: var(--color-text-secondary);
}
.product-grid-empty svg {
  margin-bottom: 16px;
  opacity: 0.4;
}
</style>

<script>
  import { addToCart } from '../scripts/cart.js';

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.add-to-cart-btn');
    if (!btn || btn.hasAttribute('disabled')) return;

    const productId = parseInt(btn.getAttribute('data-product-id') || '0');
    const name = btn.getAttribute('data-product-name') || '';
    const priceOre = parseInt(btn.getAttribute('data-price-ore') || '0');

    if (!productId) return;

    addToCart({ product_id: productId, name, price_ore: priceOre, quantity: 1 });

    const orig = btn.textContent;
    btn.textContent = 'Tilføjet ✓';
    btn.setAttribute('disabled', '');
    setTimeout(() => {
      btn.textContent = orig;
      btn.removeAttribute('disabled');
    }, 1500);
  });
</script>
