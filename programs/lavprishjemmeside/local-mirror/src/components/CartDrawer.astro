---
/**
 * CartDrawer — slide-out cart panel (right side).
 * Toggled open/closed via the data attribute `data-cart-open`.
 */
---

<div
  id="cart-backdrop"
  class="cart-backdrop"
  aria-hidden="true"
></div>

<aside
  id="cart-drawer"
  class="cart-drawer"
  aria-label="Kurv"
  role="dialog"
  aria-modal="true"
>
  <div class="cd-header">
    <h2 class="cd-title">Din kurv</h2>
    <button
      id="cart-close"
      type="button"
      class="cd-close-btn"
      aria-label="Luk kurv"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div id="cart-items" class="cd-items">
    <div id="cart-empty" class="cd-empty" style="display:none">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" class="cd-empty-icon" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <p class="cd-empty-text">Kurven er tom</p>
      <a href="/shop/" class="cd-empty-link">Gå til shoppen</a>
    </div>
    <ul id="cart-list" class="cd-list" aria-label="Varer i kurven"></ul>
  </div>

  <div id="cart-footer" class="cd-footer" style="display:none">
    <div class="cd-subtotal-row">
      <span class="cd-subtotal-label">Subtotal</span>
      <span id="cart-subtotal" class="cd-subtotal-value">0,00 kr.</span>
    </div>
    <p class="cd-shipping-note">Fragt beregnes ved checkout.</p>
    <a href="/shop/checkout/" class="cd-checkout-btn">Til betaling</a>
    <a href="/shop/kurv/" class="cd-cart-link">Se kurven</a>
  </div>
</aside>

<style>
.cart-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 40;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
}
.cart-backdrop.is-open { display: block; }

.cart-drawer {
  position: fixed;
  top: 0;
  right: 0;
  z-index: 50;
  height: 100%;
  width: 100%;
  max-width: 24rem;
  background: var(--color-bg-page);
  box-shadow: var(--shadow-xl, 0 20px 60px rgba(0,0,0,0.2));
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 300ms ease-in-out;
}
.cart-drawer.is-open { transform: translateX(0); }

.cd-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--color-border);
}
.cd-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}
.cd-close-btn {
  padding: 8px;
  border-radius: var(--radius-md);
  color: var(--color-text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  transition: background 150ms;
}
.cd-close-btn:hover { background: var(--color-neutral-100); }

.cd-items {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
}
.cd-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  text-align: center;
  color: var(--color-text-secondary);
  padding: 48px 0;
}
.cd-empty-icon { margin-bottom: 16px; opacity: 0.3; }
.cd-empty-text { font-weight: 500; margin: 0; }
.cd-empty-link {
  margin-top: 16px;
  font-size: 0.875rem;
  color: var(--color-primary);
  text-decoration: none;
}
.cd-empty-link:hover { text-decoration: underline; }

.cd-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.cd-footer {
  border-top: 1px solid var(--color-border);
  padding: 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.cd-subtotal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 0.875rem;
}
.cd-subtotal-label { color: var(--color-text-secondary); }
.cd-subtotal-value { font-weight: 700; color: var(--color-text-primary); }
.cd-shipping-note { font-size: 0.75rem; color: var(--color-text-secondary); margin: 0; }
.cd-checkout-btn {
  display: block;
  width: 100%;
  text-align: center;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  padding: 12px 24px;
  font-weight: 600;
  color: var(--color-text-on-primary);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
  transition: opacity 150ms;
}
.cd-checkout-btn:hover { opacity: 0.9; }
.cd-cart-link {
  display: block;
  text-align: center;
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  text-decoration: none;
}
.cd-cart-link:hover { color: var(--color-primary); }

.cd-item { display: flex; gap: 12px; }
.cd-item-img-wrap {
  flex-shrink: 0;
  width: 64px;
  height: 64px;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-neutral-100);
}
.cd-item-img { width: 100%; height: 100%; object-fit: cover; }
.cd-item-body { flex: 1; min-width: 0; }
.cd-item-name {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0;
}
.cd-item-variant { font-size: 0.75rem; color: var(--color-text-secondary); margin: 0; }
.cd-item-price { font-size: 0.875rem; font-weight: 600; margin: 4px 0 0; }
.cd-item-controls {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}
.cd-qty-btn {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  border: 1px solid var(--color-border);
  background: none;
  font-size: 0.875rem;
  cursor: pointer;
  color: var(--color-text-primary);
}
.cd-qty-count { font-size: 0.875rem; width: 20px; text-align: center; }
.cd-remove-btn {
  margin-left: 4px;
  font-size: 0.75rem;
  color: #ef4444;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}
.cd-remove-btn:hover { text-decoration: underline; }
</style>

<script>
  import { getCart, setQuantity, removeFromCart, getCartTotal } from '../scripts/cart.js';

  const drawer = document.getElementById('cart-drawer');
  const backdrop = document.getElementById('cart-backdrop');
  const closeBtn = document.getElementById('cart-close');
  const itemsList = document.getElementById('cart-list');
  const emptyMsg = document.getElementById('cart-empty');
  const footer = document.getElementById('cart-footer');
  const subtotalEl = document.getElementById('cart-subtotal');

  function formatDkk(ore: number): string {
    return (ore / 100).toFixed(2).replace('.', ',') + ' kr.';
  }

  function renderCart() {
    if (!itemsList) return;
    const { items } = getCart();
    itemsList.innerHTML = '';

    if (items.length === 0) {
      if (emptyMsg) emptyMsg.style.display = 'flex';
      if (footer) footer.style.display = 'none';
      return;
    }

    if (emptyMsg) emptyMsg.style.display = 'none';
    if (footer) footer.style.display = 'flex';

    items.forEach(item => {
      const li = document.createElement('li');
      li.className = 'cd-item';
      li.innerHTML = `
        <div class="cd-item-img-wrap">
          <img src="${item.image_url || '/favicon.svg'}" alt="${item.name}" width="64" height="64" class="cd-item-img" loading="lazy" />
        </div>
        <div class="cd-item-body">
          <p class="cd-item-name">${item.name}</p>
          ${item.variant_name ? `<p class="cd-item-variant">${item.variant_name}</p>` : ''}
          <p class="cd-item-price">${formatDkk(item.price_ore * item.quantity)}</p>
          <div class="cd-item-controls">
            <button class="cd-qty-btn qty-btn" data-action="minus" data-pid="${item.product_id}" data-vid="${item.variant_id ?? ''}">−</button>
            <span class="cd-qty-count">${item.quantity}</span>
            <button class="cd-qty-btn qty-btn" data-action="plus" data-pid="${item.product_id}" data-vid="${item.variant_id ?? ''}">+</button>
            <button class="cd-remove-btn remove-btn" data-pid="${item.product_id}" data-vid="${item.variant_id ?? ''}">Fjern</button>
          </div>
        </div>
      `;
      itemsList.appendChild(li);
    });

    if (subtotalEl) subtotalEl.textContent = formatDkk(getCartTotal());
  }

  itemsList?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const pid = parseInt(target.dataset.pid || '0');
    const vid = target.dataset.vid ? parseInt(target.dataset.vid) : null;

    if (!pid) return;

    const { items } = getCart();
    const item = items.find(i => i.product_id === pid && (i.variant_id ?? null) === (vid ?? null));

    if (target.classList.contains('qty-btn')) {
      const action = target.dataset.action;
      const qty = item ? item.quantity : 0;
      setQuantity(pid, vid, action === 'plus' ? qty + 1 : qty - 1);
    } else if (target.classList.contains('remove-btn')) {
      removeFromCart(pid, vid);
    }
  });

  function openDrawer() {
    renderCart();
    drawer?.classList.add('is-open');
    backdrop?.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeDrawer() {
    drawer?.classList.remove('is-open');
    backdrop?.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });

  document.addEventListener('cart:open', openDrawer);

  window.addEventListener('cart:updated', renderCart);

  renderCart();
</script>
