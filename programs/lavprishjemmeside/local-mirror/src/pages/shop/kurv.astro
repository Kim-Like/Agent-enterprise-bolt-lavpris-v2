---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<Layout title="Kurv — Shop — Lavprishjemmeside.dk" description="Se din indkøbskurv og gå til betaling.">
  <main class="kurv-page">
    <h1 class="kurv-title">Din kurv</h1>

    <div id="cart-loading" class="kurv-loading">Henter kurv...</div>

    <div id="cart-page-content" style="display:none">
      <div class="kurv-layout">
        <div class="kurv-items-col">
          <div id="cart-empty-msg" class="kurv-empty" style="display:none">
            <p class="kurv-empty-text">Kurven er tom</p>
            <a href="/shop/" class="kurv-empty-link">Gå til shoppen</a>
          </div>
          <ul id="kurv-items" class="kurv-list"></ul>
        </div>

        <div id="cart-summary" class="kurv-summary" style="display:none">
          <h2 class="kurv-summary-title">Oversigt</h2>
          <div class="kurv-summary-rows">
            <div class="kurv-summary-row">
              <span class="kurv-summary-label">Subtotal</span>
              <span id="summary-subtotal" class="kurv-summary-value">—</span>
            </div>
            <div class="kurv-summary-row">
              <span class="kurv-summary-label">Fragt</span>
              <span class="kurv-summary-label">Beregnes ved checkout</span>
            </div>
          </div>
          <div class="kurv-summary-total-row">
            <span>Total (ex. fragt)</span>
            <span id="summary-total">—</span>
          </div>
          <p class="kurv-vat-note">Inkl. 25% moms.</p>
          <a href="/shop/checkout/" class="kurv-checkout-btn">Til betaling</a>
          <a href="/shop/" class="kurv-continue-link">Fortsæt med at handle</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
.kurv-page {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 48px var(--container-padding-x);
}
.kurv-title {
  font-size: 1.875rem;
  font-weight: 800;
  color: var(--color-text-primary);
  margin: 0 0 32px;
}
.kurv-loading {
  text-align: center;
  padding: 64px 0;
  color: var(--color-text-secondary);
}
.kurv-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  align-items: start;
}
@media (min-width: 1024px) {
  .kurv-layout { grid-template-columns: 2fr 1fr; }
}
.kurv-empty {
  text-align: center;
  padding: 64px 0;
  color: var(--color-text-secondary);
}
.kurv-empty-text { font-size: 1.125rem; font-weight: 500; margin: 0 0 8px; }
.kurv-empty-link { color: var(--color-primary); text-decoration: none; }
.kurv-empty-link:hover { text-decoration: underline; }
.kurv-list { list-style: none; margin: 0; padding: 0; }
.kurv-item {
  display: flex;
  gap: 16px;
  padding: 20px 0;
  border-bottom: 1px solid var(--color-border);
}
.kurv-item-img-wrap {
  flex-shrink: 0;
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-neutral-100);
}
.kurv-item-img { width: 100%; height: 100%; object-fit: cover; }
.kurv-item-body { flex: 1; min-width: 0; }
.kurv-item-top {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 4px;
}
.kurv-item-name { font-weight: 600; color: var(--color-text-primary); margin: 0; }
.kurv-item-total { font-weight: 700; color: var(--color-text-primary); white-space: nowrap; }
.kurv-item-variant { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0; }
.kurv-item-controls {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 12px;
  flex-wrap: wrap;
}
.kurv-qty-wrap {
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.kurv-qty-btn {
  padding: 6px 12px;
  font-size: 0.875rem;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-primary);
  transition: background 150ms;
}
.kurv-qty-btn:hover { background: var(--color-neutral-100); }
.kurv-qty-count { font-size: 0.875rem; width: 32px; text-align: center; }
.kurv-item-unit { font-size: 0.875rem; color: var(--color-text-secondary); }
.kurv-remove-btn {
  margin-left: auto;
  font-size: 0.875rem;
  color: #ef4444;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}
.kurv-remove-btn:hover { text-decoration: underline; }
.kurv-summary {
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.kurv-summary-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}
.kurv-summary-rows { display: flex; flex-direction: column; gap: 8px; }
.kurv-summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 0.875rem;
}
.kurv-summary-label { color: var(--color-text-secondary); }
.kurv-summary-value { font-weight: 500; }
.kurv-summary-total-row {
  display: flex;
  justify-content: space-between;
  font-weight: 700;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}
.kurv-vat-note { font-size: 0.75rem; color: var(--color-text-secondary); margin: 0; }
.kurv-checkout-btn {
  display: block;
  width: 100%;
  text-align: center;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  padding: 12px 24px;
  font-weight: 600;
  color: var(--color-text-on-primary);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
  transition: opacity 150ms;
}
.kurv-checkout-btn:hover { opacity: 0.9; }
.kurv-continue-link {
  display: block;
  text-align: center;
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  text-decoration: none;
}
.kurv-continue-link:hover { color: var(--color-primary); }
</style>

<script define:vars={{ apiUrl }}>
  import('/shop/../scripts/cart.js').then(({ getCart, setQuantity, removeFromCart, getCartTotal, validateCart }) => {
    init(getCart, setQuantity, removeFromCart, getCartTotal, validateCart);
  }).catch(() => {});

  async function init(getCart, setQuantity, removeFromCart, getCartTotal, validateCart) {
    const loadingEl = document.getElementById('cart-loading');
    const contentEl = document.getElementById('cart-page-content');
    const itemsList = document.getElementById('kurv-items');
    const emptyMsg = document.getElementById('cart-empty-msg');
    const summaryEl = document.getElementById('cart-summary');
    const subtotalEl = document.getElementById('summary-subtotal');
    const totalEl = document.getElementById('summary-total');

    function fmt(ore) {
      return (ore / 100).toFixed(2).replace('.', ',') + ' kr.';
    }

    function render() {
      const { items } = getCart();
      if (loadingEl) loadingEl.style.display = 'none';
      if (contentEl) contentEl.style.display = 'block';

      if (items.length === 0) {
        if (emptyMsg) emptyMsg.style.display = 'block';
        if (summaryEl) summaryEl.style.display = 'none';
        itemsList.innerHTML = '';
        return;
      }

      if (emptyMsg) emptyMsg.style.display = 'none';
      if (summaryEl) summaryEl.style.display = 'flex';

      itemsList.innerHTML = '';
      items.forEach(item => {
        const li = document.createElement('li');
        li.className = 'kurv-item';
        li.innerHTML = `
          <div class="kurv-item-img-wrap">
            <img src="${item.image_url || '/favicon.svg'}" alt="${item.name}" width="80" height="80" class="kurv-item-img" loading="lazy"/>
          </div>
          <div class="kurv-item-body">
            <div class="kurv-item-top">
              <div>
                <p class="kurv-item-name">${item.name}</p>
                ${item.variant_name ? `<p class="kurv-item-variant">${item.variant_name}</p>` : ''}
              </div>
              <p class="kurv-item-total">${fmt(item.price_ore * item.quantity)}</p>
            </div>
            <div class="kurv-item-controls">
              <div class="kurv-qty-wrap">
                <button class="kurv-qty-btn qty-minus" data-pid="${item.product_id}" data-vid="${item.variant_id ?? ''}">−</button>
                <span class="kurv-qty-count">${item.quantity}</span>
                <button class="kurv-qty-btn qty-plus" data-pid="${item.product_id}" data-vid="${item.variant_id ?? ''}">+</button>
              </div>
              <span class="kurv-item-unit">${fmt(item.price_ore)} / stk</span>
              <button class="kurv-remove-btn remove-item" data-pid="${item.product_id}" data-vid="${item.variant_id ?? ''}">Fjern</button>
            </div>
          </div>
        `;
        itemsList.appendChild(li);
      });

      const total = getCartTotal();
      if (subtotalEl) subtotalEl.textContent = fmt(total);
      if (totalEl) totalEl.textContent = fmt(total);
    }

    itemsList?.addEventListener('click', e => {
      const t = e.target;
      const pid = parseInt(t.dataset.pid || '0');
      const vid = t.dataset.vid ? parseInt(t.dataset.vid) : null;
      if (!pid) return;
      const { items } = getCart();
      const item = items.find(i => i.product_id === pid && (i.variant_id ?? null) === (vid ?? null));
      if (t.classList.contains('qty-minus')) setQuantity(pid, vid, (item?.quantity || 1) - 1);
      else if (t.classList.contains('qty-plus')) setQuantity(pid, vid, (item?.quantity || 1) + 1);
      else if (t.classList.contains('remove-item')) removeFromCart(pid, vid);
    });

    window.addEventListener('cart:updated', render);

    await validateCart(apiUrl);
    render();
  }
</script>
