---
import Layout from '../../layouts/Layout.astro';
import ShopHero from '../../components/ShopHero.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import SearchBar from '../../components/SearchBar.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';

let featuredProducts = [];
let categories = [];

try {
  const [prodRes, catRes] = await Promise.all([
    fetch(`${apiUrl}/shop/products?featured=1&limit=8`),
    fetch(`${apiUrl}/shop/categories`),
  ]);
  if (prodRes.ok) {
    const data = await prodRes.json();
    featuredProducts = data.products || [];
  }
  if (catRes.ok) {
    categories = await catRes.json();
  }
} catch {
  // Build continues — pages load with empty state
}
---

<Layout title="Shop — Lavprishjemmeside.dk" description="Køb produkter direkte fra Lavprishjemmeside.dk — hurtig levering, gode priser og nem betaling.">
  <main>
    <ShopHero
      heading="Vores shop"
      subheading="Kvalitetsprodukter til gode priser — hurtig levering overalt i Danmark."
      ctaLabel="Se alle produkter"
      ctaHref="/shop/"
      badge="Officiel shop"
    />

    <section class="shop-index-section shop-search-section">
      <SearchBar />
    </section>

    {categories.length > 0 && (
      <section class="shop-index-section">
        <h2 class="shop-index-section-title">Kategorier</h2>
        <ul class="shop-categories-grid" role="list">
          {categories.map((cat: any) => (
            <li>
              <a href={`/shop/${cat.slug}/`} class="shop-cat-card">
                {cat.image_url && (
                  <img src={cat.image_url} alt={cat.name} width="48" height="48" class="shop-cat-img" loading="lazy" />
                )}
                <span class="shop-cat-name">{cat.name}</span>
                {cat.description && (
                  <span class="shop-cat-desc">{cat.description}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="shop-index-section">
      <ProductGrid
        products={featuredProducts}
        title="Udvalgte produkter"
        description="Håndplukkede favoritter fra vores sortiment."
        columns={4}
        emptyText="Ingen udvalgte produkter endnu."
      />
      {featuredProducts.length > 0 && (
        <div class="shop-index-all-cta">
          <a href="/shop/?all=1" class="shop-index-all-btn">Se alle produkter</a>
        </div>
      )}
    </section>
  </main>
</Layout>

<style>
.shop-index-section {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 48px var(--container-padding-x);
}
.shop-search-section {
  padding-top: 24px;
  padding-bottom: 0;
  display: flex;
  justify-content: center;
}
.shop-search-section :global(.search-bar) {
  max-width: 28rem;
  width: 100%;
}
.shop-index-section-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0 0 24px;
}
.shop-categories-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  list-style: none;
  margin: 0;
  padding: 0;
}
@media (min-width: 640px) {
  .shop-categories-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 768px) {
  .shop-categories-grid { grid-template-columns: repeat(4, 1fr); }
}
.shop-cat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  background: var(--color-bg-card, var(--color-neutral-100));
  padding: 20px;
  text-align: center;
  text-decoration: none;
  transition: border-color 150ms, box-shadow 150ms;
}
.shop-cat-card:hover {
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
}
.shop-cat-img {
  width: 48px;
  height: 48px;
  object-fit: cover;
  border-radius: 9999px;
}
.shop-cat-name {
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--color-text-primary);
}
.shop-cat-desc {
  font-size: 0.75rem;
  color: var(--color-text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.shop-index-all-cta {
  margin-top: 40px;
  text-align: center;
}
.shop-index-all-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  padding: 12px 32px;
  font-weight: 600;
  color: var(--color-text-primary);
  text-decoration: none;
  transition: background 150ms;
}
.shop-index-all-btn:hover { background: var(--color-neutral-100); }
</style>
