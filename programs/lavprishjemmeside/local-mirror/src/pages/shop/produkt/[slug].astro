---
import Layout from '../../../layouts/Layout.astro';
import ProductDetail from '../../../components/ProductDetail.astro';

export async function getStaticPaths() {
  const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
  try {
    const res = await fetch(`${apiUrl}/shop/products?limit=500`);
    if (!res.ok) return [];
    const data = await res.json();
    return (data.products || []).map((p: any) => ({
      params: { slug: p.slug },
      props: { product: p },
    }));
  } catch {
    return [];
  }
}

const { product: staticProduct } = Astro.props;
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';

// Fetch full product data (with variants + images) at build time
let product = staticProduct;
try {
  const res = await fetch(`${apiUrl}/shop/products/${staticProduct.slug}`);
  if (res.ok) product = await res.json();
} catch {}

const schemaMarkup = [{
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.short_desc || product.name,
  image: product.images?.[0]?.url,
  sku: product.sku,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'DKK',
    price: (product.price_ore / 100).toFixed(2),
    availability: (product.track_stock && product.stock === 0)
      ? 'https://schema.org/OutOfStock'
      : 'https://schema.org/InStock',
  }
}];
---

<Layout
  title={product.meta_title || `${product.name} — Shop — Lavprishjemmeside.dk`}
  description={product.meta_desc || product.short_desc || product.name}
  schemaMarkup={schemaMarkup}
  ogImage={product.images?.[0]?.url}
>
  <main>
    <ProductDetail {...product} apiUrl={apiUrl} />

    <!-- Reviews section -->
    <div class="reviews-section" id="reviews-section">
      <div class="reviews-inner">
        <h2 class="reviews-title">Kundeanmeldelser</h2>
        <div id="reviews-loading" class="reviews-loading">Henter anmeldelser…</div>
        <div id="reviews-summary" style="display:none;" class="reviews-summary"></div>
        <div id="reviews-list" class="reviews-list"></div>
        <div id="reviews-empty" style="display:none;" class="reviews-empty">Vær den første til at anmelde dette produkt.</div>

        <div class="review-form-wrap">
          <h3 class="review-form-title">Skriv en anmeldelse</h3>
          <div id="review-success" class="review-success" style="display:none;">Tak for din anmeldelse! Den afventer godkendelse.</div>
          <div id="review-error" class="review-error" style="display:none;"></div>
          <form id="review-form" class="review-form" novalidate>
            <div class="review-stars" id="star-selector" role="radiogroup" aria-label="Vælg bedømmelse">
              {[1,2,3,4,5].map(n => (
                <button type="button" class="review-star" data-val={String(n)} aria-label={`${n} stjerner`}>&#9733;</button>
              ))}
            </div>
            <input type="hidden" id="review-rating" value="">
            <div class="review-field">
              <label class="review-label" for="review-name">Navn</label>
              <input type="text" id="review-name" class="review-input" placeholder="Dit navn" maxlength="200">
            </div>
            <div class="review-field">
              <label class="review-label" for="review-email">E-mail <span class="review-req">*</span></label>
              <input type="email" id="review-email" class="review-input" placeholder="Din e-mail (vises ikke)" required>
            </div>
            <div class="review-field">
              <label class="review-label" for="review-body">Din anmeldelse</label>
              <textarea id="review-body" class="review-textarea" rows="4" placeholder="Fortæl andre om produktet…" maxlength="2000"></textarea>
            </div>
            <button type="submit" id="review-submit" class="review-submit-btn">Send anmeldelse</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Client-side stock refresh -->
    <script define:vars={{ productId: product.id, variantIds: (product.variants || []).map((v: any) => v.id), apiUrl }}>
      // Refresh stock from API after page load (SSG data may be stale)
      (async function() {
        try {
          const res = await fetch(`${apiUrl}/shop/products/${window.location.pathname.split('/').filter(Boolean).pop()}`);
          if (!res.ok) return;
          const fresh = await res.json();
          const stockEl = document.getElementById('stock-status');
          if (!stockEl) return;

          if (fresh.track_stock) {
            if (fresh.stock === 0 && !fresh.variants?.length) {
              stockEl.textContent = 'Udsolgt';
              stockEl.style.cssText = 'font-size:0.875rem;font-weight:500;color:#dc2626';
              const addBtn = document.getElementById('add-to-cart-detail');
              if (addBtn) { addBtn.disabled = true; addBtn.textContent = 'Udsolgt'; }
            } else if (fresh.stock <= 5) {
              stockEl.textContent = `Kun ${fresh.stock} tilbage på lager`;
              stockEl.style.cssText = 'font-size:0.875rem;font-weight:500;color:#f97316';
            }
          }

          // Update variant stock in select
          const sel = document.getElementById('variant-select');
          if (sel && fresh.variants?.length) {
            for (const opt of sel.options) {
              const v = fresh.variants.find((fv) => String(fv.id) === opt.value);
              if (v) {
                opt.dataset.stock = String(v.stock);
                if (v.stock === 0) { opt.disabled = true; opt.text = opt.text.replace(' (udsolgt)', '') + ' (udsolgt)'; }
              }
            }
          }
        } catch {}
      })();
    </script>
  </main>
</Layout>

<style>
.reviews-section {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 48px var(--container-padding-x);
  border-top: 1px solid var(--color-border, #e5e7eb);
}
.reviews-inner { max-width: 720px; }
.reviews-title { font-size: 1.25rem; font-weight: 800; color: var(--color-text-primary); margin: 0 0 24px; }
.reviews-loading { color: var(--color-text-secondary); font-size: 0.9rem; }
.reviews-summary { margin-bottom: 20px; }
.reviews-avg { font-size: 2rem; font-weight: 800; color: var(--color-text-primary); }
.reviews-avg-sub { font-size: 0.875rem; color: var(--color-text-secondary); }
.reviews-stars-display { color: #f59e0b; font-size: 1.2rem; letter-spacing: 2px; }
.reviews-list { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
.review-card {
  padding: 16px 20px;
  background: var(--color-surface, #fff);
  border: 1px solid var(--color-border, #e5e7eb);
  border-radius: var(--radius-sm, 8px);
}
.review-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
.review-card-name { font-weight: 600; font-size: 0.9375rem; color: var(--color-text-primary); }
.review-card-stars { color: #f59e0b; font-size: 1rem; }
.review-card-date { font-size: 0.8rem; color: var(--color-text-secondary); margin-left: auto; }
.review-card-body { font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6; }
.reviews-empty { color: var(--color-text-secondary); font-size: 0.9375rem; margin-bottom: 24px; }
.review-form-wrap { margin-top: 32px; padding-top: 32px; border-top: 1px solid var(--color-border, #e5e7eb); }
.review-form-title { font-size: 1.0625rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 20px; }
.review-success { padding: 12px 16px; background: #f0fdf4; border: 1px solid #86efac; border-radius: 7px; color: #166534; font-size: 0.875rem; margin-bottom: 16px; }
.review-error { padding: 12px 16px; background: #fef2f2; border: 1px solid #fca5a5; border-radius: 7px; color: #dc2626; font-size: 0.875rem; margin-bottom: 16px; }
.review-stars { display: flex; gap: 4px; margin-bottom: 16px; }
.review-star { background: none; border: none; font-size: 1.75rem; color: #d1d5db; cursor: pointer; padding: 0; line-height: 1; transition: color 100ms; }
.review-star.selected, .review-star:hover ~ .review-star { color: inherit; }
.review-star.selected { color: #f59e0b; }
.review-form { display: flex; flex-direction: column; gap: 14px; max-width: 520px; }
.review-field { display: flex; flex-direction: column; gap: 5px; }
.review-label { font-size: 0.875rem; font-weight: 600; color: var(--color-text-primary); }
.review-req { color: #dc2626; }
.review-input, .review-textarea {
  padding: 9px 13px;
  border: 1.5px solid var(--color-border, #e5e7eb);
  border-radius: var(--radius-sm, 6px);
  font-size: 0.9375rem;
  color: var(--color-text-primary);
  background: var(--color-surface, #fff);
  outline: none;
  transition: border-color 150ms;
  font-family: inherit;
}
.review-input:focus, .review-textarea:focus { border-color: var(--color-primary); }
.review-textarea { resize: vertical; min-height: 100px; }
.review-submit-btn {
  padding: 11px 24px;
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm, 6px);
  font-size: 0.9375rem;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 150ms;
  align-self: flex-start;
}
.review-submit-btn:hover { opacity: 0.88; }
.review-submit-btn:disabled { opacity: 0.55; cursor: not-allowed; }
</style>

<script define:vars={{ productSlug: product.slug, productId: product.id, apiUrl }}>
(function() {
  function starsHtml(rating) {
    return '★'.repeat(Math.round(rating)) + '☆'.repeat(5 - Math.round(rating));
  }

  function fmtDate(iso) {
    return new Date(iso).toLocaleDateString('da-DK', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  async function loadReviews() {
    try {
      const res = await fetch(`${apiUrl}/shop/products/${productSlug}/reviews`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      document.getElementById('reviews-loading').style.display = 'none';

      if (data.count > 0) {
        const summaryEl = document.getElementById('reviews-summary');
        summaryEl.innerHTML = `
          <div class="reviews-stars-display">${starsHtml(parseFloat(data.avg_rating))}</div>
          <span class="reviews-avg">${data.avg_rating}</span>
          <span class="reviews-avg-sub"> ud af 5 (${data.count} anmeldelse${data.count === 1 ? '' : 'r'})</span>
        `;
        summaryEl.style.display = 'block';

        const list = document.getElementById('reviews-list');
        list.innerHTML = data.reviews.map(r => `
          <div class="review-card">
            <div class="review-card-header">
              <span class="review-card-name">${r.customer_name}</span>
              <span class="review-card-stars">${starsHtml(r.rating)}</span>
              <span class="review-card-date">${fmtDate(r.created_at)}</span>
            </div>
            ${r.body ? `<div class="review-card-body">${r.body}</div>` : ''}
          </div>
        `).join('');
      } else {
        document.getElementById('reviews-empty').style.display = 'block';
      }
    } catch {
      document.getElementById('reviews-loading').style.display = 'none';
      document.getElementById('reviews-empty').style.display = 'block';
    }
  }

  loadReviews();

  // Star selector
  const stars = document.querySelectorAll('.review-star');
  const ratingInput = document.getElementById('review-rating');
  let selectedRating = 0;

  stars.forEach((star, idx) => {
    star.addEventListener('mouseenter', () => {
      stars.forEach((s, i) => s.classList.toggle('selected', i <= idx));
    });
    star.addEventListener('mouseleave', () => {
      stars.forEach((s, i) => s.classList.toggle('selected', i < selectedRating));
    });
    star.addEventListener('click', () => {
      selectedRating = idx + 1;
      ratingInput.value = String(selectedRating);
      stars.forEach((s, i) => s.classList.toggle('selected', i < selectedRating));
    });
  });

  document.getElementById('review-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('review-submit');
    const errEl = document.getElementById('review-error');
    const okEl = document.getElementById('review-success');
    errEl.style.display = 'none';

    const rating = parseInt(ratingInput.value);
    if (!rating || rating < 1 || rating > 5) {
      errEl.textContent = 'Vælg venligst en bedømmelse (1–5 stjerner)';
      errEl.style.display = 'block';
      return;
    }

    const email = document.getElementById('review-email').value.trim();
    const name = document.getElementById('review-name').value.trim();
    const body = document.getElementById('review-body').value.trim();

    btn.disabled = true;
    btn.textContent = 'Sender…';

    try {
      const res = await fetch(`${apiUrl}/shop/products/${productSlug}/review`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ customer_email: email, customer_name: name || 'Anonym', rating, body }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Fejl ved indsendelse');
      okEl.style.display = 'block';
      document.getElementById('review-form').style.display = 'none';
    } catch (err) {
      errEl.textContent = err.message;
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send anmeldelse';
    }
  });

  // Back-in-stock notification (show if product is out of stock)
  const outOfStockBtn = document.getElementById('add-to-cart-detail');
  if (outOfStockBtn && outOfStockBtn.disabled) {
    const wrap = outOfStockBtn.closest('.pd-actions') || outOfStockBtn.parentElement;
    if (wrap) {
      const notifyWrap = document.createElement('div');
      notifyWrap.style.cssText = 'margin-top:12px;';
      notifyWrap.innerHTML = `
        <div id="notify-form-wrap">
          <p style="font-size:0.875rem;color:var(--color-text-secondary);margin:0 0 8px;">Få besked når produktet er tilbage på lager:</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <input type="email" id="notify-email" placeholder="Din e-mail" style="padding:8px 12px;border:1.5px solid var(--color-border,#e5e7eb);border-radius:6px;font-size:0.875rem;outline:none;flex:1;min-width:180px;">
            <button id="notify-btn" style="padding:8px 16px;background:var(--color-primary);color:#fff;border:none;border-radius:6px;font-size:0.875rem;font-weight:600;cursor:pointer;white-space:nowrap;">Giv mig besked</button>
          </div>
          <div id="notify-msg" style="display:none;margin-top:8px;font-size:0.8125rem;"></div>
        </div>
      `;
      wrap.appendChild(notifyWrap);

      document.getElementById('notify-btn').addEventListener('click', async () => {
        const email = document.getElementById('notify-email').value.trim();
        const msgEl = document.getElementById('notify-msg');
        msgEl.style.display = 'none';
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          msgEl.textContent = 'Indtast en gyldig e-mail.';
          msgEl.style.cssText = 'display:block;color:#dc2626;margin-top:8px;font-size:0.8125rem;';
          return;
        }
        try {
          const res = await fetch(`${apiUrl}/shop/notify/stock`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ product_id: productId, email }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Fejl');
          msgEl.textContent = 'Du får besked, når produktet er på lager igen.';
          msgEl.style.cssText = 'display:block;color:#166534;margin-top:8px;font-size:0.8125rem;';
          document.getElementById('notify-email').disabled = true;
          document.getElementById('notify-btn').disabled = true;
        } catch (err) {
          msgEl.textContent = err.message;
          msgEl.style.cssText = 'display:block;color:#dc2626;margin-top:8px;font-size:0.8125rem;';
        }
      });
    }
  }
})();
</script>
