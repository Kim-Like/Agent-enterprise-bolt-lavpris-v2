---
import Layout from '../../layouts/Layout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<Layout title="Checkout — Shop — Lavprishjemmeside.dk" description="Udfyld din leveringsadresse og betal sikkert.">
  <main class="checkout-page">

    <div id="cancelled-notice" class="checkout-notice checkout-notice-warning" style="display:none" role="alert">
      Betalingen blev annulleret. Du kan prøve igen nedenfor.
    </div>

    <h1 class="checkout-title">Checkout</h1>

    <div id="checkout-empty" class="checkout-empty" style="display:none">
      <p class="checkout-empty-text">Kurven er tom.</p>
      <a href="/shop/" class="checkout-empty-link">Gå til shoppen</a>
    </div>

    <div id="checkout-content" class="checkout-layout" style="display:none">
      <div class="checkout-form-col">
        <form id="checkout-form" novalidate class="checkout-form">
          <section class="checkout-section">
            <h2 class="checkout-section-title">Kontaktoplysninger</h2>
            <div class="checkout-grid">
              <div>
                <label class="form-label" for="first_name">Fornavn *</label>
                <input id="first_name" name="first_name" type="text" required autocomplete="given-name" class="form-input" />
              </div>
              <div>
                <label class="form-label" for="last_name">Efternavn *</label>
                <input id="last_name" name="last_name" type="text" required autocomplete="family-name" class="form-input" />
              </div>
              <div class="checkout-col-span-2">
                <label class="form-label" for="email">E-mail *</label>
                <input id="email" name="email" type="email" required autocomplete="email" class="form-input" />
              </div>
              <div>
                <label class="form-label" for="phone">Telefon</label>
                <input id="phone" name="phone" type="tel" autocomplete="tel" class="form-input" />
              </div>
            </div>
          </section>

          <section class="checkout-section">
            <h2 class="checkout-section-title">Leveringsadresse</h2>
            <div class="checkout-grid">
              <div class="checkout-col-span-2">
                <label class="form-label" for="address1">Adresse *</label>
                <input id="address1" name="address1" type="text" required autocomplete="street-address" class="form-input" />
              </div>
              <div class="checkout-col-span-2">
                <label class="form-label" for="address2">Adresse 2 (etage, lejlighedsnr.)</label>
                <input id="address2" name="address2" type="text" autocomplete="address-line2" class="form-input" />
              </div>
              <div>
                <label class="form-label" for="zip">Postnummer *</label>
                <input id="zip" name="zip" type="text" required autocomplete="postal-code" class="form-input" maxlength="4" />
              </div>
              <div>
                <label class="form-label" for="city">By *</label>
                <input id="city" name="city" type="text" required autocomplete="address-level2" class="form-input" />
              </div>
            </div>
          </section>

          <section class="checkout-section">
            <h2 class="checkout-section-title">Forsendelse</h2>
            <div id="shipping-methods" class="checkout-shipping-methods">
              <p class="checkout-loading-text">Henter forsendelsesmetoder...</p>
            </div>
          </section>

          <section class="checkout-section">
            <h2 class="checkout-section-title">Note til butikken</h2>
            <textarea
              id="customer-note"
              name="customer_note"
              placeholder="Evt. særlige ønsker eller oplysninger til din ordre (valgfri)"
              class="form-input"
              rows="3"
              style="resize:vertical"
              maxlength="1000"
            ></textarea>
          </section>

          <section class="checkout-section">
            <h2 class="checkout-section-title">Rabatkode</h2>
            <div class="checkout-discount-row">
              <input id="discount-input" type="text" placeholder="Indtast kode" class="form-input checkout-discount-input" />
              <button type="button" id="discount-btn" class="checkout-discount-btn">Anvend</button>
            </div>
            <p id="discount-msg" class="checkout-discount-msg" style="display:none"></p>
          </section>

          <div id="checkout-error" class="checkout-notice checkout-notice-error" style="display:none" role="alert"></div>

          <button type="submit" id="pay-btn" class="checkout-pay-btn">
            Betal sikkert med Flatpay
          </button>
          <p class="checkout-pay-note">
            Du sendes videre til en sikker betalingsside (Visa, Mastercard, MobilePay).
          </p>
        </form>
      </div>

      <div class="checkout-summary-col">
        <div class="checkout-summary-box">
          <h2 class="checkout-summary-title">Din ordre</h2>
          <ul id="summary-items" class="checkout-summary-items"></ul>
          <div class="checkout-summary-totals">
            <div class="checkout-summary-row">
              <span class="checkout-summary-label">Subtotal</span>
              <span id="sum-subtotal">—</span>
            </div>
            <div class="checkout-summary-row">
              <span class="checkout-summary-label">Fragt</span>
              <span id="sum-shipping">Vælg forsendelse</span>
            </div>
            <div id="sum-discount-row" class="checkout-summary-row checkout-summary-discount" style="display:none">
              <span>Rabat</span>
              <span id="sum-discount">—</span>
            </div>
          </div>
          <div class="checkout-summary-grand-total">
            <span>Total inkl. moms</span>
            <span id="sum-total">—</span>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
.checkout-page {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 48px var(--container-padding-x);
}
.checkout-notice {
  margin-bottom: 24px;
  border-radius: var(--radius-md);
  padding: 12px 16px;
  font-size: 0.875rem;
}
.checkout-notice-warning {
  background: #fffbeb;
  border: 1px solid #fcd34d;
  color: #92400e;
}
.checkout-notice-error {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  color: #b91c1c;
}
.checkout-title {
  font-size: 1.875rem;
  font-weight: 800;
  color: var(--color-text-primary);
  margin: 0 0 32px;
}
.checkout-empty {
  text-align: center;
  padding: 64px 0;
  color: var(--color-text-secondary);
}
.checkout-empty-text { margin: 0 0 8px; }
.checkout-empty-link { color: var(--color-primary); text-decoration: none; }
.checkout-empty-link:hover { text-decoration: underline; }

.checkout-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: start;
}
@media (min-width: 1024px) {
  .checkout-layout { grid-template-columns: 3fr 2fr; }
}

.checkout-form { display: flex; flex-direction: column; gap: 32px; }
.checkout-section { display: flex; flex-direction: column; gap: 16px; }
.checkout-section-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}
.checkout-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}
@media (min-width: 640px) {
  .checkout-grid { grid-template-columns: 1fr 1fr; }
}
.checkout-col-span-2 { grid-column: 1 / -1; }

.form-label {
  display: block;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}
.form-input {
  width: 100%;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  padding: 8px 12px;
  font-size: 0.875rem;
  outline: none;
  box-sizing: border-box;
  transition: border-color 150ms;
}
.form-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
}

.checkout-shipping-methods { display: flex; flex-direction: column; gap: 12px; }
.checkout-loading-text { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0; }
.checkout-shipping-label {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  padding: 12px;
  transition: border-color 150ms;
}
.checkout-shipping-label:hover { border-color: var(--color-primary); }
.checkout-shipping-label.is-selected {
  border-color: var(--color-primary);
  background: color-mix(in srgb, var(--color-primary) 5%, transparent);
}

.checkout-discount-row { display: flex; gap: 8px; }
.checkout-discount-input { flex: 1; }
.checkout-discount-btn {
  padding: 8px 16px;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  font-size: 0.875rem;
  font-weight: 500;
  background: none;
  cursor: pointer;
  white-space: nowrap;
  transition: background 150ms;
}
.checkout-discount-btn:hover { background: var(--color-neutral-100); }
.checkout-discount-msg { margin: 8px 0 0; font-size: 0.875rem; }
.checkout-discount-msg.is-success { color: #16a34a; }
.checkout-discount-msg.is-error { color: #dc2626; }

.checkout-pay-btn {
  width: 100%;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  padding: 16px 24px;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-on-primary);
  box-shadow: var(--shadow-sm);
  border: none;
  cursor: pointer;
  transition: opacity 150ms;
}
.checkout-pay-btn:hover:not(:disabled) { opacity: 0.9; }
.checkout-pay-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.checkout-pay-note {
  font-size: 0.75rem;
  text-align: center;
  color: var(--color-text-secondary);
  margin: 0;
}

.checkout-summary-box {
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.checkout-summary-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text-primary);
  margin: 0;
}
.checkout-summary-items {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.checkout-summary-item {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  font-size: 0.875rem;
}
.checkout-summary-item-name {
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 60%;
}
.checkout-summary-item-price { font-weight: 500; white-space: nowrap; }
.checkout-summary-totals {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
  font-size: 0.875rem;
}
.checkout-summary-row { display: flex; justify-content: space-between; }
.checkout-summary-label { color: var(--color-text-secondary); }
.checkout-summary-discount { color: #16a34a; }
.checkout-summary-grand-total {
  display: flex;
  justify-content: space-between;
  font-weight: 700;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}
</style>

<script define:vars={{ apiUrl }}>
  if (new URLSearchParams(window.location.search).get('cancelled')) {
    const el = document.getElementById('cancelled-notice');
    if (el) el.style.display = 'block';
  }

  let shippingMethods = [];
  let selectedShipping = null;
  let appliedDiscount = null;

  // Session token for stock reservation — stable per browser session
  const SESSION_TOKEN_KEY = 'shop_session_token';
  function getSessionToken() {
    let t = sessionStorage.getItem(SESSION_TOKEN_KEY);
    if (!t) {
      t = Array.from(crypto.getRandomValues(new Uint8Array(16))).map(b => b.toString(16).padStart(2, '0')).join('');
      sessionStorage.setItem(SESSION_TOKEN_KEY, t);
    }
    return t;
  }

  function fmt(ore) { return (ore / 100).toFixed(2).replace('.', ',') + ' kr.'; }

  async function init() {
    const cart = await import('/src/scripts/cart.js');
    const { getCart, getCartTotal, validateCart } = cart;

    const { items } = getCart();
    const contentEl = document.getElementById('checkout-content');
    const emptyEl = document.getElementById('checkout-empty');

    if (items.length === 0) {
      if (emptyEl) emptyEl.style.display = 'block';
      return;
    }
    if (contentEl) contentEl.style.display = 'grid';

    await validateCart(apiUrl);

    renderSummary(getCart, getCartTotal);
    await loadShipping(getCart, getCartTotal);

    document.getElementById('discount-btn')?.addEventListener('click', async () => {
      const code = document.getElementById('discount-input').value.trim();
      const msgEl = document.getElementById('discount-msg');
      if (!code) return;

      const subtotal = getCartTotal();
      try {
        const res = await fetch(`${apiUrl}/shop/discount/validate`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, subtotal_ore: subtotal }),
        });
        const data = await res.json();
        if (!res.ok) {
          msgEl.textContent = data.error || 'Ugyldig kode';
          msgEl.className = 'checkout-discount-msg is-error';
          msgEl.style.display = 'block';
          appliedDiscount = null;
        } else {
          appliedDiscount = data;
          msgEl.textContent = `Kode "${data.code}" anvendt — -${fmt(data.discount_ore)}`;
          msgEl.className = 'checkout-discount-msg is-success';
          msgEl.style.display = 'block';
        }
      } catch {
        msgEl.textContent = 'Kunne ikke validere kode';
        msgEl.className = 'checkout-discount-msg is-error';
        msgEl.style.display = 'block';
      }
      updateTotals(getCartTotal);
    });

    document.getElementById('checkout-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('pay-btn');
      const errEl = document.getElementById('checkout-error');
      if (errEl) errEl.style.display = 'none';

      if (!selectedShipping) {
        errEl.textContent = 'Vælg en forsendelsesmetode';
        errEl.style.display = 'block';
        return;
      }

      const f = e.target;
      const customer = {
        first_name: f.first_name.value.trim(),
        last_name: f.last_name.value.trim(),
        email: f.email.value.trim(),
        phone: f.phone.value.trim(),
        address1: f.address1.value.trim(),
        address2: f.address2.value.trim(),
        city: f.city.value.trim(),
        zip: f.zip.value.trim(),
        country: 'DK',
      };

      btn.disabled = true;
      btn.textContent = 'Reserverer varer...';

      try {
        const { items } = getCart();
        const sessionToken = getSessionToken();

        // Reserve stock before creating order
        const reserveRes = await fetch(`${apiUrl}/shop/cart/reserve`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: items.map(i => ({ product_id: i.product_id, variant_id: i.variant_id, quantity: i.quantity })),
            session_token: sessionToken,
          }),
        });
        if (!reserveRes.ok) {
          const reserveData = await reserveRes.json();
          errEl.textContent = reserveData.error || 'En vare er ikke tilgængelig i den ønskede mængde';
          errEl.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Betal sikkert med Flatpay';
          return;
        }

        btn.textContent = 'Opretter ordre...';

        const customerNote = document.getElementById('customer-note')?.value?.trim() || null;

        const res = await fetch(`${apiUrl}/shop/orders`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: items.map(i => ({ product_id: i.product_id, variant_id: i.variant_id, quantity: i.quantity })),
            customer,
            shipping_method_id: selectedShipping.id,
            discount_code: appliedDiscount?.code || null,
            customer_note: customerNote,
            session_token: sessionToken,
          }),
        });

        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.error || 'Ordren kunne ikke oprettes';
          errEl.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Betal sikkert med Flatpay';
          return;
        }

        if (typeof window.Frisbii !== 'undefined') {
          window.Frisbii.open(data.frisbii_session_id);
        } else {
          btn.textContent = 'Åbner betalingsvindue...';
          const script = document.createElement('script');
          script.src = 'https://checkout.frisbii.com/checkout.js';
          script.onload = () => {
            if (typeof window.Frisbii !== 'undefined') {
              window.Frisbii.open(data.frisbii_session_id);
            } else {
              window.location.href = `/shop/ordre/${data.order_token}/`;
            }
          };
          script.onerror = () => {
            window.location.href = `/shop/ordre/${data.order_token}/`;
          };
          document.head.appendChild(script);
        }

      } catch {
        errEl.textContent = 'Der opstod en fejl. Prøv igen.';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Betal sikkert med Flatpay';
      }
    });
  }

  function renderSummary(getCart, getCartTotal) {
    const { items } = getCart();
    const listEl = document.getElementById('summary-items');
    if (!listEl) return;
    listEl.innerHTML = '';
    items.forEach(item => {
      const li = document.createElement('li');
      li.className = 'checkout-summary-item';
      li.innerHTML = `
        <span class="checkout-summary-item-name">
          ${item.name}${item.variant_name ? ` / ${item.variant_name}` : ''} × ${item.quantity}
        </span>
        <span class="checkout-summary-item-price">${fmt(item.price_ore * item.quantity)}</span>
      `;
      listEl.appendChild(li);
    });
    const el = document.getElementById('sum-subtotal');
    if (el) el.textContent = fmt(getCartTotal());
    updateTotals(getCartTotal);
  }

  function updateTotals(getCartTotal) {
    const subtotal = getCartTotal();
    const shippingOre = selectedShipping?.price_ore ?? null;
    let shipping = shippingOre;
    if (selectedShipping?.free_above_ore && subtotal >= selectedShipping.free_above_ore) shipping = 0;

    const discountOre = appliedDiscount?.discount_ore ?? 0;
    const discountRow = document.getElementById('sum-discount-row');
    const discountEl = document.getElementById('sum-discount');
    if (discountOre > 0) {
      if (discountRow) discountRow.style.display = 'flex';
      if (discountEl) discountEl.textContent = `−${fmt(discountOre)}`;
    } else {
      if (discountRow) discountRow.style.display = 'none';
    }

    const shippingEl = document.getElementById('sum-shipping');
    const totalEl = document.getElementById('sum-total');

    if (shipping === null) {
      if (shippingEl) shippingEl.textContent = 'Vælg forsendelse';
      if (totalEl) totalEl.textContent = '—';
    } else {
      if (shippingEl) shippingEl.textContent = shipping === 0 ? 'Gratis' : fmt(shipping);
      const total = Math.max(0, subtotal + shipping - discountOre);
      if (totalEl) totalEl.textContent = fmt(total);
    }
  }

  async function loadShipping(getCart, getCartTotal) {
    const container = document.getElementById('shipping-methods');
    try {
      const res = await fetch(`${apiUrl}/shop/shipping/methods`);
      if (!res.ok) return;
      shippingMethods = await res.json();
    } catch { return; }

    if (!container) return;
    container.innerHTML = '';
    const subtotal = getCartTotal();

    shippingMethods.forEach((method, i) => {
      const isFree = method.free_above_ore !== null && subtotal >= method.free_above_ore;
      const displayPrice = isFree ? 'Gratis' : fmt(method.price_ore);
      const label = document.createElement('label');
      label.className = 'checkout-shipping-label' + (i === 0 ? ' is-selected' : '');
      label.innerHTML = `
        <input type="radio" name="shipping_method" value="${method.id}" style="accent-color:var(--color-primary)" ${i === 0 ? 'checked' : ''} />
        <div style="flex:1">
          <p style="font-weight:500;font-size:0.875rem;margin:0">${method.name}</p>
          <p style="font-size:0.75rem;color:var(--color-text-secondary);margin:0">${method.est_days_min}–${method.est_days_max} hverdage</p>
        </div>
        <span style="font-weight:600;font-size:0.875rem">${displayPrice}</span>
      `;
      container.appendChild(label);

      if (i === 0) {
        selectedShipping = method;
        updateTotals(getCartTotal);
      }
    });

    container.addEventListener('change', (e) => {
      const val = parseInt(e.target.value);
      selectedShipping = shippingMethods.find(m => m.id === val) || null;
      container.querySelectorAll('.checkout-shipping-label').forEach(l => l.classList.remove('is-selected'));
      e.target.closest('.checkout-shipping-label')?.classList.add('is-selected');
      updateTotals(getCartTotal);
    });
  }

  init().catch(console.error);
</script>
