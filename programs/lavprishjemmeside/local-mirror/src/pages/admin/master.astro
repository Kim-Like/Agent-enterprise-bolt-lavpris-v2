---
import AdminLayout from '../../layouts/AdminLayout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<AdminLayout title="Master Hub">
  <script is:inline>
    (function() {
      try {
        var token = localStorage.getItem('admin_token');
        if (!token) return;
        var payload = JSON.parse(atob(token.split('.')[1]));
        if (payload.role !== 'master') {
          window.location.replace('/admin/dashboard/?message=master_required');
          return;
        }
      } catch(e) {}
    })();
  </script>

  <style>
    .master-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      gap: 1rem;
    }
    .master-title {
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }
    .master-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      background: #f3f4f6;
      border: 1px solid #e5e7eb;
      border-radius: 999px;
      padding: 0.25rem 0.75rem;
      font-size: 0.75rem;
      color: #6b7280;
      font-weight: 500;
    }
    .master-badge-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 50%;
      background: #22c55e;
      flex-shrink: 0;
    }

    /* Tab bar */
    .tab-bar {
      display: flex;
      gap: 0;
      border-bottom: 1px solid #e5e7eb;
      margin-bottom: 1.5rem;
    }
    .tab-btn {
      padding: 0.625rem 1.125rem;
      font-size: 0.8125rem;
      font-weight: 500;
      border: none;
      background: none;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      color: #6b7280;
      margin-bottom: -1px;
      transition: color 0.15s, border-color 0.15s;
      white-space: nowrap;
    }
    .tab-btn:hover { color: #374151; }
    .tab-btn.active {
      border-bottom-color: #3b82f6;
      color: #2563eb;
    }

    /* Panel shared */
    .panel-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 1.25rem;
    }

    /* Sites grid */
    .sites-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    @media (min-width: 900px) {
      .sites-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* Site card */
    .site-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 1.125rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .site-card-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
    }
    .site-card-name {
      font-size: 0.9375rem;
      font-weight: 600;
      color: #111827;
      text-decoration: none;
    }
    .site-card-name:hover { color: #2563eb; }
    .site-card-domain { font-size: 0.75rem; color: #9ca3af; margin-top: 0.125rem; }
    .site-card-badges {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: flex-end;
      flex-shrink: 0;
    }
    .site-card-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.5rem;
    }
    .stat-mini {
      background: #f9fafb;
      border-radius: 0.5rem;
      padding: 0.5rem 0.375rem;
      text-align: center;
    }
    .stat-mini-val {
      font-size: 1.0625rem;
      font-weight: 700;
      color: #111827;
      line-height: 1.2;
    }
    .stat-mini-lbl {
      font-size: 0.6875rem;
      color: #9ca3af;
      margin-top: 0.125rem;
    }
    .site-card-note {
      background: #f9fafb;
      border: 1px solid #f3f4f6;
      border-radius: 0.5rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
      color: #6b7280;
    }
    .site-card-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.75rem;
      color: #9ca3af;
    }
    .site-card-foot strong { color: #374151; }
    .site-card-admin-link {
      color: #3b82f6;
      font-weight: 500;
      text-decoration: none;
      font-size: 0.75rem;
    }
    .site-card-admin-link:hover { text-decoration: underline; }

    /* Health dot */
    .health-dot {
      display: inline-block;
      width: 0.625rem;
      height: 0.625rem;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .health-online { background: #22c55e; }
    .health-degraded { background: #f59e0b; }
    .health-offline { background: #ef4444; }
    .health-unknown { background: #d1d5db; }

    /* Pill badges */
    .pill {
      display: inline-block;
      font-size: 0.6875rem;
      font-weight: 500;
      border-radius: 999px;
      padding: 0.125rem 0.5rem;
      white-space: nowrap;
    }
    .pill-gray { background: #f3f4f6; color: #6b7280; }
    .pill-blue { background: #dbeafe; color: #1d4ed8; }
    .pill-amber { background: #fef3c7; color: #92400e; }
    .pill-red { background: #fee2e2; color: #991b1b; }
    .pill-green { background: #dcfce7; color: #166534; }

    /* Rollout banner */
    .rollout-banner {
      border-radius: 0.625rem;
      border: 1px solid #e5e7eb;
      padding: 0.75rem 1rem;
      font-size: 0.8125rem;
      margin-bottom: 1rem;
    }

    /* Loading / error states */
    .state-center {
      text-align: center;
      padding: 3rem 1rem;
      font-size: 0.875rem;
      color: #9ca3af;
    }
    .state-error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 0.75rem;
      padding: 0.875rem 1rem;
      color: #b91c1c;
      font-size: 0.8125rem;
      margin-bottom: 1rem;
    }

    /* Add site form */
    .add-site-summary {
      font-size: 0.8125rem;
      font-weight: 500;
      color: #6b7280;
      cursor: pointer;
      padding: 0.5rem 0;
    }
    .add-site-summary:hover { color: #111827; }
    .add-site-form {
      margin-top: 1rem;
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 1.25rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.875rem;
    }
    @media (max-width: 640px) {
      .add-site-form { grid-template-columns: 1fr; }
    }
    .form-label {
      display: block;
      font-size: 0.6875rem;
      color: #9ca3af;
      margin-bottom: 0.25rem;
      font-weight: 500;
    }
    .form-input {
      width: 100%;
      border: 1px solid #d1d5db;
      border-radius: 0.5rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
      color: #111827;
      background: #fff;
      box-sizing: border-box;
      transition: border-color 0.15s;
    }
    .form-input:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }
    .form-span2 { grid-column: span 2; }
    @media (max-width: 640px) {
      .form-span2 { grid-column: span 1; }
    }

    /* AI Usage tab */
    .ai-site-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 1.125rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .ai-site-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
    }
    .ai-chart { display: flex; align-items: flex-end; gap: 2px; height: 3rem; }
    .ai-chart-bar { background: #93c5fd; border-radius: 2px 2px 0 0; width: 0.75rem; flex-shrink: 0; transition: background 0.1s; }
    .ai-chart-bar:hover { background: #3b82f6; }
    .ai-unavailable { font-size: 0.75rem; color: #f87171; }

    /* Claude Code tab */
    .claude-step-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    @media (max-width: 700px) {
      .claude-step-grid { grid-template-columns: 1fr; }
    }
    .claude-step {
      border: 1px solid #e5e7eb;
      border-radius: 0.625rem;
      padding: 0.875rem;
    }
    .claude-step-blue { background: linear-gradient(135deg, #eff6ff 0%, #fff 100%); }
    .claude-step-green { background: linear-gradient(135deg, #f0fdf4 0%, #fff 100%); }
    .claude-step-amber { background: linear-gradient(135deg, #fffbeb 0%, #fff 100%); }
    .step-label {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.375rem;
    }
    .step-label-blue { color: #1d4ed8; }
    .step-label-green { color: #166534; }
    .step-label-amber { color: #92400e; }
    .claude-options-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: flex-end;
      margin-bottom: 1rem;
    }
    .auth-status-row {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      padding-top: 0.625rem;
    }
    .claude-prompt-label {
      font-size: 0.6875rem;
      color: #9ca3af;
      font-weight: 500;
      margin-bottom: 0.375rem;
    }
    textarea.form-input {
      font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
      resize: vertical;
      min-height: 6rem;
    }
    .claude-actions {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.875rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.5rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.8125rem;
      font-weight: 500;
      cursor: pointer;
      border: none;
      transition: background 0.15s, opacity 0.15s;
    }
    .btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-primary { background: #3b82f6; color: #fff; }
    .btn-primary:hover:not(:disabled) { background: #2563eb; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-danger:hover:not(:disabled) { background: #dc2626; }
    .btn-ghost {
      background: #fff;
      color: #374151;
      border: 1px solid #e5e7eb;
    }
    .btn-ghost:hover:not(:disabled) { background: #f9fafb; }
    .btn-ghost-blue {
      background: #fff;
      color: #3b82f6;
      border: 1px solid #bfdbfe;
    }
    .btn-ghost-blue:hover:not(:disabled) { background: #eff6ff; }

    /* Auth panel */
    .auth-panel {
      background: #fff;
      border: 1px solid #bfdbfe;
      border-radius: 0.75rem;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }
    .auth-panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.875rem;
    }
    .auth-steps {
      font-size: 0.75rem;
      color: #6b7280;
      margin-bottom: 1rem;
      padding-left: 1rem;
      line-height: 1.75;
    }

    /* Terminal */
    .terminal {
      background: #090c10;
      border: 1px solid #1f2937;
      border-radius: 0.75rem;
      padding: 1rem;
      min-height: 16rem;
    }
    .terminal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }
    .terminal-label {
      font-size: 0.6875rem;
      color: #4b5563;
      font-family: ui-monospace, monospace;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    #claude-output {
      font-size: 0.8125rem;
      font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
      white-space: pre-wrap;
      word-break: break-words;
      overflow: auto;
      max-height: 60vh;
      color: #d1d5db;
    }

    /* Site add section */
    .add-section { margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid #f3f4f6; }

    .hidden-el { display: none !important; }
  </style>

  <div class="master-header">
    <div class="master-title">
      <h1 style="font-size:1.375rem;font-weight:700;color:#111827;margin:0;">Master Hub</h1>
    </div>
    <div class="master-badge">
      <span class="master-badge-dot"></span>
      lavprishjemmeside.dk
    </div>
  </div>

  <!-- Tab bar -->
  <div class="tab-bar">
    <button onclick="switchTab('sites')" id="tab-sites" class="tab-btn active">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="display:inline;vertical-align:-1px;margin-right:0.3em"><rect x="1" y="1" width="4.5" height="4.5" rx="1" stroke="currentColor" stroke-width="1.3"/><rect x="7.5" y="1" width="4.5" height="4.5" rx="1" stroke="currentColor" stroke-width="1.3"/><rect x="1" y="7.5" width="4.5" height="4.5" rx="1" stroke="currentColor" stroke-width="1.3"/><rect x="7.5" y="7.5" width="4.5" height="4.5" rx="1" stroke="currentColor" stroke-width="1.3"/></svg>
      Sites
    </button>
    <button onclick="switchTab('ai')" id="tab-ai" class="tab-btn">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="display:inline;vertical-align:-1px;margin-right:0.3em"><path d="M2 10 L4 5 L6.5 8.5 L8 6 L11 10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      AI Usage
    </button>
    <button onclick="switchTab('claude')" id="tab-claude" class="tab-btn">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="display:inline;vertical-align:-1px;margin-right:0.3em"><rect x="1" y="3" width="11" height="7" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M4 7l1.5-1.5L4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M7.5 7h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      Claude Code
    </button>
  </div>

  <!-- ── Tab 1: Sites ────────────────────────────────────────── -->
  <div id="panel-sites">
    <div id="sites-rollout-banner" class="rollout-banner hidden-el"></div>
    <div id="sites-loading" class="state-center">Henter sites…</div>
    <div id="sites-error" class="state-error hidden-el"></div>
    <div id="sites-grid" class="sites-grid hidden-el"></div>

    <div class="add-section">
      <details>
        <summary class="add-site-summary">+ Registrer nyt site</summary>
        <form id="add-site-form" class="add-site-form">
          <div>
            <label class="form-label">Navn</label>
            <input name="name" placeholder="Min Kunde A/S" class="form-input" />
          </div>
          <div>
            <label class="form-label">Domain</label>
            <input name="domain" placeholder="minkunde.dk" class="form-input" />
          </div>
          <div>
            <label class="form-label">API URL</label>
            <input name="api_url" placeholder="https://api.minkunde.dk" class="form-input" />
          </div>
          <div>
            <label class="form-label">Admin URL</label>
            <input name="admin_url" placeholder="https://minkunde.dk/admin/" class="form-input" />
          </div>
          <div>
            <label class="form-label">DB Name</label>
            <input name="db_name" placeholder="theartis_minkunde" class="form-input" />
          </div>
          <div>
            <label class="form-label">DB User</label>
            <input name="db_user" placeholder="theartis_minkunde" class="form-input" />
          </div>
          <div>
            <label class="form-label">DB Password</label>
            <input name="db_password" type="password" class="form-input" />
          </div>
          <div class="form-span2" style="display:flex;justify-content:flex-end;">
            <button type="submit" class="btn btn-primary">Gem site</button>
          </div>
        </form>
      </details>
    </div>
  </div>

  <!-- ── Tab 2: AI Usage ─────────────────────────────────────── -->
  <div id="panel-ai" class="hidden-el">
    <div id="ai-loading" class="state-center">Henter AI-forbrug…</div>
    <div id="ai-content" class="hidden-el" style="display:flex;flex-direction:column;gap:0.875rem;"></div>
  </div>

  <!-- ── Tab 3: Claude Code Runner ──────────────────────────── -->
  <div id="panel-claude" class="hidden-el">
    <div class="panel-card" style="margin-bottom:1rem;">
      <!-- Step selectors -->
      <div class="claude-step-grid">
        <div class="claude-step claude-step-blue">
          <p class="step-label step-label-blue">Step 1</p>
          <label class="form-label">Repository</label>
          <select id="claude-repo" onchange="onClaudeRepoOrTaskChange()" class="form-input">
            <option value="">Henter repos…</option>
          </select>
        </div>
        <div class="claude-step claude-step-green">
          <p class="step-label step-label-green">Step 2</p>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.25rem;">
            <label class="form-label" style="margin-bottom:0;">Kanban task</label>
            <button onclick="loadClaudeKanbanTasks()" class="btn btn-ghost" style="padding:0.2rem 0.5rem;font-size:0.6875rem;">Refresh</button>
          </div>
          <select id="claude-task" onchange="onClaudeRepoOrTaskChange()" class="form-input">
            <option value="">Vælg task…</option>
          </select>
        </div>
        <div class="claude-step claude-step-amber">
          <p class="step-label step-label-amber">Step 3</p>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.25rem;">
            <label class="form-label" style="margin-bottom:0;">Plan .md file</label>
            <button onclick="loadTaskMdFiles()" class="btn btn-ghost" style="padding:0.2rem 0.5rem;font-size:0.6875rem;">Refresh</button>
          </div>
          <select id="claude-md-file" onchange="updateRunButtonState()" class="form-input">
            <option value="">Vælg .md-fil…</option>
          </select>
          <div id="claude-md-help" style="font-size:0.6875rem;color:#9ca3af;margin-top:0.375rem;">A run requires a planning .md file.</div>
          <button onclick="createNewPlanMd()" class="btn btn-ghost" style="margin-top:0.5rem;font-size:0.75rem;padding:0.3rem 0.625rem;">Create new .md plan</button>
        </div>
      </div>

      <!-- Model / auth row -->
      <div class="claude-options-row">
        <div>
          <label class="form-label">Model</label>
          <select id="claude-model" class="form-input" style="min-width:13rem;">
            <option value="sonnet">Sonnet 4.6 (default)</option>
            <option value="haiku">Haiku 4.5 (fast / cheap)</option>
            <option value="opus">Opus 4.6 (powerful)</option>
          </select>
        </div>
        <div>
          <label class="form-label">Timeout</label>
          <select id="claude-timeout" class="form-input">
            <option value="10">10 min</option>
            <option value="30">30 min</option>
            <option value="60">60 min</option>
          </select>
        </div>
        <div>
          <input id="claude-account" type="hidden" value="/home/theartis/.claude" />
          <div class="auth-status-row">
            <span id="auth-dot" style="display:inline-block;width:0.5rem;height:0.5rem;border-radius:50%;background:#d1d5db;flex-shrink:0;"></span>
            <span id="auth-label" style="font-size:0.75rem;color:#9ca3af;max-width:12rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Checking…</span>
          </div>
        </div>
      </div>

      <!-- Prompt -->
      <div style="margin-bottom:0.875rem;">
        <div class="claude-prompt-label">Task / prompt</div>
        <textarea id="claude-prompt" rows="5" placeholder="Describe the task for Claude Code…&#10;e.g. Run node api/run-schema.cjs and report any errors" class="form-input"></textarea>
      </div>

      <!-- Actions -->
      <div class="claude-actions">
        <button onclick="runClaude()" id="claude-run-btn" class="btn btn-primary">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 2l7 4-7 4V2z" fill="currentColor"/></svg>
          Run
        </button>
        <button onclick="killClaude()" id="claude-kill" class="btn btn-danger hidden-el">
          <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><rect x="1.5" y="1.5" width="8" height="8" rx="1" fill="currentColor"/></svg>
          Kill
        </button>
        <button onclick="clearOutput()" class="btn btn-ghost">Clear</button>
        <button onclick="openAuthPanel()" class="btn btn-ghost-blue" style="margin-left:auto;">Auth Account</button>
      </div>
    </div>

    <!-- Auth panel -->
    <div id="claude-auth-panel" class="auth-panel hidden-el">
      <div class="auth-panel-head">
        <p style="font-size:0.875rem;font-weight:600;color:#111827;margin:0;">Authenticate Claude Account</p>
        <button onclick="closeAuthPanel()" class="btn btn-ghost" style="padding:0.25rem 0.625rem;font-size:0.75rem;">Close</button>
      </div>
      <ol class="auth-steps">
        <li>Click <strong>Generate Auth URL</strong></li>
        <li>Click the link that appears and authorize in your browser</li>
        <li>The callback page shows: <em>"Authentication Code — Paste this into Claude Code:"</em></li>
        <li>Paste that code into the field below and click <strong>Submit Code</strong></li>
      </ol>

      <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.75rem;">
        <button onclick="startClaudeAuth()" id="auth-start-btn" class="btn btn-primary" style="font-size:0.8125rem;">Generate Auth URL</button>
        <span id="auth-spinner" class="hidden-el" style="font-size:0.75rem;color:#9ca3af;">Generating…</span>
      </div>

      <div id="auth-url-box" class="hidden-el" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:0.5rem;padding:0.75rem;margin-bottom:0.75rem;">
        <p style="font-size:0.75rem;color:#6b7280;margin-bottom:0.25rem;">Open this URL in your browser to authorize:</p>
        <a id="auth-url-link" href="#" target="_blank" rel="noopener" style="font-size:0.75rem;color:#1d4ed8;word-break:break-all;font-family:ui-monospace,monospace;"></a>
      </div>

      <pre id="auth-output" class="hidden-el" style="font-size:0.75rem;font-family:ui-monospace,monospace;background:#090c10;color:#4ade80;border-radius:0.5rem;padding:0.75rem;max-height:10rem;overflow:auto;white-space:pre-wrap;word-break:break-all;margin-bottom:0.75rem;"></pre>

      <div style="display:flex;gap:0.5rem;">
        <input id="auth-code-input" type="text" placeholder="Paste Authentication Code here…" class="form-input" style="flex:1;font-family:ui-monospace,monospace;" />
        <button onclick="submitAuthCode()" class="btn btn-primary" style="white-space:nowrap;">Submit Code</button>
      </div>
      <p id="auth-status" style="font-size:0.75rem;margin-top:0.5rem;color:#6b7280;"></p>
    </div>

    <!-- Output terminal -->
    <div class="terminal">
      <div class="terminal-head">
        <span class="terminal-label">Output</span>
        <span id="claude-status" style="font-size:0.6875rem;color:#4b5563;font-family:ui-monospace,monospace;"></span>
      </div>
      <pre id="claude-output"></pre>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ apiUrl }}>
function normalizeApiBase(url) {
  return String(url || '').replace(/\/+$/, '');
}

function normalizedHost(host) {
  return String(host || '').toLowerCase().replace(/^www\./, '');
}

function isApiLikeBase(url) {
  try {
    var u = new URL(url);
    var h = normalizedHost(u.hostname);
    return h.indexOf('api.') === 0 || /\/api(\/|$)/.test(u.pathname);
  } catch (_) {
    return false;
  }
}

function buildApiCandidates(primary) {
  var candidates = [];
  function add(url) {
    var clean = normalizeApiBase(url);
    if (!clean) return;
    if (candidates.indexOf(clean) === -1) candidates.push(clean);
  }

  var currentHost = normalizedHost(window.location.hostname);
  var fallbackApi = '';
  try {
    if (currentHost && currentHost.indexOf('api.') !== 0) {
      fallbackApi = window.location.protocol + '//api.' + currentHost;
    }
  } catch (_) {}

  var primaryClean = normalizeApiBase(primary);
  var primaryHost = '';
  try {
    primaryHost = normalizedHost(new URL(primaryClean).hostname);
  } catch (_) {}

  if (primaryClean && !isApiLikeBase(primaryClean) && primaryHost === currentHost && fallbackApi) {
    add(fallbackApi);
    add(primaryClean);
  } else {
    add(primaryClean);
    add(fallbackApi);
  }

  return candidates;
}

var API_CANDIDATES = buildApiCandidates(apiUrl);
var API = API_CANDIDATES[0] || normalizeApiBase(apiUrl);
var activeTab = 'sites';
var currentTaskId = null;
var masterStepUpToken = sessionStorage.getItem('master_step_up_token') || '';

function parseJsonResponse(res, endpointUrl) {
  var contentType = String((res.headers && res.headers.get('content-type')) || '').toLowerCase();
  if (contentType.indexOf('application/json') >= 0) return res.json();
  return res.text().then(function(text) {
    var sample = String(text || '').trim();
    if (sample.charAt(0) === '<') {
      var err = new Error('Non-JSON response [' + res.status + '] ' + endpointUrl);
      err.code = 'NON_JSON';
      throw err;
    }
    try {
      return sample ? JSON.parse(sample) : {};
    } catch (_) {
      var err2 = new Error('Invalid JSON [' + res.status + '] ' + endpointUrl);
      err2.code = 'INVALID_JSON';
      throw err2;
    }
  });
}

function masterFetchJson(path, options) {
  var attempts = API_CANDIDATES.filter(function(base) {
    var baseHost = '';
    try {
      baseHost = normalizedHost(new URL(base).hostname);
    } catch (_) {}
    return isApiLikeBase(base) || baseHost !== normalizedHost(window.location.hostname);
  });
  if (!attempts.length) attempts = [normalizeApiBase(apiUrl)];
  var index = 0;

  function attempt() {
    var base = attempts[index];
    API = base || API;
    var url = normalizeApiBase(base) + path;
    return fetch(url, options || {})
      .then(function(res) {
        if (!res.ok) {
          var e = new Error('HTTP ' + res.status + ' ' + url);
          e.status = res.status;
          throw e;
        }
        return parseJsonResponse(res, url);
      })
      .catch(function(err) {
        var canRetryParse = err && (err.code === 'NON_JSON' || err.code === 'INVALID_JSON' || /Unexpected token </.test(String(err.message || '')));
        var canRetryStatus = err && (err.status === 404 || err.status === 405);
        if ((canRetryParse || canRetryStatus) && index < attempts.length - 1) {
          index += 1;
          return attempt();
        }
        throw err;
      });
  }

  return attempt();
}

function authHeaders() {
  var token = localStorage.getItem('admin_token');
  var headers = { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token };
  if (masterStepUpToken) headers['x-master-step-up-token'] = masterStepUpToken;
  return headers;
}

function ensureMasterStepUp() {
  return fetch(API + '/master/step-up-status', { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(status) {
      if (!status.required || status.verified) return true;
      var password = prompt('Master step-up required. Re-enter your password:');
      if (!password) return false;
      return fetch(API + '/master/step-up', {
        method: 'POST',
        headers: authHeaders(),
        body: JSON.stringify({ password: password })
      }).then(function(r) { return r.json(); }).then(function(j) {
        if (!j.ok || !j.token) {
          alert(j.error || 'Step-up authentication failed');
          return false;
        }
        masterStepUpToken = j.token;
        sessionStorage.setItem('master_step_up_token', j.token);
        return true;
      });
    })
    .catch(function() {
      return true;
    });
}

function show(id) { var el = document.getElementById(id); if (el) el.style.display = ''; }
function hide(id) { var el = document.getElementById(id); if (el) el.style.display = 'none'; }
function showEl(el) { if (el) el.style.display = ''; }
function hideEl(el) { if (el) el.style.display = 'none'; }

function switchTab(tab) {
  ['sites', 'ai', 'claude'].forEach(function(t) {
    var panel = document.getElementById('panel-' + t);
    var btn = document.getElementById('tab-' + t);
    if (panel) panel.style.display = t === tab ? '' : 'none';
    if (btn) {
      if (t === tab) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    }
  });
  activeTab = tab;
  if (tab === 'sites') loadSites();
  if (tab === 'ai') loadAiUsage();
  if (tab === 'claude') {
    ensureMasterStepUp().then(function(ok) {
      if (!ok) return;
      loadClaudeRepos();
      loadClaudeKanbanTasks();
      loadClaudeAccounts();
      updateRunButtonState();
    });
  }
}

function healthDotHtml(status) {
  var cls = { online: 'health-online', degraded: 'health-degraded', offline: 'health-offline', unknown: 'health-unknown' };
  return '<span class="health-dot ' + (cls[status] || 'health-unknown') + '"></span>';
}

function rolloutBadgeHtml(status) {
  if (status === 'update_available') return '<span class="pill pill-blue">Update available</span>';
  if (status === 'changelog_live_pending') return '<span class="pill pill-amber">Rollout pending</span>';
  if (status === 'telemetry_missing' || status === 'status_unavailable') return '<span class="pill pill-amber">Status unavailable</span>';
  return '';
}

function fmt(n) { return Number(n).toLocaleString('da-DK'); }
function fmtCost(n) { return '$' + Number(n).toFixed(4); }

function renderSiteCard(site) {
  var buildLabel = site.live_build || site.version || 'ukendt';
  return '<div class="site-card">' +
    '<div class="site-card-head">' +
      '<div>' +
        '<a href="' + site.admin_url + '" target="_blank" class="site-card-name">' + site.name + '</a>' +
        '<p class="site-card-domain">' + site.domain + '</p>' +
      '</div>' +
      '<div class="site-card-badges">' +
        healthDotHtml(site.health) +
        '<span class="pill pill-gray">' + buildLabel + '</span>' +
        rolloutBadgeHtml(site.update_status) +
      '</div>' +
    '</div>' +
    '<div class="site-card-stats">' +
      '<div class="stat-mini"><div class="stat-mini-val">' + site.pages + '</div><div class="stat-mini-lbl">Sider</div></div>' +
      '<div class="stat-mini"><div class="stat-mini-val">' + site.components_used + '</div><div class="stat-mini-lbl">Kompon.</div></div>' +
      '<div class="stat-mini"><div class="stat-mini-val">' + site.media + '</div><div class="stat-mini-lbl">Media</div></div>' +
      '<div class="stat-mini"><div class="stat-mini-val">' + site.db_size_mb + '</div><div class="stat-mini-lbl">MB DB</div></div>' +
    '</div>' +
    '<div class="site-card-note">' + (site.update_message || 'Ingen opdateringsnote.') + '</div>' +
    '<div class="site-card-foot">' +
      '<span>AI tokens (30d): <strong>' + fmt(site.ai_tokens) + '</strong></span>' +
      '<span>Cost: <strong>' + fmtCost(site.ai_cost_usd) + '</strong></span>' +
      '<a href="' + site.admin_url + '" target="_blank" class="site-card-admin-link">Admin →</a>' +
    '</div>' +
  '</div>';
}

function loadSites() {
  var loading = document.getElementById('sites-loading');
  var grid = document.getElementById('sites-grid');
  var errEl = document.getElementById('sites-error');
  var banner = document.getElementById('sites-rollout-banner');
  showEl(loading);
  hideEl(grid);
  hideEl(errEl);
  hideEl(banner);

  fetch(API + '/master/sites', { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(payload) {
      var sites = Array.isArray(payload) ? payload : (payload.sites || []);
      var rollout = Array.isArray(payload) ? null : payload.rollout;
      hideEl(loading);
      grid.innerHTML = sites.map(renderSiteCard).join('');
      showEl(grid);

      if (rollout && rollout.sourceVsParent && rollout.sourceVsParent.status === 'changelog_live_pending') {
        banner.style.cssText = 'border-color:#fde68a;background:#fffbeb;color:#92400e;';
        banner.innerHTML = '<strong>Rollout afventer.</strong> ' + rollout.sourceVsParent.message;
        showEl(banner);
        return;
      }

      if (rollout && rollout.summary && rollout.summary.clientUpdateCount > 0) {
        banner.style.cssText = 'border-color:#bfdbfe;background:#eff6ff;color:#1e3a8a;';
        banner.innerHTML = '<strong>Opdateringer tilgængelige.</strong> ' + rollout.summary.clientUpdateCount + ' klientsite(s) er bag mastersitet.';
        showEl(banner);
        return;
      }

      if (rollout && (rollout.status === 'status_unavailable' || rollout.error)) {
        banner.style.cssText = 'border-color:#fde68a;background:#fffbeb;color:#78350f;';
        banner.innerHTML = '<strong>Opdateringsstatus utilgængelig.</strong> ' + (rollout.error || 'Agent Enterprise svarede ikke med rollout-data.');
        showEl(banner);
      }
    })
    .catch(function(e) {
      hideEl(loading);
      errEl.textContent = 'Kunne ikke hente sites: ' + e.message;
      showEl(errEl);
    });
}

document.getElementById('add-site-form').addEventListener('submit', function(e) {
  e.preventDefault();
  var data = {};
  new FormData(this).forEach(function(v, k) { if (v) data[k] = v; });
  fetch(API + '/master/sites', { method: 'POST', headers: authHeaders(), body: JSON.stringify(data) })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.error) { alert(res.error); return; }
      e.target.reset();
      loadSites();
    })
    .catch(function(e) { alert('Fejl: ' + e.message); });
});

function renderMiniChart(usageRows) {
  if (!usageRows || !usageRows.length) return '<p style="font-size:0.75rem;color:#9ca3af;">Ingen data</p>';
  var max = Math.max.apply(null, usageRows.map(function(r) { return Number(r.tokens) || 0; })) || 1;
  var bars = usageRows.slice(-14).map(function(r) {
    var h = Math.max(3, Math.round((Number(r.tokens) / max) * 48));
    return '<div class="ai-chart-bar" title="' + r.day + ': ' + fmt(r.tokens) + ' tokens" style="height:' + h + 'px;"></div>';
  }).join('');
  return '<div class="ai-chart">' + bars + '</div>';
}

function loadAiUsage() {
  var loading = document.getElementById('ai-loading');
  var content = document.getElementById('ai-content');
  showEl(loading);
  hideEl(content);

  fetch(API + '/master/ai-usage', { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(sites) {
      hideEl(loading);
      content.innerHTML = sites.map(function(site) {
        var totalTokens = (site.usage || []).reduce(function(s, r) { return s + Number(r.tokens); }, 0);
        var totalCost = (site.usage || []).reduce(function(s, r) { return s + Number(r.cost_usd); }, 0);
        return '<div class="ai-site-card">' +
          '<div class="ai-site-head">' +
            '<div>' +
              '<p style="font-size:0.9375rem;font-weight:600;color:#111827;margin:0;">' + site.site + '</p>' +
              '<p style="font-size:0.75rem;color:#9ca3af;margin-top:0.125rem;">' + site.domain + '</p>' +
            '</div>' +
            '<div style="text-align:right;">' +
              '<p style="font-size:0.875rem;font-weight:700;color:#111827;margin:0;">' + fmt(totalTokens) + ' tokens</p>' +
              '<p style="font-size:0.75rem;color:#9ca3af;margin-top:0.125rem;">' + fmtCost(totalCost) + ' (30 dage)</p>' +
            '</div>' +
          '</div>' +
          renderMiniChart(site.usage) +
          (site.error ? '<p class="ai-unavailable">DB utilgængelig</p>' : '') +
        '</div>';
      }).join('') || '<p style="color:#9ca3af;font-size:0.875rem;">Ingen sites fundet.</p>';
      showEl(content);
    })
    .catch(function() {
      loading.textContent = 'Kunne ikke hente AI-forbrug.';
    });
}

var claudeTasks = [];

function loadClaudeRepos() {
  var sel = document.getElementById('claude-repo');
  if (!sel) return;
  fetch(API + '/master/claude-repos', { headers: authHeaders() })
    .then(function(r) {
      if (!r.ok) throw new Error(r.status === 403 ? 'Kun master-brugere' : 'Kunne ikke hente repos');
      return r.json();
    })
    .then(function(repos) {
      sel.innerHTML = repos.map(function(r) {
        return '<option value="' + r.domain + '">' + r.name + ' (' + r.domain + ')</option>';
      }).join('');
      if (repos.length && !sel.value) sel.selectedIndex = 0;
      onClaudeRepoOrTaskChange();
    })
    .catch(function(e) {
      sel.innerHTML = '<option value="">Fejl: ' + (e.message || 'Kunne ikke hente') + '</option>';
    });
}

function loadClaudeKanbanTasks() {
  var sel = document.getElementById('claude-task');
  if (!sel) return;
  fetch(API + '/master/kanban-tasks', { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(tasks) {
      claudeTasks = tasks || [];
      sel.innerHTML = '<option value="">Vælg task…</option>' + claudeTasks.map(function(t) {
        return '<option value="' + t.id + '">#' + t.id + ' · ' + escHtml(t.title) + ' (' + t.column_name + ')</option>';
      }).join('');
      onClaudeRepoOrTaskChange();
    })
    .catch(function() {
      sel.innerHTML = '<option value="">Kunne ikke hente tasks</option>';
    });
}

function getSelectedTaskId() {
  var sel = document.getElementById('claude-task');
  var n = parseInt(sel && sel.value, 10);
  return n || null;
}

function onClaudeRepoOrTaskChange() {
  loadTaskMdFiles();
  updateRunButtonState();
}

function loadTaskMdFiles() {
  var repoEl = document.getElementById('claude-repo');
  var taskId = getSelectedTaskId();
  var mdSel = document.getElementById('claude-md-file');
  var help = document.getElementById('claude-md-help');
  if (!repoEl || !mdSel || !help) return;
  if (!repoEl.value || !taskId) {
    mdSel.innerHTML = '<option value="">Vælg repo + task først</option>';
    help.textContent = 'A run requires a planning .md file.';
    updateRunButtonState();
    return;
  }
  mdSel.innerHTML = '<option value="">Henter .md-filer…</option>';
  fetch(API + '/master/task-md-files?task_id=' + encodeURIComponent(taskId) + '&repo=' + encodeURIComponent(repoEl.value), { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var associated = data.associated || [];
      var suggested = data.suggested || [];
      var all = data.all || [];
      var opts = ['<option value="">Vælg .md-fil…</option>'];
      if (associated.length) {
        opts.push('<optgroup label="Associated with task">');
        associated.forEach(function(p) { opts.push('<option value="' + escHtml(p) + '">' + escHtml(p) + '</option>'); });
        opts.push('</optgroup>');
      }
      if (suggested.length) {
        opts.push('<optgroup label="Suggested">');
        suggested.forEach(function(p) { opts.push('<option value="' + escHtml(p) + '">' + escHtml(p) + '</option>'); });
        opts.push('</optgroup>');
      }
      opts.push('<optgroup label="All docs">');
      all.forEach(function(p) { opts.push('<option value="' + escHtml(p) + '">' + escHtml(p) + '</option>'); });
      opts.push('</optgroup>');
      mdSel.innerHTML = opts.join('');
      if (associated.length) mdSel.value = associated[0];
      help.textContent = associated.length ? 'Task-linked plan file detected.' : 'No linked .md file found for this task.';
      updateRunButtonState();
    })
    .catch(function() {
      mdSel.innerHTML = '<option value="">Kunne ikke hente .md-filer</option>';
      help.textContent = 'A run requires a planning .md file.';
      updateRunButtonState();
    });
}

function createNewPlanMd() {
  var taskId = getSelectedTaskId();
  var repoEl = document.getElementById('claude-repo');
  if (!taskId || !repoEl || !repoEl.value) {
    alert('Vælg repo og kanban task først');
    return Promise.resolve(false);
  }
  return fetch(API + '/master/task-md-files', {
    method: 'POST',
    headers: authHeaders(),
    body: JSON.stringify({ task_id: taskId, repo: repoEl.value, mode: 'create' })
  }).then(function(r) { return r.json(); })
    .then(function(j) {
      if (!j.ok) {
        alert(j.error || 'Kunne ikke oprette .md plan');
        return false;
      }
      return loadTaskMdFiles(), new Promise(function(resolve) {
        setTimeout(function() {
          var mdSel = document.getElementById('claude-md-file');
          if (mdSel && j.file_path) mdSel.value = j.file_path;
          updateRunButtonState();
          resolve(true);
        }, 200);
      });
    })
    .catch(function(e) {
      alert('Fejl: ' + e.message);
      return false;
    });
}

function loadClaudeAccounts() {
  fetch(API + '/master/claude-accounts', { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(accounts) {
      var sel = document.getElementById('claude-account');
      if (sel) {
        sel.innerHTML = accounts.map(function(a) {
          return '<option value="' + a.configDir + '">' + a.label + '</option>';
        }).join('');
      }
      loadAuthStatus();
    })
    .catch(function() { loadAuthStatus(); });
}

function loadAuthStatus() {
  var sel = document.getElementById('claude-account');
  var dot = document.getElementById('auth-dot');
  var label = document.getElementById('auth-label');
  if (!sel || !dot || !label) return;
  var account_dir = sel.value;
  fetch(API + '/master/claude-auth-status?account_dir=' + encodeURIComponent(account_dir), { headers: authHeaders() })
    .then(function(r) { return r.json(); })
    .then(function(s) {
      if (s.authenticated) {
        dot.style.background = '#22c55e';
        label.textContent = s.email || s.name || 'Authenticated';
        label.style.color = '#15803d';
      } else if (s.expired) {
        dot.style.background = '#f59e0b';
        label.textContent = 'Token expired — re-authenticate';
        label.style.color = '#92400e';
      } else {
        dot.style.background = '#d1d5db';
        label.textContent = 'Not authenticated';
        label.style.color = '#9ca3af';
      }
    })
    .catch(function() {
      dot.style.background = '#d1d5db';
      label.textContent = 'Status unknown';
      label.style.color = '#9ca3af';
    });
}

function appendOutput(text, color) {
  var out = document.getElementById('claude-output');
  var span = document.createElement('span');
  span.style.color = color || '#d1d5db';
  span.textContent = text;
  out.appendChild(span);
  if (out.children.length > 5000) {
    for (var i = 0; i < 1000; i++) { if (out.firstChild) out.removeChild(out.firstChild); }
  }
  out.scrollTop = out.scrollHeight;
}

function clearOutput() {
  document.getElementById('claude-output').innerHTML = '';
  document.getElementById('claude-status').textContent = '';
}

function setRunning(running) {
  var runBtn = document.getElementById('claude-run-btn');
  var killBtn = document.getElementById('claude-kill');
  if (runBtn) runBtn.disabled = running || !canRunClaude();
  if (killBtn) { killBtn.style.display = running ? '' : 'none'; }
  document.getElementById('claude-status').textContent = running ? 'Running…' : '';
}

function canRunClaude() {
  var body = (document.getElementById('claude-prompt').value || '').trim();
  var repo = document.getElementById('claude-repo').value;
  var taskId = getSelectedTaskId();
  var mdPath = document.getElementById('claude-md-file').value;
  return Boolean(body && repo && taskId && mdPath);
}

function updateRunButtonState() {
  var runBtn = document.getElementById('claude-run-btn');
  if (runBtn) runBtn.disabled = !canRunClaude();
}

function runClaude() {
  var body = document.getElementById('claude-prompt').value.trim();
  if (!body) { updateRunButtonState(); return; }
  var repo        = document.getElementById('claude-repo').value;
  var model       = document.getElementById('claude-model').value;
  var account_dir = document.getElementById('claude-account').value;
  var timeout_min = parseInt(document.getElementById('claude-timeout').value) || 10;
  var task_id = getSelectedTaskId();
  var md_path = document.getElementById('claude-md-file').value;

  if (!repo || !task_id) {
    alert('Vælg repository og kanban task først');
    updateRunButtonState();
    return;
  }

  var createdNewPlan = false;
  var ensurePlan = Promise.resolve(true);
  if (!md_path) {
    if (!confirm('Should we plan a new .md file?')) {
      updateRunButtonState();
      return;
    }
    ensurePlan = createNewPlanMd().then(function(ok) {
      if (ok) {
        createdNewPlan = true;
        md_path = document.getElementById('claude-md-file').value;
      }
      return ok;
    });
  }

  ensurePlan.then(function(ok) {
    if (!ok || !md_path) {
      updateRunButtonState();
      return;
    }
    clearOutput();
    setRunning(true);
    appendOutput('$ claude --model ' + model + ' --print --dangerously-skip-permissions\n', '#6b7280');
    appendOutput('  repo: ' + repo + ' | task: #' + task_id + ' | md: ' + md_path + '\n', '#4b5563');
    appendOutput('  account: ' + account_dir + ' | timeout: ' + timeout_min + 'min\n\n', '#4b5563');

    fetch(API + '/master/claude-run', {
      method: 'POST',
      headers: authHeaders(),
      body: JSON.stringify({
        prompt: body,
        repo: repo,
        model: model,
        account_dir: account_dir,
        timeout_min: timeout_min,
        task_id: task_id,
        md_path: md_path,
        created_new_plan: createdNewPlan
      }),
    }).then(function(res) {
      if (res.status === 403) {
        return res.json().then(function(j) {
          if (j.code === 'STEP_UP_REQUIRED') {
            appendOutput('Step-up authentication required. Run cancelled.\n', '#fbbf24');
          } else {
            appendOutput('Error: ' + (j.error || 'Forbidden') + '\n', '#f87171');
          }
          setRunning(false);
        });
      }
      if (res.status === 409 || res.status === 400) {
        return res.json().then(function(j) {
          appendOutput('Error: ' + j.error + '\n', '#f87171');
          setRunning(false);
        });
      }
      currentTaskId = res.headers.get('X-Task-Id');
      if (!res.body) {
        appendOutput('Error: No response body (SSE not supported?)\n', '#f87171');
        setRunning(false);
        return;
      }
      var reader = res.body.getReader();
      var decoder = new TextDecoder();
      var buf = '';
      var statusEl = document.getElementById('claude-status');
      var hitLimit = false;

      function isLimitMsg(text) {
        return /hit.{0,30}limit|usage.?limit|rate.?limit|overloaded|too many|resets\s+\w+\s+\d/i.test(text);
      }

      function read() {
        return reader.read().then(function(chunk) {
          if (chunk.done) { setRunning(false); currentTaskId = null; updateRunButtonState(); return; }
          buf += decoder.decode(chunk.value, { stream: true });
          var lines = buf.split('\n');
          buf = lines.pop();
          lines.forEach(function(line) {
            if (!line.startsWith('data: ')) return;
            var raw = line.slice(6).trim();
            if (!raw) return;
            var ev;
            try { ev = JSON.parse(raw); } catch { return; }
            if (ev.type === 'start' && ev.md_path) {
              appendOutput('[Using plan file: ' + ev.md_path + (ev.kanban_task_id ? ' | task #' + ev.kanban_task_id : '') + ']\n', '#67e8f9');
            }
            if (ev.type === 'out') {
              if (isLimitMsg(ev.text)) {
                hitLimit = true;
                appendOutput(ev.text, '#c084fc');
                if (statusEl) statusEl.textContent = 'Usage limit reached';
              } else {
                appendOutput(ev.text, '#4ade80');
              }
            }
            if (ev.type === 'err') {
              if (isLimitMsg(ev.text)) {
                hitLimit = true;
                appendOutput(ev.text, '#c084fc');
                if (statusEl) statusEl.textContent = 'Usage limit reached';
              } else {
                appendOutput(ev.text, '#fbbf24');
              }
            }
            if (ev.type === 'done') {
              if (hitLimit) {
                appendOutput('\nClaude Pro daily limit reached. Check the message above for reset time.\n', '#c084fc');
              } else {
                appendOutput('\n[Exited with code ' + ev.code + ']\n', ev.code === 0 ? '#60a5fa' : '#f87171');
              }
              setRunning(false);
              currentTaskId = null;
              updateRunButtonState();
            }
          });
          return read();
        });
      }
      return read();
    }).catch(function(err) {
      appendOutput('Request failed: ' + err.message + '\n', '#f87171');
      setRunning(false);
      updateRunButtonState();
    });
  });
}

function killClaude() {
  if (!currentTaskId) return;
  fetch(API + '/master/claude-run/' + currentTaskId, { method: 'DELETE', headers: authHeaders() })
    .then(function() {
      appendOutput('\n[Killed by user]\n', '#fbbf24');
      setRunning(false);
      currentTaskId = null;
      updateRunButtonState();
    });
}

function openAuthPanel() {
  var el = document.getElementById('claude-auth-panel');
  if (el) el.style.display = '';
}
function closeAuthPanel() {
  var el = document.getElementById('claude-auth-panel');
  if (el) el.style.display = 'none';
}

function startClaudeAuth() {
  var account_dir = document.getElementById('claude-account').value;
  var out = document.getElementById('auth-output');
  var urlBox = document.getElementById('auth-url-box');
  var urlLink = document.getElementById('auth-url-link');
  var statusEl = document.getElementById('auth-status');
  var spinner = document.getElementById('auth-spinner');
  var startBtn = document.getElementById('auth-start-btn');

  hideEl(out);
  hideEl(urlBox);
  statusEl.textContent = '';
  statusEl.style.color = '#6b7280';
  startBtn.disabled = true;
  showEl(spinner);

  fetch(API + '/master/claude-auth-start', {
    method: 'POST',
    headers: authHeaders(),
    body: JSON.stringify({ account_dir: account_dir }),
  }).then(function(r) { return r.json(); })
    .then(function(j) {
      hideEl(spinner);
      startBtn.disabled = false;

      if (j.error) {
        out.textContent = 'Error: ' + j.error + (j.detail ? '\n' + j.detail : '');
        showEl(out);
        statusEl.textContent = 'Failed — see output above';
        statusEl.style.color = '#ef4444';
        return;
      }

      if (j.url) {
        urlLink.href = j.url;
        urlLink.textContent = j.url;
        showEl(urlBox);
        statusEl.textContent = 'URL ready — click the link above, authorize, then paste the code below';
        statusEl.style.color = '#2563eb';
        document.getElementById('auth-code-input').focus();
      }
    })
    .catch(function(err) {
      hideEl(spinner);
      startBtn.disabled = false;
      out.textContent = 'Request failed: ' + err.message;
      showEl(out);
      statusEl.textContent = 'Network error';
      statusEl.style.color = '#ef4444';
    });
}

function submitAuthCode() {
  var code = document.getElementById('auth-code-input').value.trim();
  var statusEl = document.getElementById('auth-status');
  var out = document.getElementById('auth-output');
  var spinner = document.getElementById('auth-spinner');
  if (!code) {
    statusEl.textContent = 'Paste the authentication code first';
    statusEl.style.color = '#f59e0b';
    return;
  }
  statusEl.textContent = 'Submitting code — exchanging token…';
  statusEl.style.color = '#6b7280';
  showEl(spinner);

  fetch(API + '/master/claude-auth-code', {
    method: 'POST',
    headers: authHeaders(),
    body: JSON.stringify({ code: code }),
  }).then(function(r) { return r.json(); })
    .then(function(j) {
      hideEl(spinner);
      document.getElementById('auth-code-input').value = '';
      if (j.ok) {
        out.textContent = String.fromCharCode(10003) + ' ' + (j.output || 'Authentication successful.');
        showEl(out);
        statusEl.textContent = 'Authenticated! Claude Code will now use your Claude Pro account.';
        statusEl.style.color = '#16a34a';
        loadClaudeAccounts();
        loadAuthStatus();
      } else {
        out.textContent = String.fromCharCode(10007) + ' ' + j.error + (j.detail ? '\n' + j.detail : '');
        showEl(out);
        statusEl.textContent = 'Authentication failed — see output above';
        statusEl.style.color = '#ef4444';
      }
    })
    .catch(function(err) {
      hideEl(spinner);
      statusEl.textContent = 'Request failed: ' + err.message;
      statusEl.style.color = '#ef4444';
    });
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

window.switchTab = switchTab;
window.toggleIAnControl = toggleIAnControl;
window.openAddCard = openAddCard;
window.submitCard = submitCard;
window.moveCard = moveCard;
window.deleteCard = deleteCard;
window.runClaude = runClaude;
window.killClaude = killClaude;
window.clearOutput = clearOutput;
window.loadClaudeAccounts = loadClaudeAccounts;
window.loadClaudeKanbanTasks = loadClaudeKanbanTasks;
window.loadTaskMdFiles = loadTaskMdFiles;
window.onClaudeRepoOrTaskChange = onClaudeRepoOrTaskChange;
window.createNewPlanMd = createNewPlanMd;
window.updateRunButtonState = updateRunButtonState;
window.openAuthPanel = openAuthPanel;
window.closeAuthPanel = closeAuthPanel;
window.startClaudeAuth = startClaudeAuth;
window.submitAuthCode = submitAuthCode;

var promptInput = document.getElementById('claude-prompt');
if (promptInput) promptInput.addEventListener('input', updateRunButtonState);

loadSites();
</script>
