---
import AdminLayout from '../../../layouts/AdminLayout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<AdminLayout title="Produkter">
  <div class="admin-shop-products">
    <div class="asp-header">
      <h1 class="asp-title">Produkter</h1>
      <div class="asp-header-actions">
        <a id="export-btn" class="asp-btn-secondary" href="#">Eksporter CSV</a>
        <label class="asp-btn-secondary" style="cursor:pointer;">
          Importer CSV
          <input type="file" id="import-file" accept=".csv" style="display:none;">
        </label>
        <button id="new-product-btn" class="asp-btn-primary">+ Nyt produkt</button>
      </div>
    </div>
    <div id="import-result" class="asp-import-result" style="display:none;"></div>

    <div class="asp-filters">
      <input id="search-input" type="search" placeholder="Søg produkt eller SKU..." class="admin-input asp-search" />
      <select id="status-filter" class="admin-input">
        <option value="">Alle statuser</option>
        <option value="1">Aktive</option>
        <option value="0">Inaktive</option>
      </select>
    </div>

    <div id="loading" class="asp-loading">Henter produkter...</div>
    <div id="error" class="asp-error" style="display:none"></div>

    <div id="products-table-wrap" class="asp-table-wrap" style="display:none">
      <table class="asp-table">
        <thead>
          <tr>
            <th class="asp-th">Produkt</th>
            <th class="asp-th">Pris</th>
            <th class="asp-th">Lager</th>
            <th class="asp-th">Status</th>
            <th class="asp-th">Handling</th>
          </tr>
        </thead>
        <tbody id="products-tbody" class="asp-tbody"></tbody>
      </table>
    </div>
    <div id="pagination" class="asp-pagination" style="display:none"></div>
  </div>

  <div id="product-modal" class="asp-modal-backdrop" style="display:none">
    <div class="asp-modal">
      <div class="asp-modal-header">
        <h2 id="modal-title" class="asp-modal-title">Nyt produkt</h2>
        <button id="modal-close" class="asp-modal-close">&times;</button>
      </div>
      <form id="product-form" class="asp-modal-body">
        <input type="hidden" id="product-id" value="" />
        <div class="asp-grid">
          <div class="asp-col-2">
            <label class="admin-label" for="p-name">Navn *</label>
            <input id="p-name" name="name" class="admin-input asp-full" required />
          </div>
          <div class="asp-col-2">
            <label class="admin-label" for="p-slug">Slug *</label>
            <input id="p-slug" name="slug" class="admin-input asp-full" required />
          </div>
          <div>
            <label class="admin-label" for="p-price">Pris (øre, f.eks. 9995) *</label>
            <input id="p-price" name="price_ore" type="number" min="0" class="admin-input asp-full" required />
          </div>
          <div>
            <label class="admin-label" for="p-compare">Sammenligningspris (øre)</label>
            <input id="p-compare" name="compare_ore" type="number" min="0" class="admin-input asp-full" />
          </div>
          <div>
            <label class="admin-label" for="p-sku">SKU</label>
            <input id="p-sku" name="sku" class="admin-input asp-full" />
          </div>
          <div>
            <label class="admin-label" for="p-stock">Lager</label>
            <input id="p-stock" name="stock" type="number" min="0" class="admin-input asp-full" />
          </div>
          <div class="asp-col-2">
            <label class="admin-label" for="p-short-desc">Kort beskrivelse</label>
            <textarea id="p-short-desc" name="short_desc" rows="2" class="admin-input asp-full"></textarea>
          </div>
          <div class="asp-col-2">
            <label class="admin-label" for="p-desc">Beskrivelse (HTML tilladt)</label>
            <textarea id="p-desc" name="description" rows="4" class="admin-input asp-full"></textarea>
          </div>
          <div class="asp-checkbox-row">
            <input id="p-active" name="is_active" type="checkbox" checked />
            <label for="p-active" class="asp-checkbox-label">Aktiv</label>
          </div>
          <div class="asp-checkbox-row">
            <input id="p-featured" name="is_featured" type="checkbox" />
            <label for="p-featured" class="asp-checkbox-label">Anbefalet</label>
          </div>
          <div class="asp-checkbox-row">
            <input id="p-track-stock" name="track_stock" type="checkbox" checked />
            <label for="p-track-stock" class="asp-checkbox-label">Spor lager</label>
          </div>
        </div>
        <div id="form-error" class="asp-form-error" style="display:none"></div>
        <div class="asp-modal-footer">
          <button type="button" id="form-cancel" class="asp-btn-secondary">Annuller</button>
          <button type="submit" id="form-save" class="asp-btn-primary">Gem</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<style>
.admin-shop-products { display: flex; flex-direction: column; gap: 24px; }
.asp-header { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px; }
.asp-title { font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); margin: 0; }
.asp-filters { display: flex; flex-wrap: wrap; gap: 12px; }
.asp-search { width: 100%; }
@media (min-width: 640px) { .asp-search { width: 16rem; } }
.asp-loading { text-align: center; padding: 32px 0; color: var(--color-text-secondary); }
.asp-error { color: #dc2626; padding: 16px 0; }
.asp-table-wrap { overflow-x: auto; border-radius: var(--radius-md); border: 1px solid var(--color-border); }
.asp-table { min-width: 100%; border-collapse: collapse; font-size: 0.875rem; }
.asp-table thead { background: var(--color-neutral-100); }
.asp-th {
  padding: 12px 16px;
  text-align: left;
  font-weight: 600;
  color: var(--color-text-secondary);
  white-space: nowrap;
}
.asp-tbody tr { border-top: 1px solid var(--color-border); }
.asp-tbody tr:hover { background: var(--color-neutral-100); }
.asp-pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  padding-top: 8px;
}
.asp-td { padding: 12px 16px; }
.asp-product-cell { display: flex; align-items: center; gap: 12px; }
.asp-product-thumb { width: 40px; height: 40px; border-radius: var(--radius-sm, 4px); object-fit: cover; }
.asp-product-thumb-empty { width: 40px; height: 40px; border-radius: var(--radius-sm, 4px); background: var(--color-neutral-100); flex-shrink: 0; }
.asp-product-name { font-weight: 500; color: var(--color-text-primary); margin: 0; }
.asp-product-sku { font-size: 0.75rem; color: var(--color-text-secondary); margin: 0; }
.asp-status-badge { display: inline-block; border-radius: 9999px; padding: 2px 8px; font-size: 0.75rem; font-weight: 600; }
.asp-status-active { background: #dcfce7; color: #166534; }
.asp-status-inactive { background: var(--color-neutral-100); color: var(--color-text-secondary); }
.asp-action-btn { font-size: 0.75rem; padding: 0; border: none; background: none; cursor: pointer; }
.asp-edit-btn { color: var(--color-primary); }
.asp-edit-btn:hover { text-decoration: underline; }
.asp-delete-btn { color: #ef4444; }
.asp-delete-btn:hover { text-decoration: underline; }
.asp-pag-btn { padding: 4px 12px; border: 1px solid var(--color-border); border-radius: var(--radius-sm, 4px); font-size: 0.75rem; cursor: pointer; background: none; }

.asp-modal-backdrop {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-start; justify-content: center;
  overflow-y: auto; padding: 32px 16px;
}
.asp-modal { width: 100%; max-width: 36rem; background: white; border-radius: var(--radius-xl, 12px); box-shadow: var(--shadow-xl); }
.asp-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid var(--color-border); }
.asp-modal-title { font-size: 1.125rem; font-weight: 700; color: var(--color-text-primary); margin: 0; }
.asp-modal-close { font-size: 1.25rem; line-height: 1; background: none; border: none; cursor: pointer; color: var(--color-text-secondary); }
.asp-modal-close:hover { color: var(--color-text-primary); }
.asp-modal-body { padding: 24px; display: flex; flex-direction: column; gap: 16px; }
.asp-modal-footer { display: flex; justify-content: flex-end; gap: 12px; padding-top: 8px; }
.asp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.asp-col-2 { grid-column: 1 / -1; }
.asp-full { width: 100%; box-sizing: border-box; }
.asp-checkbox-row { display: flex; align-items: center; gap: 8px; }
.asp-checkbox-label { font-size: 0.875rem; font-weight: 500; color: var(--color-text-primary); }
.asp-form-error { border-radius: var(--radius-sm); background: #fef2f2; border: 1px solid #fca5a5; padding: 8px 12px; font-size: 0.875rem; color: #b91c1c; }

.admin-input {
  border: 1px solid var(--color-border, #d1d5db);
  border-radius: var(--radius-md, 0.375rem);
  padding: 6px 10px;
  font-size: 0.875rem;
  outline: none;
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}
.admin-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
}
.admin-label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 4px; }
.asp-header-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.asp-btn-secondary {
  display: inline-block;
  padding: 8px 14px;
  background: var(--color-surface, #fff);
  color: var(--color-text-primary);
  border: 1.5px solid var(--color-border, #e5e7eb);
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  text-decoration: none;
  transition: border-color 150ms, background 150ms;
}
.asp-btn-secondary:hover { border-color: var(--color-primary); background: #f8faff; }
.asp-import-result {
  padding: 12px 16px;
  border-radius: var(--radius-md);
  font-size: 0.875rem;
}
.asp-import-result.success { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
.asp-import-result.error { background: #fef2f2; border: 1px solid #fca5a5; color: #dc2626; }
.asp-btn-primary {
  padding: 8px 16px;
  background: var(--color-primary);
  color: var(--color-text-on-primary);
  border: none;
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: opacity 150ms;
}
.asp-btn-primary:hover:not(:disabled) { opacity: 0.9; }
.asp-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
.asp-btn-secondary {
  padding: 8px 16px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  background: none;
  cursor: pointer;
  color: var(--color-text-primary);
}
.asp-btn-secondary:hover { background: var(--color-neutral-100); }
</style>

<script define:vars={{ apiUrl }}>
  const token = () => localStorage.getItem('admin_token');
  const headers = () => ({ 'Content-Type': 'application/json', 'Authorization': `Bearer ${token()}` });

  let currentPage = 1;
  let editingId = null;

  async function loadProducts() {
    const search = document.getElementById('search-input').value;
    const active = document.getElementById('status-filter').value;
    const params = new URLSearchParams({ page: currentPage, limit: 25, ...(search && { search }), ...(active !== '' && { active }) });

    try {
      const res = await fetch(`${apiUrl}/shop/admin/products?${params}`, { headers: headers() });
      const data = await res.json();
      document.getElementById('loading')?.classList.add('hidden');
      const tableWrap = document.getElementById('products-table-wrap');
      if (tableWrap) tableWrap.style.display = 'block';

      const tbody = document.getElementById('products-tbody');
      tbody.innerHTML = '';
      (data.products || []).forEach(p => {
        const tr = document.createElement('tr');
        const statusCls = p.is_active ? 'asp-status-active' : 'asp-status-inactive';
        const statusLabel = p.is_active ? 'Aktiv' : 'Inaktiv';
        tr.innerHTML = `
          <td class="asp-td">
            <div class="asp-product-cell">
              ${p.primary_image ? `<img src="${p.primary_image}" class="asp-product-thumb" loading="lazy"/>` : '<div class="asp-product-thumb-empty"></div>'}
              <div>
                <p class="asp-product-name">${p.name}</p>
                <p class="asp-product-sku">${p.sku || '—'}</p>
              </div>
            </div>
          </td>
          <td class="asp-td">${(p.price_ore / 100).toFixed(2).replace('.', ',')} kr.</td>
          <td class="asp-td">${p.track_stock ? p.stock : '∞'}</td>
          <td class="asp-td">
            <span class="asp-status-badge ${statusCls}">${statusLabel}</span>
          </td>
          <td class="asp-td" style="display:flex;gap:8px;align-items:center">
            <button class="asp-action-btn asp-edit-btn edit-btn" data-id="${p.id}">Rediger</button>
            <button class="asp-action-btn asp-delete-btn delete-btn" data-id="${p.id}" data-name="${p.name}">Slet</button>
          </td>
        `;
        tbody.appendChild(tr);
      });

      const pag = document.getElementById('pagination');
      if (pag) {
        pag.style.display = 'flex';
        pag.innerHTML = `<span>Side ${currentPage} · ${data.total} produkter i alt</span>
          <div style="display:flex;gap:8px">
            ${currentPage > 1 ? '<button id="prev-page" class="asp-pag-btn">← Forrige</button>' : ''}
            ${data.total > currentPage * 25 ? '<button id="next-page" class="asp-pag-btn">Næste →</button>' : ''}
          </div>`;
        document.getElementById('prev-page')?.addEventListener('click', () => { currentPage--; loadProducts(); });
        document.getElementById('next-page')?.addEventListener('click', () => { currentPage++; loadProducts(); });
      }
    } catch (e) {
      document.getElementById('loading')?.classList.add('hidden');
      const errEl = document.getElementById('error');
      errEl.textContent = 'Fejl ved hentning af produkter: ' + e.message;
      errEl.style.display = 'block';
    }
  }

  document.getElementById('products-tbody')?.addEventListener('click', async (e) => {
    if (e.target.classList.contains('edit-btn')) {
      await openEdit(parseInt(e.target.dataset.id));
    }
    if (e.target.classList.contains('delete-btn')) {
      if (!confirm(`Slet "${e.target.dataset.name}"?`)) return;
      await fetch(`${apiUrl}/shop/admin/products/${e.target.dataset.id}`, { method: 'DELETE', headers: headers() });
      loadProducts();
    }
  });

  let searchTimer;
  document.getElementById('search-input')?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { currentPage = 1; loadProducts(); }, 400);
  });
  document.getElementById('status-filter')?.addEventListener('change', () => { currentPage = 1; loadProducts(); });

  async function openEdit(id) {
    const res = await fetch(`${apiUrl}/shop/admin/products/${id}`, { headers: headers() });
    const p = await res.json();
    editingId = id;
    document.getElementById('modal-title').textContent = 'Rediger produkt';
    document.getElementById('product-id').value = id;
    document.getElementById('p-name').value = p.name || '';
    document.getElementById('p-slug').value = p.slug || '';
    document.getElementById('p-price').value = p.price_ore || '';
    document.getElementById('p-compare').value = p.compare_ore || '';
    document.getElementById('p-sku').value = p.sku || '';
    document.getElementById('p-stock').value = p.stock || 0;
    document.getElementById('p-short-desc').value = p.short_desc || '';
    document.getElementById('p-desc').value = p.description || '';
    document.getElementById('p-active').checked = !!p.is_active;
    document.getElementById('p-featured').checked = !!p.is_featured;
    document.getElementById('p-track-stock').checked = !!p.track_stock;
    document.getElementById('product-modal').style.display = 'flex';
  }

  function openNew() {
    editingId = null;
    document.getElementById('modal-title').textContent = 'Nyt produkt';
    document.getElementById('product-form').reset();
    document.getElementById('product-id').value = '';
    document.getElementById('p-active').checked = true;
    document.getElementById('p-track-stock').checked = true;
    const formErr = document.getElementById('form-error');
    if (formErr) formErr.style.display = 'none';
    document.getElementById('product-modal').style.display = 'flex';
  }

  document.getElementById('new-product-btn')?.addEventListener('click', openNew);
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  document.getElementById('form-cancel')?.addEventListener('click', closeModal);
  function closeModal() { document.getElementById('product-modal').style.display = 'none'; }

  document.getElementById('product-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('form-save');
    btn.disabled = true;
    btn.textContent = 'Gemmer...';

    const body = {
      name: document.getElementById('p-name').value,
      slug: document.getElementById('p-slug').value,
      price_ore: document.getElementById('p-price').value,
      compare_ore: document.getElementById('p-compare').value || null,
      sku: document.getElementById('p-sku').value || null,
      stock: document.getElementById('p-stock').value,
      short_desc: document.getElementById('p-short-desc').value || null,
      description: document.getElementById('p-desc').value || null,
      is_active: document.getElementById('p-active').checked,
      is_featured: document.getElementById('p-featured').checked,
      track_stock: document.getElementById('p-track-stock').checked,
    };

    const url = editingId ? `${apiUrl}/shop/admin/products/${editingId}` : `${apiUrl}/shop/admin/products`;
    const method = editingId ? 'PUT' : 'POST';

    try {
      const res = await fetch(url, { method, headers: headers(), body: JSON.stringify(body) });
      const data = await res.json();
      const formErr = document.getElementById('form-error');
      if (!res.ok) {
        formErr.textContent = data.error || 'Fejl';
        formErr.style.display = 'block';
      } else {
        closeModal();
        loadProducts();
      }
    } catch (e) {
      const formErr = document.getElementById('form-error');
      formErr.textContent = e.message;
      formErr.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Gem';
    }
  });

  document.getElementById('p-name')?.addEventListener('input', () => {
    if (editingId) return;
    const slug = document.getElementById('p-name').value
      .toLowerCase()
      .replace(/æ/g, 'ae').replace(/ø/g, 'oe').replace(/å/g, 'aa')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    document.getElementById('p-slug').value = slug;
  });

  loadProducts();

  // Export CSV
  document.getElementById('export-btn').addEventListener('click', (e) => {
    e.preventDefault();
    const url = `${apiUrl}/shop/admin/products/export.csv`;
    const a = document.createElement('a');
    a.href = url;
    a.setAttribute('Authorization', `Bearer ${token()}`);
    fetch(url, { headers: headers() })
      .then(res => res.blob())
      .then(blob => {
        const objUrl = URL.createObjectURL(blob);
        a.href = objUrl;
        a.download = 'products-export.csv';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(objUrl);
      })
      .catch(() => alert('Eksport fejlede'));
  });

  // Import CSV
  document.getElementById('import-file').addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const resultEl = document.getElementById('import-result');
    resultEl.style.display = 'none';

    const fd = new FormData();
    fd.append('file', file);

    try {
      const res = await fetch(`${apiUrl}/shop/admin/products/import`, {
        method: 'POST',
        headers: { Authorization: `Bearer ${token()}` },
        body: fd,
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Import fejlede');
      resultEl.textContent = `Import fuldført: ${data.upserted} produkter opdateret/oprettet, ${data.skipped} sprunget over.${data.errors?.length ? ' Fejl på rækker: ' + data.errors.map(er => er.row).join(', ') : ''}`;
      resultEl.className = 'asp-import-result success';
      resultEl.style.display = 'block';
      loadProducts();
    } catch (err) {
      resultEl.textContent = err.message;
      resultEl.className = 'asp-import-result error';
      resultEl.style.display = 'block';
    }
    e.target.value = '';
  });
</script>
