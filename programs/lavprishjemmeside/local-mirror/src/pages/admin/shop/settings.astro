---
import AdminLayout from '../../../layouts/AdminLayout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<AdminLayout title="Shop-indstillinger">
  <div class="shop-settings">
    <h1 class="ss-title">Shop-indstillinger</h1>

    <div id="loading" class="ss-loading">Henter indstillinger...</div>

    <form id="settings-form" class="ss-form" style="display:none">

      <section class="ss-section">
        <h2 class="ss-section-title">Generelt</h2>
        <div class="ss-field">
          <label class="admin-label" for="shop-name">Shopnavn</label>
          <input id="shop-name" name="shop_name" class="admin-input ss-input-full" />
        </div>
        <div class="ss-field">
          <label class="admin-label" for="shop-email">Shop-e-mail (bekræftelsesmails sendes fra/til)</label>
          <input id="shop-email" name="shop_email" type="email" class="admin-input ss-input-full" />
        </div>
        <div class="ss-field">
          <label class="admin-label" for="cvr">CVR-nummer</label>
          <input id="cvr" name="cvr_number" class="admin-input ss-input-sm" />
        </div>
      </section>

      <section class="ss-section">
        <h2 class="ss-section-title">Flatpay / Frisbii betaling</h2>
        <p class="ss-help-text">API-nøgler gemmes krypteret. Eksisterende nøgler vises som ••••••••. Lad feltet stå tomt for at beholde eksisterende nøgle.</p>
        <div class="ss-field">
          <label class="admin-label" for="fp-key">Flatpay API-nøgle (privat, format: priv_xxxx)</label>
          <input id="fp-key" name="flatpay_api_key" type="password" autocomplete="off" class="admin-input ss-input-full" placeholder="••••••••" />
        </div>
        <div class="ss-field">
          <label class="admin-label" for="fp-secret">Webhook-hemmelighed</label>
          <input id="fp-secret" name="flatpay_webhook_secret" type="password" autocomplete="off" class="admin-input ss-input-full" placeholder="••••••••" />
        </div>
        <div class="ss-checkbox-row">
          <input id="fp-test" name="flatpay_test_mode" type="checkbox" />
          <label for="fp-test" class="ss-checkbox-label">Test-tilstand (brug Frisbii testmiljø)</label>
        </div>
        <div class="ss-webhook-box">
          <strong>Webhook URL (til Flatpay dashboard):</strong><br>
          <code id="webhook-url" class="ss-webhook-url"></code>
        </div>
      </section>

      <section class="ss-section">
        <h2 class="ss-section-title">E-mail-notifikationer</h2>
        <div class="ss-field">
          <label class="admin-label" for="notify-email">Admin-e-mail (modtager kopi af nye ordrer)</label>
          <input id="notify-email" name="notify_admin_email" type="email" class="admin-input ss-input-full" />
        </div>
        <div class="ss-checkbox-row">
          <input id="cust-confirm" name="send_customer_confirmation" type="checkbox" />
          <label for="cust-confirm" class="ss-checkbox-label">Send ordrebekræftelse til kunden</label>
        </div>
        <div class="ss-checkbox-row">
          <input id="ship-notify" name="send_shipping_notification" type="checkbox" />
          <label for="ship-notify" class="ss-checkbox-label">Send forsendelsesnotifikation til kunden</label>
        </div>
      </section>

      <div id="settings-error" class="ss-alert ss-alert-error" style="display:none"></div>
      <div id="settings-success" class="ss-alert ss-alert-success" style="display:none">Indstillinger gemt!</div>

      <button type="submit" id="save-btn" class="ss-save-btn">Gem indstillinger</button>
    </form>
  </div>
</AdminLayout>

<style>
.shop-settings { display: flex; flex-direction: column; gap: 32px; max-width: 42rem; }
.ss-title { font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); margin: 0; }
.ss-loading { text-align: center; padding: 32px 0; color: var(--color-text-secondary); }
.ss-form { display: flex; flex-direction: column; gap: 32px; }
.ss-section {
  border-radius: var(--radius-lg, 12px);
  border: 1px solid var(--color-border);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.ss-section-title { font-size: 1.125rem; font-weight: 600; color: var(--color-text-primary); margin: 0; }
.ss-field { display: flex; flex-direction: column; gap: 4px; }
.ss-input-full { width: 100%; box-sizing: border-box; }
.ss-input-sm { width: 10rem; }
.ss-checkbox-row { display: flex; align-items: center; gap: 8px; }
.ss-checkbox-label { font-size: 0.875rem; font-weight: 500; color: var(--color-text-primary); }
.ss-help-text { font-size: 0.875rem; color: var(--color-text-secondary); margin: 0; }
.ss-webhook-box {
  font-size: 0.875rem;
  color: #92400e;
  background: #fffbeb;
  border: 1px solid #fcd34d;
  border-radius: var(--radius-md);
  padding: 12px;
  line-height: 1.6;
}
.ss-webhook-url { font-size: 0.75rem; word-break: break-all; }
.ss-alert {
  border-radius: var(--radius-md);
  padding: 12px 16px;
  font-size: 0.875rem;
}
.ss-alert-error { background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; }
.ss-alert-success { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
.ss-save-btn {
  padding: 10px 24px;
  background: var(--color-primary);
  color: var(--color-text-on-primary);
  border: none;
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  align-self: flex-start;
  transition: opacity 150ms;
}
.ss-save-btn:hover:not(:disabled) { opacity: 0.9; }
.ss-save-btn:disabled { opacity: 0.5; cursor: not-allowed; }

.admin-input {
  border: 1px solid var(--color-border, #d1d5db);
  border-radius: var(--radius-md, 0.375rem);
  padding: 6px 10px;
  font-size: 0.875rem;
  outline: none;
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}
.admin-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
}
.admin-label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 4px; }
</style>

<script define:vars={{ apiUrl }}>
  const token = () => localStorage.getItem('admin_token');
  const headers = () => ({ 'Content-Type': 'application/json', 'Authorization': `Bearer ${token()}` });

  document.getElementById('webhook-url').textContent = `${apiUrl}/shop/flatpay/webhook`;

  async function load() {
    const res = await fetch(`${apiUrl}/shop/admin/settings`, { headers: headers() });
    const s = await res.json();

    document.getElementById('loading')?.classList.add('hidden');
    const form = document.getElementById('settings-form');
    if (form) form.style.display = 'flex';

    document.getElementById('shop-name').value = s.shop_name || '';
    document.getElementById('shop-email').value = s.shop_email || '';
    document.getElementById('cvr').value = s.cvr_number || '';
    document.getElementById('fp-test').checked = !!s.flatpay_test_mode;
    document.getElementById('notify-email').value = s.notify_admin_email || '';
    document.getElementById('cust-confirm').checked = !!s.send_customer_confirmation;
    document.getElementById('ship-notify').checked = !!s.send_shipping_notification;
  }

  document.getElementById('settings-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('save-btn');
    const errEl = document.getElementById('settings-error');
    const succEl = document.getElementById('settings-success');
    errEl.style.display = 'none';
    succEl.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Gemmer...';

    const body = {
      shop_name: document.getElementById('shop-name').value,
      shop_email: document.getElementById('shop-email').value,
      cvr_number: document.getElementById('cvr').value,
      flatpay_test_mode: document.getElementById('fp-test').checked,
      notify_admin_email: document.getElementById('notify-email').value,
      send_customer_confirmation: document.getElementById('cust-confirm').checked,
      send_shipping_notification: document.getElementById('ship-notify').checked,
    };

    const fpKey = document.getElementById('fp-key').value.trim();
    const fpSecret = document.getElementById('fp-secret').value.trim();
    if (fpKey) body.flatpay_api_key = fpKey;
    if (fpSecret) body.flatpay_webhook_secret = fpSecret;

    try {
      const res = await fetch(`${apiUrl}/shop/admin/settings`, {
        method: 'POST', headers: headers(), body: JSON.stringify(body)
      });
      const data = await res.json();
      if (!res.ok) {
        errEl.textContent = data.error || 'Fejl';
        errEl.style.display = 'block';
      } else {
        succEl.style.display = 'block';
        document.getElementById('fp-key').value = '';
        document.getElementById('fp-secret').value = '';
        setTimeout(() => { succEl.style.display = 'none'; }, 3000);
      }
    } catch (err) {
      errEl.textContent = err.message;
      errEl.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Gem indstillinger';
    }
  });

  load();
</script>
