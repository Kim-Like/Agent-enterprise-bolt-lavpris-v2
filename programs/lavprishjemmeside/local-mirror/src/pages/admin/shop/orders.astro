---
import AdminLayout from '../../../layouts/AdminLayout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<AdminLayout title="Ordrer">
  <div class="admin-orders">
    <div class="ao-header">
      <h1 class="ao-title">Ordrer</h1>
    </div>

    <div id="stats-row" class="ao-stats-grid">
      <div class="ao-stat-card">
        <p class="ao-stat-label">Omsætning (30d)</p>
        <p id="stat-revenue" class="ao-stat-value">—</p>
      </div>
      <div class="ao-stat-card">
        <p class="ao-stat-label">Ordrer (30d)</p>
        <p id="stat-orders" class="ao-stat-value">—</p>
      </div>
      <div class="ao-stat-card">
        <p class="ao-stat-label">Afventer betaling</p>
        <p id="stat-pending" class="ao-stat-value ao-stat-warning">—</p>
      </div>
      <div class="ao-stat-card">
        <p class="ao-stat-label">Klar til afsendelse</p>
        <p id="stat-to-ship" class="ao-stat-value ao-stat-info">—</p>
      </div>
    </div>

    <div class="ao-filters">
      <input id="search-input" type="search" placeholder="Søg ordre, e-mail, navn..." class="admin-input ao-search" />
      <select id="status-filter" class="admin-input">
        <option value="">Alle statuser</option>
        <option value="pending_payment">Afventer betaling</option>
        <option value="paid">Betalt</option>
        <option value="processing">Under behandling</option>
        <option value="shipped">Afsendt</option>
        <option value="delivered">Leveret</option>
        <option value="cancelled">Annulleret</option>
        <option value="refunded">Refunderet</option>
      </select>
    </div>

    <div id="loading" class="ao-loading">Henter ordrer...</div>

    <div id="orders-table-wrap" class="ao-table-wrap" style="display:none">
      <table class="ao-table">
        <thead>
          <tr>
            <th class="ao-th">Ordre</th>
            <th class="ao-th">Kunde</th>
            <th class="ao-th">Total</th>
            <th class="ao-th">Status</th>
            <th class="ao-th">Dato</th>
            <th class="ao-th">Handling</th>
          </tr>
        </thead>
        <tbody id="orders-tbody" class="ao-tbody"></tbody>
      </table>
    </div>

    <div id="pagination" class="ao-pagination" style="display:none"></div>
  </div>

  <div id="order-modal" class="ao-modal-backdrop" style="display:none">
    <div class="ao-modal">
      <div class="ao-modal-header">
        <h2 id="modal-order-title" class="ao-modal-title">Ordredetaljer</h2>
        <button id="modal-close" class="ao-modal-close">&times;</button>
      </div>
      <div id="modal-body" class="ao-modal-body"></div>
    </div>
  </div>

  <div id="refund-modal" class="ao-modal-backdrop" style="display:none">
    <div class="ao-modal" style="max-width:32rem">
      <div class="ao-modal-header">
        <h2 class="ao-modal-title">Refunder ordre</h2>
        <button id="refund-modal-close" class="ao-modal-close">&times;</button>
      </div>
      <div class="ao-modal-body">
        <div>
          <label class="ao-field-label" for="refund-reason">Årsag (valgfri)</label>
          <input id="refund-reason" type="text" class="admin-input" style="width:100%;margin-top:4px" placeholder="F.eks. kunden ønsker at annullere" />
        </div>
        <div>
          <label class="ao-field-label">Gendan lagerbeholdning?</label>
          <div style="display:flex;align-items:center;gap:8px;margin-top:6px">
            <input type="checkbox" id="refund-restore-stock" style="width:1rem;height:1rem;accent-color:var(--color-primary)" />
            <label for="refund-restore-stock" style="font-size:0.875rem;color:var(--color-text-primary)">Ja, gendan lager for alle varer</label>
          </div>
        </div>
        <div id="refund-error" class="ao-notice ao-notice-error" style="display:none"></div>
        <div style="display:flex;gap:8px;justify-content:flex-end">
          <button id="refund-cancel-btn" class="ao-cancel-btn">Annuller</button>
          <button id="refund-confirm-btn" class="ao-danger-btn">Bekræft refundering</button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<style>
.admin-orders { display: flex; flex-direction: column; gap: 24px; }
.ao-header { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px; }
.ao-title { font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); margin: 0; }
.ao-stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
@media (min-width: 768px) { .ao-stats-grid { grid-template-columns: repeat(4, 1fr); } }
.ao-stat-card {
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  padding: 16px;
}
.ao-stat-label { font-size: 0.75rem; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; }
.ao-stat-value { font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); margin: 4px 0 0; }
.ao-stat-warning { color: #d97706; }
.ao-stat-info { color: #2563eb; }
.ao-filters { display: flex; flex-wrap: wrap; gap: 12px; }
.ao-search { width: 100%; }
@media (min-width: 640px) { .ao-search { width: 16rem; } }
.ao-loading { text-align: center; padding: 32px 0; color: var(--color-text-secondary); }
.ao-table-wrap { overflow-x: auto; border-radius: var(--radius-md); border: 1px solid var(--color-border); }
.ao-table { min-width: 100%; border-collapse: collapse; font-size: 0.875rem; }
.ao-table thead { background: var(--color-neutral-100); }
.ao-th { padding: 12px 16px; text-align: left; font-weight: 600; color: var(--color-text-secondary); white-space: nowrap; }
.ao-tbody tr { border-top: 1px solid var(--color-border); }
.ao-tbody tr:hover { background: var(--color-neutral-100); }
.ao-td { padding: 12px 16px; }
.ao-customer-name { color: var(--color-text-primary); margin: 0; }
.ao-customer-email { font-size: 0.75rem; color: var(--color-text-secondary); margin: 0; }
.ao-status-badge { display: inline-block; border-radius: 9999px; padding: 2px 8px; font-size: 0.75rem; font-weight: 600; }
.ao-status-pending { background: #fef3c7; color: #92400e; }
.ao-status-paid { background: #dcfce7; color: #166534; }
.ao-status-processing { background: #dbeafe; color: #1e40af; }
.ao-status-shipped { background: #dbeafe; color: #1e40af; }
.ao-status-delivered { background: #dcfce7; color: #166534; }
.ao-status-cancelled { background: #fee2e2; color: #991b1b; }
.ao-status-refunded { background: var(--color-neutral-100); color: var(--color-text-secondary); }
.ao-view-btn { font-size: 0.75rem; color: var(--color-primary); background: none; border: none; cursor: pointer; padding: 0; }
.ao-view-btn:hover { text-decoration: underline; }
.ao-pagination {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 0.875rem; color: var(--color-text-secondary); padding-top: 8px;
}
.ao-pag-btn { padding: 4px 12px; border: 1px solid var(--color-border); border-radius: var(--radius-sm, 4px); font-size: 0.75rem; cursor: pointer; background: none; }
.ao-date { color: var(--color-text-secondary); }
.ao-order-number { font-weight: 500; color: var(--color-text-primary); }

.ao-modal-backdrop {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-start; justify-content: center;
  overflow-y: auto; padding: 32px 16px;
}
.ao-modal { width: 100%; max-width: 42rem; background: white; border-radius: var(--radius-xl, 12px); box-shadow: var(--shadow-xl); }
.ao-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid var(--color-border); }
.ao-modal-title { font-size: 1.125rem; font-weight: 700; color: var(--color-text-primary); margin: 0; }
.ao-modal-close { font-size: 1.25rem; background: none; border: none; cursor: pointer; color: var(--color-text-secondary); }
.ao-modal-close:hover { color: var(--color-text-primary); }
.ao-modal-body { padding: 24px; display: flex; flex-direction: column; gap: 24px; }

.admin-input {
  border: 1px solid var(--color-border, #d1d5db);
  border-radius: var(--radius-md, 0.375rem);
  padding: 6px 10px;
  font-size: 0.875rem;
  outline: none;
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}
.admin-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
}
.ao-field-label {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.ao-notice {
  border-radius: var(--radius-md, 6px);
  padding: 10px 14px;
  font-size: 0.875rem;
}
.ao-notice-error {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  color: #b91c1c;
}
.ao-cancel-btn {
  padding: 6px 16px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md, 6px);
  font-size: 0.875rem;
  background: none;
  cursor: pointer;
  color: var(--color-text-primary);
}
.ao-cancel-btn:hover { background: var(--color-neutral-100); }
.ao-danger-btn {
  padding: 6px 16px;
  border: none;
  border-radius: var(--radius-md, 6px);
  font-size: 0.875rem;
  font-weight: 600;
  background: #dc2626;
  color: #fff;
  cursor: pointer;
}
.ao-danger-btn:hover { background: #b91c1c; }
.ao-danger-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.ao-refund-btn {
  padding: 4px 12px;
  font-size: 0.75rem;
  border: 1px solid #fca5a5;
  border-radius: 9999px;
  cursor: pointer;
  background: #fef2f2;
  color: #b91c1c;
  font-weight: 500;
}
.ao-refund-btn:hover { background: #fee2e2; }
.ao-note-row { display: flex; gap: 8px; }
.ao-note-input { flex: 1; }
.ao-save-note-btn {
  padding: 4px 14px;
  background: var(--color-text-primary);
  color: white;
  border: none;
  border-radius: var(--radius-sm, 4px);
  font-size: 0.75rem;
  cursor: pointer;
  white-space: nowrap;
}
.ao-save-note-btn:hover { opacity: 0.85; }
.ao-event-internal { color: var(--color-text-primary); font-style: italic; }
.ao-customer-note-box {
  background: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: var(--radius-sm, 4px);
  padding: 8px 12px;
  font-size: 0.875rem;
  color: #78350f;
}
</style>

<script define:vars={{ apiUrl }}>
  const token = () => localStorage.getItem('admin_token');
  const headers = () => ({ 'Content-Type': 'application/json', 'Authorization': `Bearer ${token()}` });

  const statusMap = {
    pending_payment: ['Afventer betaling', 'ao-status-pending'],
    paid: ['Betalt', 'ao-status-paid'],
    processing: ['Under behandling', 'ao-status-processing'],
    shipped: ['Afsendt', 'ao-status-shipped'],
    delivered: ['Leveret', 'ao-status-delivered'],
    cancelled: ['Annulleret', 'ao-status-cancelled'],
    refunded: ['Refunderet', 'ao-status-refunded'],
  };

  function fmt(ore) { return (ore / 100).toFixed(2).replace('.', ',') + ' kr.'; }
  function fmtDate(d) { if (!d) return '—'; return new Date(d).toLocaleDateString('da-DK', { day: '2-digit', month: 'short', year: 'numeric' }); }

  let currentPage = 1;

  async function loadDashboard() {
    try {
      const res = await fetch(`${apiUrl}/shop/admin/dashboard`, { headers: headers() });
      const d = await res.json();
      if (d.revenue) {
        document.getElementById('stat-revenue').textContent = fmt(d.revenue.revenue_30d_ore || 0);
        document.getElementById('stat-orders').textContent = d.revenue.orders_30d || 0;
        document.getElementById('stat-pending').textContent = d.revenue.pending || 0;
        document.getElementById('stat-to-ship').textContent = d.revenue.to_ship || 0;
      }
    } catch {}
  }

  async function loadOrders() {
    const search = document.getElementById('search-input').value;
    const status = document.getElementById('status-filter').value;
    const params = new URLSearchParams({ page: currentPage, limit: 25, ...(search && { search }), ...(status && { status }) });

    try {
      const res = await fetch(`${apiUrl}/shop/admin/orders?${params}`, { headers: headers() });
      const data = await res.json();
      document.getElementById('loading')?.classList.add('hidden');
      const tableWrap = document.getElementById('orders-table-wrap');
      if (tableWrap) tableWrap.style.display = 'block';

      const tbody = document.getElementById('orders-tbody');
      tbody.innerHTML = '';
      (data.orders || []).forEach(o => {
        const [label, cls] = statusMap[o.status] || [o.status, 'ao-status-refunded'];
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td class="ao-td ao-order-number">${o.order_number}</td>
          <td class="ao-td">
            <p class="ao-customer-name">${o.ship_first_name} ${o.ship_last_name}</p>
            <p class="ao-customer-email">${o.ship_email}</p>
          </td>
          <td class="ao-td" style="font-weight:500">${fmt(o.total_ore)}</td>
          <td class="ao-td">
            <span class="ao-status-badge ${cls}">${label}</span>
          </td>
          <td class="ao-td ao-date">${fmtDate(o.created_at)}</td>
          <td class="ao-td">
            <button class="ao-view-btn view-btn" data-id="${o.id}">Se detaljer</button>
          </td>
        `;
        tbody.appendChild(tr);
      });

      const pag = document.getElementById('pagination');
      if (pag) {
        pag.style.display = 'flex';
        pag.innerHTML = `<span>Side ${currentPage} · ${data.total} ordrer i alt</span>
          <div style="display:flex;gap:8px">
            ${currentPage > 1 ? '<button id="prev-page" class="ao-pag-btn">← Forrige</button>' : ''}
            ${data.total > currentPage * 25 ? '<button id="next-page" class="ao-pag-btn">Næste →</button>' : ''}
          </div>`;
        document.getElementById('prev-page')?.addEventListener('click', () => { currentPage--; loadOrders(); });
        document.getElementById('next-page')?.addEventListener('click', () => { currentPage++; loadOrders(); });
      }
    } catch {}
  }

  document.getElementById('orders-tbody')?.addEventListener('click', async (e) => {
    if (e.target.classList.contains('view-btn')) openOrder(parseInt(e.target.dataset.id));
  });

  let currentOrderId = null;

  async function openOrder(id) {
    const res = await fetch(`${apiUrl}/shop/admin/orders/${id}`, { headers: headers() });
    const o = await res.json();
    currentOrderId = o.id;

    const [label, cls] = statusMap[o.status] || [o.status, 'ao-status-refunded'];
    const refundableStatuses = ['paid', 'processing', 'shipped', 'delivered'];
    const canRefund = refundableStatuses.includes(o.status);

    document.getElementById('modal-order-title').textContent = `Ordre ${o.order_number}`;
    document.getElementById('modal-body').innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;font-size:0.875rem">
        <div>
          <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0">Status</p>
          <div style="display:flex;align-items:center;gap:8px;margin-top:4px;flex-wrap:wrap">
            <span class="ao-status-badge ${cls}">${label}</span>
            ${canRefund ? `<button class="ao-refund-btn" id="open-refund-modal-btn">Refunder</button>` : ''}
          </div>
        </div>
        <div>
          <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0">Total</p>
          <p style="font-weight:700;margin:4px 0 0">${fmt(o.total_ore)}</p>
        </div>
        <div>
          <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0">Kunde</p>
          <p style="margin:4px 0 0">${o.ship_first_name} ${o.ship_last_name}<br><a href="mailto:${o.ship_email}" style="color:var(--color-primary)">${o.ship_email}</a></p>
        </div>
        <div>
          <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0">Adresse</p>
          <p style="margin:4px 0 0">${o.ship_address1}, ${o.ship_zip} ${o.ship_city}</p>
        </div>
      </div>

      ${o.customer_note ? `
        <div>
          <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0 0 6px">Note fra kunde</p>
          <div class="ao-customer-note-box">${o.customer_note}</div>
        </div>
      ` : ''}

      <div>
        <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0 0 8px">Produkter</p>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:4px;font-size:0.875rem">
          ${(o.items || []).map(i => `
            <li style="display:flex;justify-content:space-between">
              <span>${i.product_name}${i.variant_name ? ' / ' + i.variant_name : ''} × ${i.quantity}</span>
              <span style="font-weight:500">${fmt(i.total_price_ore)}</span>
            </li>
          `).join('')}
        </ul>
      </div>

      <div style="border-top:1px solid var(--color-border);padding-top:16px">
        <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0 0 12px">Opdater status</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px">
          ${['paid','processing','shipped','delivered','cancelled'].map(s => {
            const [sl] = statusMap[s] || [s, ''];
            return `<button class="status-update-btn" data-order-id="${o.id}" data-status="${s}" style="padding:4px 12px;font-size:0.75rem;border:1px solid var(--color-border);border-radius:9999px;cursor:pointer;font-weight:500;background:${o.status === s ? 'var(--color-neutral-100)' : 'none'}">${sl}</button>`;
          }).join('')}
        </div>
      </div>

      <div style="border-top:1px solid var(--color-border);padding-top:16px">
        <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0 0 8px">Sporings-id</p>
        <div style="display:flex;gap:8px">
          <input id="tracking-number" type="text" value="${o.tracking_number || ''}" placeholder="Sporings-id" class="admin-input" style="flex:1" />
          <input id="tracking-carrier" type="text" value="${o.tracking_carrier || ''}" placeholder="Fragtfirma" class="admin-input" style="width:7rem" />
          <button id="save-tracking-btn" data-order-id="${o.id}" style="padding:4px 12px;background:var(--color-text-primary);color:white;border:none;border-radius:var(--radius-sm,4px);font-size:0.75rem;cursor:pointer">Gem</button>
        </div>
      </div>

      <div style="border-top:1px solid var(--color-border);padding-top:16px">
        <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0 0 8px">Intern note</p>
        <div class="ao-note-row">
          <input id="internal-note-input" type="text" class="admin-input ao-note-input" placeholder="Tilføj intern note..." />
          <button id="save-note-btn" class="ao-save-note-btn" data-order-id="${o.id}">Gem</button>
        </div>
      </div>

      <div style="border-top:1px solid var(--color-border);padding-top:16px">
        <p style="font-size:0.75rem;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;margin:0 0 8px">Hændelseslog</p>
        <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:6px;font-size:0.75rem">
          ${(o.events || []).map(ev => {
            const isNote = ev.event_type === 'internal_note';
            const style = isNote ? 'color:var(--color-text-primary);' : 'color:var(--color-text-secondary);';
            const prefix = isNote ? '📝 Intern note' : `<strong>${ev.event_type}</strong>`;
            return `<li style="${style}">${new Date(ev.created_at).toLocaleString('da-DK')} · ${prefix}${ev.message ? ' — ' + ev.message : ''}</li>`;
          }).join('')}
        </ul>
      </div>
    `;

    document.querySelectorAll('.status-update-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        await fetch(`${apiUrl}/shop/admin/orders/${btn.dataset.orderId}/status`, {
          method: 'POST', headers: headers(),
          body: JSON.stringify({ status: btn.dataset.status })
        });
        document.getElementById('order-modal').style.display = 'none';
        loadOrders();
        loadDashboard();
      });
    });

    document.getElementById('save-tracking-btn')?.addEventListener('click', async (e) => {
      await fetch(`${apiUrl}/shop/admin/orders/${e.target.dataset.orderId}/tracking`, {
        method: 'POST', headers: headers(),
        body: JSON.stringify({
          tracking_number: document.getElementById('tracking-number').value,
          tracking_carrier: document.getElementById('tracking-carrier').value,
        })
      });
    });

    document.getElementById('save-note-btn')?.addEventListener('click', async (e) => {
      const noteInput = document.getElementById('internal-note-input');
      const note = noteInput?.value?.trim();
      if (!note) return;
      const ordId = parseInt(e.target.dataset.orderId);
      const saveRes = await fetch(`${apiUrl}/shop/admin/orders/${ordId}/note`, {
        method: 'POST', headers: headers(),
        body: JSON.stringify({ note }),
      });
      if (saveRes.ok) {
        noteInput.value = '';
        openOrder(ordId);
      }
    });

    document.getElementById('open-refund-modal-btn')?.addEventListener('click', () => {
      document.getElementById('order-modal').style.display = 'none';
      document.getElementById('refund-reason').value = '';
      document.getElementById('refund-restore-stock').checked = false;
      document.getElementById('refund-error').style.display = 'none';
      document.getElementById('refund-modal').style.display = 'flex';
    });

    document.getElementById('order-modal').style.display = 'flex';
  }

  document.getElementById('refund-modal-close')?.addEventListener('click', () => {
    document.getElementById('refund-modal').style.display = 'none';
  });

  document.getElementById('refund-cancel-btn')?.addEventListener('click', () => {
    document.getElementById('refund-modal').style.display = 'none';
  });

  document.getElementById('refund-confirm-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('refund-confirm-btn');
    const errEl = document.getElementById('refund-error');
    const reason = document.getElementById('refund-reason').value.trim();
    const restoreStock = document.getElementById('refund-restore-stock').checked;

    btn.disabled = true;
    btn.textContent = 'Refunderer...';
    errEl.style.display = 'none';

    try {
      const res = await fetch(`${apiUrl}/shop/admin/orders/${currentOrderId}/refund`, {
        method: 'POST', headers: headers(),
        body: JSON.stringify({ reason: reason || null, restore_stock: restoreStock }),
      });
      const data = await res.json();
      if (!res.ok) {
        errEl.textContent = data.error || 'Refundering fejlede';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Bekræft refundering';
        return;
      }
      document.getElementById('refund-modal').style.display = 'none';
      loadOrders();
      loadDashboard();
    } catch {
      errEl.textContent = 'Der opstod en fejl. Prøv igen.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Bekræft refundering';
    }
  });

  document.getElementById('modal-close')?.addEventListener('click', () => {
    document.getElementById('order-modal').style.display = 'none';
  });

  let searchTimer;
  document.getElementById('search-input')?.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { currentPage = 1; loadOrders(); }, 400);
  });
  document.getElementById('status-filter')?.addEventListener('change', () => { currentPage = 1; loadOrders(); });

  loadDashboard();
  loadOrders();
</script>
