---
import AdminLayout from '../../layouts/AdminLayout.astro';
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api.lavprishjemmeside.dk';
---

<AdminLayout title="Oversigt">
  <style>
    .dash-stat-card { background:#fff; border:1px solid #e5e7eb; border-radius:0.75rem; padding:1.125rem 1.25rem; transition:box-shadow 0.14s; }
    .dash-stat-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.07); }
    .dash-stat-value { font-size:1.75rem; font-weight:700; color:#111827; letter-spacing:-0.03em; line-height:1.1; }
    .dash-stat-label { font-size:0.75rem; color:#6b7280; font-weight:500; margin-bottom:0.25rem; display:block; }
    .dash-stat-trend { display:inline-flex; align-items:center; gap:0.2rem; font-size:0.6875rem; font-weight:600; margin-top:0.25rem; }
    .dash-stat-trend--up { color:#16a34a; }
    .dash-stat-trend--neutral { color:#9ca3af; }
    .skel { background:linear-gradient(90deg,#f3f4f6 25%,#e9ebee 50%,#f3f4f6 75%); background-size:200% 100%; animation:skelShimmer 1.4s infinite; border-radius:0.375rem; }
    @keyframes skelShimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .activity-chart-wrap { background:#fff; border:1px solid #e5e7eb; border-radius:0.75rem; padding:1.25rem; margin-bottom:1.25rem; }
    .activity-chart-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:0.875rem; }
    .activity-chart-title { font-size:0.8125rem; font-weight:600; color:#111827; }
    .activity-bars { display:flex; align-items:flex-end; gap:3px; height:4.5rem; }
    .activity-bar { flex:1; border-radius:3px 3px 0 0; background:#3b82f6; opacity:0.7; transition:opacity 0.14s; min-width:0; cursor:default; }
    .activity-bar:hover { opacity:1; }
    .activity-day-labels { display:flex; gap:3px; margin-top:0.25rem; }
    .activity-day-label { flex:1; font-size:0.55rem; color:#9ca3af; text-align:center; white-space:nowrap; overflow:hidden; }
    .dash-table th { font-size:0.6875rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#9ca3af; padding-bottom:0.5rem; border-bottom:1px solid #f3f4f6; text-align:left; }
    .dash-table td { padding:0.5rem 0; font-size:0.8125rem; border-bottom:1px solid #f9fafb; color:#374151; }
    .dash-table tr:last-child td { border-bottom:none; }
    .dash-section-card { background:#fff; border:1px solid #e5e7eb; border-radius:0.75rem; padding:1.25rem; }
    .dash-section-title { font-size:0.8125rem; font-weight:600; color:#111827; margin-bottom:0.875rem; display:flex; align-items:center; justify-content:space-between; }
    .dash-section-link { font-size:0.75rem; color:#3b82f6; text-decoration:none; font-weight:500; }
    .dash-section-link:hover { text-decoration:underline; }
    .version-strip { background:#0f1117; border-radius:0.75rem; color:#fff; padding:1rem 1.25rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
    .version-meta-label { font-size:0.6rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#6b7280; display:block; margin-bottom:0.125rem; }
    .version-meta-value { font-size:0.8125rem; font-weight:600; color:#f9fafb; }
    .pill-gray { display:inline-flex; align-items:center; font-size:0.6875rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:9999px; background:rgba(255,255,255,0.1); color:#d1d5db; }
    .copy-btn { background:rgba(255,255,255,0.08); color:#d1d5db; border:1px solid rgba(255,255,255,0.1); padding:0.35rem 0.75rem; border-radius:0.4rem; font-size:0.75rem; cursor:pointer; transition:background 0.14s ease; white-space:nowrap; }
    .copy-btn:hover { background:rgba(255,255,255,0.13); }
    .publish-btn { background:#f59e0b; color:#fff; border:none; padding:0.45rem 1rem; border-radius:0.5rem; font-size:0.8125rem; font-weight:600; cursor:pointer; transition:background 0.14s ease; white-space:nowrap; }
    .publish-btn:hover { background:#d97706; }
    .publish-btn:disabled { opacity:0.6; cursor:not-allowed; }
    .status-dot { display:inline-block; width:0.5rem; height:0.5rem; border-radius:50%; flex-shrink:0; }
    .banner-strip { border-radius:0.6rem; padding:0.65rem 1rem; font-size:0.8rem; }
    .page-row { display:flex; align-items:center; justify-content:space-between; padding:0.35rem 0; border-bottom:1px solid #f9fafb; }
    .page-row:last-child { border-bottom:none; }
    .feature-row { display:flex; align-items:center; gap:0.4rem; font-size:0.8rem; color:#6b7280; padding:0.15rem 0; }
    .content-link { display:flex; align-items:center; gap:0.375rem; font-size:0.8rem; color:#3b82f6; text-decoration:none; padding:0.3rem 0; }
    .content-link:hover { text-decoration:underline; }
    .quick-action-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0.625rem; margin-bottom:1.25rem; }
    .quick-action-btn {
      display:flex; flex-direction:column; align-items:flex-start; gap:0.375rem;
      background:#fff; border:1px solid #e5e7eb; border-radius:0.75rem;
      padding:0.875rem 1rem; text-decoration:none; cursor:pointer;
      transition:border-color 0.14s ease, box-shadow 0.14s ease, background 0.14s ease;
    }
    .quick-action-btn:hover { border-color:#93c5fd; box-shadow:0 0 0 3px rgba(59,130,246,0.08); background:#f0f9ff; }
    .qa-icon { display:flex; align-items:center; justify-content:center; width:2rem; height:2rem; border-radius:0.5rem; flex-shrink:0; }
    .qa-label { font-size:0.8125rem; font-weight:600; color:#111827; line-height:1.3; }
    .qa-sub { font-size:0.6875rem; color:#9ca3af; line-height:1.3; }
    @media (max-width:900px) {
      .dash-three-col { grid-template-columns: 1fr !important; }
      .dash-two-col { grid-template-columns: 1fr !important; }
      .quick-action-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width:600px) {
      .quick-action-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <script is:inline>
    (function() {
      if (typeof window !== 'undefined' && window.location.search.indexOf('message=master_required') !== -1) {
        var el = document.getElementById('master-required-banner');
        if (el) el.classList.remove('hidden');
      }
    })();
  </script>

  <div id="master-required-banner" class="hidden banner-strip mb-4" style="background:#fef3c7;border:1px solid #fcd34d;color:#92400e;">
    Kun master-brugere har adgang til Master Hub.
  </div>

  <div id="loading">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(10rem,1fr));gap:0.75rem;margin-bottom:1.25rem;">
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.125rem 1.25rem;"><div class="skel" style="height:0.75rem;width:55%;margin-bottom:0.5rem;"></div><div class="skel" style="height:1.75rem;width:70%;"></div></div>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.125rem 1.25rem;"><div class="skel" style="height:0.75rem;width:55%;margin-bottom:0.5rem;"></div><div class="skel" style="height:1.75rem;width:70%;"></div></div>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.125rem 1.25rem;"><div class="skel" style="height:0.75rem;width:55%;margin-bottom:0.5rem;"></div><div class="skel" style="height:1.75rem;width:70%;"></div></div>
      <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.125rem 1.25rem;"><div class="skel" style="height:0.75rem;width:55%;margin-bottom:0.5rem;"></div><div class="skel" style="height:1.75rem;width:70%;"></div></div>
    </div>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.25rem;margin-bottom:1.25rem;"><div class="skel" style="height:4.5rem;width:100%;"></div></div>
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.25rem;"><div class="skel" style="height:1rem;width:40%;margin-bottom:0.75rem;"></div><div class="skel" style="height:0.75rem;width:100%;margin-bottom:0.4rem;"></div><div class="skel" style="height:0.75rem;width:90%;margin-bottom:0.4rem;"></div><div class="skel" style="height:0.75rem;width:80%;"></div></div>
  </div>
  <div id="error" class="hidden" style="text-align:center;padding:3rem 0;">
    <p id="error-text" style="color:#ef4444;margin-bottom:0.75rem;font-size:0.875rem;"></p>
    <button onclick="window.location.reload()" style="color:#3b82f6;font-size:0.8rem;background:none;border:none;cursor:pointer;text-decoration:underline;">Prøv igen</button>
  </div>

  <div id="dashboard" style="display:none;">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1.25rem;">
      <div>
        <h1 style="font-size:1.25rem;font-weight:700;color:#111827;margin:0;letter-spacing:-0.02em;">Oversigt</h1>
        <p style="font-size:0.75rem;color:#9ca3af;margin:0.125rem 0 0;">Webstedsstatus og seneste aktivitet</p>
      </div>
      <button id="dashboard-publish-btn" class="publish-btn">Publicer til live (~90 sek)</button>
    </div>

    <div id="rollout-banner" class="hidden banner-strip mb-5"></div>

    <div class="version-strip mb-6">
      <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;min-width:0;">
        <div>
          <span class="version-meta-label">Build</span>
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <span id="cms-build" class="version-meta-value" style="font-size:1rem;letter-spacing:-0.01em;">—</span>
            <span id="cms-release-pill" class="pill-gray">Release —</span>
          </div>
        </div>
        <div>
          <span class="version-meta-label">Commit</span>
          <span id="cms-commit" class="version-meta-value" style="font-family:monospace;font-size:0.8rem;">—</span>
        </div>
        <div>
          <span class="version-meta-label">Seneste ændring</span>
          <span id="cms-committed-at" class="version-meta-value">—</span>
        </div>
        <div>
          <span class="version-meta-label">Kanal</span>
          <span id="cms-update-channel" class="version-meta-value">—</span>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <p id="cms-version-help" style="font-size:0.7rem;color:#6b7280;max-width:18rem;text-align:right;display:none;"></p>
        <button id="cms-copy-version-btn" class="copy-btn">Kopiér build-id</button>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(10rem,1fr));gap:0.75rem;margin-bottom:1.25rem;">
      <div class="dash-stat-card">
        <span class="dash-stat-label">Hændelser i alt</span>
        <span class="dash-stat-value" id="stat-events-total">&mdash;</span>
        <div id="stat-events-total-trend" class="dash-stat-trend dash-stat-trend--neutral" style="display:none;"></div>
      </div>
      <div class="dash-stat-card">
        <span class="dash-stat-label">Hændelser i dag</span>
        <span class="dash-stat-value" id="stat-events-today">&mdash;</span>
        <div id="stat-events-today-note" style="font-size:0.6875rem;color:#9ca3af;margin-top:0.25rem;display:none;">seneste 24 timer</div>
      </div>
      <div class="dash-stat-card">
        <span class="dash-stat-label">Sessioner i alt</span>
        <span class="dash-stat-value" id="stat-sessions-total">&mdash;</span>
        <div id="stat-sessions-total-trend" class="dash-stat-trend dash-stat-trend--neutral" style="display:none;"></div>
      </div>
      <div class="dash-stat-card">
        <span class="dash-stat-label">Sider pr. session</span>
        <span class="dash-stat-value" id="stat-avg-pages">&mdash;</span>
        <div style="font-size:0.6875rem;color:#9ca3af;margin-top:0.25rem;">gennemsnit</div>
      </div>
    </div>

    <div class="activity-chart-wrap" id="activity-chart-section" style="display:none;">
      <div class="activity-chart-header">
        <span class="activity-chart-title">Aktivitet — seneste 14 dage</span>
        <span id="activity-chart-peak" style="font-size:0.6875rem;color:#9ca3af;"></span>
      </div>
      <div class="activity-bars" id="activity-bars"></div>
      <div class="activity-day-labels" id="activity-day-labels"></div>
    </div>

    <div class="quick-action-grid">
      <a href="/admin/ai-assemble/" class="quick-action-btn">
        <div class="qa-icon" style="background:#eff6ff;">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#3b82f6" stroke-width="1.8"><polygon points="13 2 3 14 12 14 7 22 17 10 8 10"/></svg>
        </div>
        <span class="qa-label">Ny side med AI</span>
        <span class="qa-sub">Generer sideindhold automatisk</span>
      </a>
      <a href="/admin/pages/" class="quick-action-btn">
        <div class="qa-icon" style="background:#f0fdf4;">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#16a34a" stroke-width="1.8"><rect x="3" y="2" width="14" height="16" rx="2"/><line x1="7" y1="7" x2="13" y2="7"/><line x1="7" y1="11" x2="13" y2="11"/><line x1="7" y1="15" x2="10" y2="15"/></svg>
        </div>
        <span class="qa-label">Rediger sider</span>
        <span class="qa-sub">Tilpas komponenter og indhold</span>
      </a>
      <a href="/admin/media/" class="quick-action-btn">
        <div class="qa-icon" style="background:#fff7ed;">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#ea580c" stroke-width="1.8"><rect x="2" y="4" width="16" height="12" rx="2"/><circle cx="7" cy="9" r="1.5"/><path d="M2 14l4-4 3 3 3-3 6 4"/></svg>
        </div>
        <span class="qa-label">Upload medier</span>
        <span class="qa-sub">Billeder til sider og shop</span>
      </a>
      <button id="quick-publish-btn" class="quick-action-btn" style="border:none;text-align:left;">
        <div class="qa-icon" style="background:#fefce8;">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#ca8a04" stroke-width="1.8"><path d="M10 2v10M5 7l5-5 5 5"/><path d="M3 17h14"/></svg>
        </div>
        <span class="qa-label">Publicer nu</span>
        <span class="qa-sub">Send ændringer live</span>
      </button>
    </div>

    <div class="dash-three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1.25rem;">
      <div class="dash-section-card">
        <div class="dash-section-title">Sider <a href="/admin/pages/" class="dash-section-link">Rediger &rarr;</a></div>
        <div id="settings-pages"><p style="font-size:0.8rem;color:#9ca3af;">Henter...</p></div>
      </div>
      <div class="dash-section-card">
        <div class="dash-section-title">Design <div style="display:flex;gap:0.75rem;"><a href="/admin/styling/" class="dash-section-link">Styling &rarr;</a><a href="/admin/header-footer/" class="dash-section-link">Header &rarr;</a></div></div>
        <div id="settings-global"><p style="font-size:0.8rem;color:#9ca3af;">Henter...</p></div>
      </div>
      <div class="dash-section-card">
        <div class="dash-section-title">Indhold &amp; SEO</div>
        <a href="/admin/media/" class="content-link"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="16" height="12" rx="2"/><circle cx="7" cy="9" r="1.5"/><path d="M2 14l4-4 3 3 3-3 6 4"/></svg>Mediebibliotek</a>
        <a href="/admin/pages/" class="content-link"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="6"/><path d="M17 17l3 3"/></svg>SEO for sider</a>
        <a href="/admin/ai-assemble/" class="content-link"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="13 2 3 14 12 14 7 22 17 10 8 10"/></svg>AI Indholdsudvikler</a>
        <a href="/admin/assistant/" class="content-link"><svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 10c0 4.4-3.6 8-8 8H3l2-2a8 8 0 1 1 13-6z"/></svg>Assistant</a>
      </div>
    </div>

    <div class="dash-two-col" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;">
      <div class="dash-section-card">
        <div class="dash-section-title">Top hændelser</div>
        <table class="dash-table" style="width:100%;"><thead><tr><th>Hændelse</th><th>Type</th><th style="text-align:right;">Antal</th></tr></thead><tbody id="table-top-events"><tr><td colspan="3" style="color:#9ca3af;">Henter...</td></tr></tbody></table>
      </div>
      <div class="dash-section-card">
        <div class="dash-section-title">Top landingssider</div>
        <table class="dash-table" style="width:100%;"><thead><tr><th>Side</th><th style="text-align:right;">Sessioner</th></tr></thead><tbody id="table-top-pages"><tr><td colspan="2" style="color:#9ca3af;">Henter...</td></tr></tbody></table>
      </div>
    </div>

    <div class="dash-section-card">
      <div class="dash-section-title">Seneste hændelser</div>
      <div style="overflow-x:auto;">
        <table class="dash-table" style="width:100%;"><thead><tr><th>Type</th><th>Navn</th><th>Side</th><th>Tidspunkt</th></tr></thead><tbody id="table-recent-events"><tr><td colspan="4" style="color:#9ca3af;">Henter...</td></tr></tbody></table>
      </div>
    </div>
  </div>

  <script define:vars={{ apiUrl }}>
  (function() {
    var API = apiUrl;
    var token = localStorage.getItem('admin_token');
    if (!token) return;

    function authFetch(url) {
      return fetch(url, { headers: { 'Authorization': 'Bearer ' + token } }).then(function(res) {
        if (res.status === 401 || res.status === 403) {
          localStorage.removeItem('admin_token');
          window.location.href = '/admin/';
          throw new Error('Unauthorized');
        }
        if (res.status === 503) throw new Error('503 Service Unavailable — API-serveren er utilgængelig. Genstart Node.js på serveren (touch api/tmp/restart.txt).');
        if (!res.ok) throw new Error('HTTP ' + res.status + ' — ' + res.statusText);
        return res.json();
      });
    }

    function esc(str) {
      var div = document.createElement('div');
      div.textContent = str || '';
      return div.innerHTML;
    }

    function fmt(dateStr) {
      if (!dateStr) return '\u2014';
      var d = new Date(dateStr);
      return d.toLocaleDateString('da-DK') + ' ' + d.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit' });
    }

    function setVersionMeta(meta) {
      var build = meta && meta.build ? meta.build : '\u2014';
      var releaseVersion = meta && meta.release_version ? meta.release_version : '\u2014';
      var commitShort = meta && meta.commit_short ? meta.commit_short : '\u2014';
      var committedAt = meta && meta.git_committed_at ? fmt(meta.git_committed_at) : '\u2014';
      var updateChannel = meta && meta.update_channel ? meta.update_channel : '\u2014';
      var gitRef = meta && meta.git_ref ? meta.git_ref : null;
      var dirty = Boolean(meta && meta.dirty);

      document.getElementById('cms-build').textContent = build;
      document.getElementById('cms-release-pill').textContent = 'Release ' + releaseVersion;
      document.getElementById('cms-commit').textContent = commitShort;
      document.getElementById('cms-committed-at').textContent = committedAt;
      document.getElementById('cms-update-channel').textContent = updateChannel;

      if (dirty || (gitRef && gitRef !== build)) {
        var helpEl = document.getElementById('cms-version-help');
        if (helpEl) {
          helpEl.textContent = dirty ? 'Lokale ændringer til stede.' : 'Git ref: ' + gitRef;
          helpEl.style.display = 'block';
        }
      }

      var copyBtn = document.getElementById('cms-copy-version-btn');
      if (copyBtn) copyBtn.dataset.copyValue = build;
    }

    function renderRolloutStatus(payload) {
      var banner = document.getElementById('rollout-banner');
      if (!banner) return;

      if (!payload) {
        banner.style.cssText = 'background:#fef3c7;border:1px solid #fcd34d;color:#92400e;';
        banner.innerHTML = '<strong>Opdateringsstatus utilgængelig.</strong> Kunne ikke hente release-status fra Agent Enterprise.';
        banner.classList.remove('hidden');
        return;
      }

      var comparison = payload.comparison || payload.sourceVsParent || null;
      var summary = payload.summary || null;
      var status = comparison && comparison.status ? comparison.status : (payload.status || (summary && summary.status) || 'unknown');
      var message = comparison && comparison.message
        ? comparison.message
        : (payload.error || (summary && summary.warnings && summary.warnings[0]) || 'Ingen aktiv release-advarsel.');

      if (status === 'aligned' && !(summary && summary.pendingParentRollout) && !(summary && summary.clientUpdateCount)) {
        banner.classList.add('hidden');
        return;
      }

      banner.classList.remove('hidden');

      if (status === 'changelog_live_pending' || (summary && summary.pendingParentRollout)) {
        banner.style.cssText = 'background:#fef3c7;border:1px solid #fcd34d;color:#92400e;';
        banner.innerHTML = '<strong>Rollout afventer.</strong> ' + message;
        return;
      }
      if (status === 'update_available') {
        banner.style.cssText = 'background:#dbeafe;border:1px solid #bfdbfe;color:#1e40af;';
        banner.innerHTML = '<strong>Opdatering tilgængelig.</strong> ' + message;
        return;
      }
      banner.style.cssText = 'background:#fef3c7;border:1px solid #fcd34d;color:#92400e;';
      banner.innerHTML = '<strong>Opdateringsstatus utilgængelig.</strong> ' + message;
    }

    function refreshRolloutStatus() {
      authFetch(API + '/rollout/status').then(renderRolloutStatus).catch(function() { renderRolloutStatus(null); });
    }

    Promise.all([
      authFetch(API + '/health').catch(function() { return null; }),
      authFetch(API + '/rollout/status').catch(function() { return null; }),
      authFetch(API + '/events/summary').catch(function() { return { total: 0, today: 0, top_events: [], recent: [] }; }),
      authFetch(API + '/sessions/summary').catch(function() { return { total: 0, today: 0, avg_pages: 0, top_pages: [], recent: [] }; }),
      authFetch(API + '/design-settings/').catch(function() { return null; }),
      authFetch(API + '/page-components?page=all').catch(function() { return []; })
    ])
    .then(function(results) {
      var health = results[0] || null;
      var rollout = results[1] || null;
      var events = results[2] || { total: 0, today: 0, top_events: [], recent: [] };
      var sessions = results[3] || { total: 0, today: 0, avg_pages: 0, top_pages: [], recent: [] };
      var designSettings = results[4];
      var pageComponents = results[5] || [];

      setVersionMeta(health && health.cms ? health.cms : null);
      renderRolloutStatus(rollout);

      var pageGroups = {};
      pageComponents.forEach(function(pc) {
        var path = (pc.page_path || '/').trim();
        if (!pageGroups[path]) pageGroups[path] = { total: 0, published: 0 };
        pageGroups[path].total++;
        if (pc.is_published) pageGroups[path].published++;
      });
      var pagesHtml = '';
      var paths = Object.keys(pageGroups).sort();
      if (paths.length === 0) {
        pagesHtml = '<p style="font-size:0.8rem;color:#9ca3af;">Ingen sider. <a href="/admin/ai-assemble/" style="color:#3b82f6;">Opret side</a></p>';
      } else {
        paths.forEach(function(p) {
          var g = pageGroups[p];
          var allPub = g.published === g.total;
          pagesHtml += '<div class="page-row">'
            + '<span style="font-family:monospace;font-size:0.75rem;color:#374151;">' + esc(p) + '</span>'
            + '<span style="display:flex;align-items:center;gap:0.3rem;">'
            + '<span class="status-dot" style="background:' + (allPub ? '#22c55e' : '#f59e0b') + ';"></span>'
            + '<span style="font-size:0.75rem;color:#6b7280;">' + g.published + '/' + g.total + '</span>'
            + '</span></div>';
        });
      }
      document.getElementById('settings-pages').innerHTML = pagesHtml;

      var globalHtml = '';
      if (designSettings) {
        var primary = designSettings.color_primary || '#2563EB';
        globalHtml = '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.4rem;">'
          + '<span style="display:inline-block;width:1rem;height:1rem;border-radius:0.25rem;background:' + esc(primary) + ';border:1px solid rgba(0,0,0,0.08);flex-shrink:0;"></span>'
          + '<span style="font-size:0.8rem;color:#374151;">Primær: <code style="font-size:0.75rem;color:#6b7280;">' + esc(primary) + '</code></span></div>'
          + '<div class="feature-row"><svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><path d="M4 8h12M4 12h12"/></svg> Font: ' + esc(designSettings.font_heading || designSettings.font_body || '—') + '</div>'
          + '<div class="feature-row"><svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><rect x="2" y="2" width="16" height="16" rx="4"/></svg> Radius: ' + esc(designSettings.border_radius || '—') + '</div>'
          + '<div class="feature-row"><svg width="11" height="11" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;"><rect x="3" y="5" width="14" height="10" rx="2"/></svg> Skygge: ' + esc(designSettings.shadow_style || '—') + '</div>';
        var features = [['Smooth scroll', designSettings.feature_smooth_scroll], ['Korn-overlay', designSettings.feature_grain_overlay], ['Sideloader', designSettings.feature_page_loader], ['Klæbende header', designSettings.feature_sticky_header]];
        globalHtml += '<div style="margin-top:0.5rem;padding-top:0.5rem;border-top:1px solid #f3f4f6;">';
        features.forEach(function(f) {
          var on = (f[1] ?? 1) !== 0;
          globalHtml += '<div class="feature-row"><span class="status-dot" style="background:' + (on ? '#22c55e' : '#d1d5db') + ';"></span><span>' + esc(f[0]) + '</span></div>';
        });
        globalHtml += '</div>';
      } else {
        globalHtml = '<p style="font-size:0.8rem;color:#9ca3af;">Kunne ikke hente. <a href="/admin/styling/" style="color:#3b82f6;">Åbn styling</a></p>';
      }
      document.getElementById('settings-global').innerHTML = globalHtml;

      document.getElementById('stat-events-total').textContent = (events.total || 0).toLocaleString('da-DK');
      document.getElementById('stat-events-today').textContent = (events.today || 0).toLocaleString('da-DK');
      document.getElementById('stat-sessions-total').textContent = (sessions.total || 0).toLocaleString('da-DK');
      document.getElementById('stat-avg-pages').textContent = sessions.avg_pages != null ? sessions.avg_pages : '—';

      var todayNote = document.getElementById('stat-events-today-note');
      if (todayNote && (events.today || 0) > 0) todayNote.style.display = 'block';

      buildActivityChart(events.recent || []);

      var html = '';
      (events.top_events || []).slice(0, 8).forEach(function(ev) {
        html += '<tr><td>' + esc(ev.event_name) + '</td><td><span style="font-size:0.7rem;background:#f3f4f6;color:#6b7280;padding:0.1rem 0.4rem;border-radius:0.25rem;">' + esc(ev.event_type) + '</span></td><td style="text-align:right;font-weight:600;">' + ev.count + '</td></tr>';
      });
      document.getElementById('table-top-events').innerHTML = html || '<tr><td colspan="3" style="color:#9ca3af;">Ingen data</td></tr>';

      html = '';
      (sessions.top_pages || []).slice(0, 8).forEach(function(p) {
        html += '<tr><td style="font-family:monospace;font-size:0.75rem;">' + esc(p.first_page) + '</td><td style="text-align:right;font-weight:600;">' + p.count + '</td></tr>';
      });
      document.getElementById('table-top-pages').innerHTML = html || '<tr><td colspan="2" style="color:#9ca3af;">Ingen data</td></tr>';

      html = '';
      (events.recent || []).slice(0, 12).forEach(function(ev) {
        html += '<tr><td><span style="font-size:0.7rem;background:#f3f4f6;color:#6b7280;padding:0.1rem 0.4rem;border-radius:0.25rem;">' + esc(ev.event_type) + '</span></td><td>' + esc(ev.event_name) + '</td><td style="font-family:monospace;font-size:0.75rem;color:#6b7280;">' + esc(ev.page_url) + '</td><td style="white-space:nowrap;color:#9ca3af;font-size:0.75rem;">' + fmt(ev.created_at) + '</td></tr>';
      });
      document.getElementById('table-recent-events').innerHTML = html || '<tr><td colspan="4" style="color:#9ca3af;">Ingen seneste hændelser</td></tr>';

      document.getElementById('loading').style.display = 'none';
      document.getElementById('dashboard').style.display = 'block';

      window.setInterval(refreshRolloutStatus, 60000);
    })
    .catch(function(err) {
      if (err.message === 'Unauthorized') return;
      document.getElementById('loading').style.display = 'none';
      var msg = err.message === 'Failed to fetch'
        ? ('Kunne ikke forbinde til API (' + API + '). Tjek om serveren kører.')
        : (err.message.indexOf('503') >= 0 ? err.message : 'Kunne ikke hente data: ' + err.message);
      document.getElementById('error-text').textContent = msg;
      document.getElementById('error').classList.remove('hidden');
    });

    function buildActivityChart(recentEvents) {
      var section = document.getElementById('activity-chart-section');
      var barsEl = document.getElementById('activity-bars');
      var labelsEl = document.getElementById('activity-day-labels');
      var peakEl = document.getElementById('activity-chart-peak');
      if (!section || !barsEl || !labelsEl || recentEvents.length === 0) return;

      var dayMap = {};
      recentEvents.forEach(function(ev) {
        var d = (ev.created_at || '').slice(0, 10);
        if (d) dayMap[d] = (dayMap[d] || 0) + 1;
      });

      var today = new Date();
      var days = [];
      for (var i = 13; i >= 0; i--) {
        var d = new Date(today);
        d.setDate(today.getDate() - i);
        var key = d.toISOString().slice(0, 10);
        days.push({ key: key, label: d.toLocaleDateString('da-DK', { month: 'numeric', day: 'numeric' }), count: dayMap[key] || 0 });
      }

      var max = Math.max.apply(null, days.map(function(d) { return d.count; }));
      if (max === 0) return;

      barsEl.innerHTML = '';
      labelsEl.innerHTML = '';

      days.forEach(function(d) {
        var pct = max > 0 ? (d.count / max) * 100 : 0;
        var bar = document.createElement('div');
        bar.className = 'activity-bar';
        bar.style.height = Math.max(4, pct) + '%';
        bar.title = d.label + ': ' + d.count + ' hændelser';
        barsEl.appendChild(bar);

        var lbl = document.createElement('div');
        lbl.className = 'activity-day-label';
        lbl.textContent = i === 0 ? 'i dag' : (d.key === days[0].key ? d.label : (days.indexOf(d) % 2 === 0 ? d.label : ''));
        labelsEl.appendChild(lbl);
      });

      if (peakEl) peakEl.textContent = 'Top: ' + max + ' hændelser';
      section.style.display = 'block';
    }

    function triggerPublish(btn, successLabel, originalLabel) {
      btn.disabled = true;
      var qaIcon = btn.querySelector && btn.querySelector('.qa-icon');
      if (btn.textContent !== undefined && !qaIcon) btn.textContent = 'Starter...';
      fetch(API + '/publish', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' } })
        .then(function(res) { return res.json().then(function(d) { return { ok: res.ok, data: d }; }); })
        .then(function(r) {
          if (r.ok) {
            if (btn.querySelector) {
              var lbl = btn.querySelector('.qa-label');
              var sub = btn.querySelector('.qa-sub');
              if (lbl) lbl.textContent = 'Udrulning startet';
              if (sub) sub.textContent = 'Siden er live om ~90 sek';
              var icon = btn.querySelector('.qa-icon');
              if (icon) icon.innerHTML = '<svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#16a34a" stroke-width="2"><polyline points="4 10 8 14 16 6"/></svg>';
              if (icon) icon.style.background = '#f0fdf4';
            } else {
              btn.textContent = successLabel;
              btn.style.background = '#16a34a';
            }
          } else {
            throw new Error(r.data.error || 'Fejl');
          }
        })
        .catch(function(err) {
          if (window.toast) toast('Fejl: ' + err.message, 'error'); else alert('Fejl: ' + err.message);
          btn.disabled = false;
          if (!btn.querySelector) btn.textContent = originalLabel;
        });
    }

    document.getElementById('dashboard-publish-btn')?.addEventListener('click', function() {
      triggerPublish(this, 'Udrulning startet', 'Publicer til live (~90 sek)');
    });

    document.getElementById('quick-publish-btn')?.addEventListener('click', function() {
      triggerPublish(this, 'Udrulning startet', 'Publicer nu');
    });

    document.getElementById('cms-copy-version-btn')?.addEventListener('click', function() {
      var btn = this;
      var value = btn.dataset.copyValue;
      if (!value) return;
      var restore = btn.textContent;
      function done(label) { btn.textContent = label; setTimeout(function() { btn.textContent = restore; }, 1500); }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).then(function() { done('Kopieret'); }).catch(function() { done('Kopiér manuelt'); });
      } else {
        done('Kopiér manuelt');
      }
    });
  })();
  </script>
</AdminLayout>
