---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Admin</title>
    <style>
      [data-reveal] {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }

      #admin-sidebar {
        background: #0f1117;
        width: 15rem;
        flex-shrink: 0;
      }

      .nav-section-label {
        padding: 0.5rem 0.75rem 0.25rem;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #4b5563;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.4rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.8125rem;
        color: #9ca3af;
        text-decoration: none;
        transition: background 0.14s ease, color 0.14s ease;
        position: relative;
        font-weight: 450;
      }

      .nav-item:hover {
        background: rgba(255,255,255,0.06);
        color: #f9fafb;
      }

      .nav-item.active {
        background: rgba(255,255,255,0.09);
        color: #fff;
        font-weight: 600;
      }

      .nav-item.active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 25%;
        height: 50%;
        width: 2.5px;
        background: #3b82f6;
        border-radius: 0 2px 2px 0;
      }

      .nav-item--master {
        color: #a78bfa;
      }

      .nav-item--master:hover {
        color: #c4b5fd;
        background: rgba(167,139,250,0.08);
      }

      .nav-item--master.active {
        color: #c4b5fd;
        background: rgba(167,139,250,0.12);
      }

      .nav-item--master.active::before {
        background: #a78bfa;
      }

      .nav-divider {
        height: 1px;
        background: rgba(255,255,255,0.06);
        margin: 0.35rem 0.75rem;
      }

      #admin-header {
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
        padding: 0 1.5rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .admin-page-main {
        flex: 1;
        padding: 1.75rem 2rem;
        overflow-y: auto;
        background: #f8f9fc;
        min-height: 0;
      }

      @media (max-width: 1023px) {
        #admin-sidebar {
          position: fixed;
          top: 0;
          left: 0;
          bottom: 0;
          z-index: 50;
          transform: translateX(-100%);
          transition: transform 0.22s ease;
          display: flex !important;
        }
        #admin-sidebar.open {
          transform: translateX(0);
          box-shadow: 4px 0 24px rgba(0,0,0,0.35);
        }
        .admin-page-main {
          padding: 1.25rem 1rem;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <script is:inline>
    (function() {
      var token = localStorage.getItem('admin_token');
      var path = window.location.pathname.replace(/\/$/, '') || '/admin';
      var isLoginPage = path === '/admin';
      if (!token && !isLoginPage) {
        window.location.href = '/admin/';
        return;
      }
      if (token && isLoginPage) {
        window.location.href = '/admin/dashboard/';
        return;
      }
    })();
    </script>

    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside id="admin-sidebar" class="hidden flex-col min-h-screen" aria-label="Admin navigation">
        <div style="padding: 1rem 0.875rem; border-bottom: 1px solid rgba(255,255,255,0.07);">
          <a href="/admin/dashboard/" style="display:flex; align-items:center; gap:0.5rem; text-decoration:none;">
            <span style="display:inline-flex; align-items:center; justify-content:center; width:1.75rem; height:1.75rem; background:#3b82f6; border-radius:0.4rem; font-size:0.8rem; font-weight:700; color:#fff; flex-shrink:0;">L</span>
            <span style="font-size:0.875rem; font-weight:700; color:#fff; letter-spacing:-0.01em;">LPH Admin</span>
          </a>
        </div>

        <nav style="flex:1; padding: 0.5rem 0.375rem; overflow-y:auto;" role="navigation">
          <a href="/admin/master/" id="master-hub-link" class="nav-item nav-item--master" style="margin-top:0.25rem;">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><path d="M10 2l2.5 5 5.5.75-4 3.9.95 5.5L10 14.7l-4.95 2.45.95-5.5L2 7.75 7.5 7z"/></svg>
            Master Hub
          </a>

          <div class="nav-divider" style="margin-top:0.375rem;"></div>

          <a href="/admin/dashboard/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><rect x="2" y="2" width="7" height="7" rx="1.5"/><rect x="11" y="2" width="7" height="7" rx="1.5"/><rect x="2" y="11" width="7" height="7" rx="1.5"/><rect x="11" y="11" width="7" height="7" rx="1.5"/></svg>
            Oversigt
          </a>
          <a href="/admin/traffic/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><polyline points="2 14 7 8 11 11 18 4"/></svg>
            Trafik
          </a>

          <div class="nav-section-label" style="margin-top:0.5rem;">Webstedskonfig</div>

          <a href="/admin/pages/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><rect x="3" y="2" width="14" height="16" rx="2"/><line x1="7" y1="7" x2="13" y2="7"/><line x1="7" y1="11" x2="13" y2="11"/><line x1="7" y1="15" x2="10" y2="15"/></svg>
            Sider
          </a>
          <a href="/admin/styling/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><circle cx="10" cy="10" r="4"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.22 4.22l1.42 1.42M14.36 14.36l1.42 1.42M4.22 15.78l1.42-1.42M14.36 5.64l1.42-1.42"/></svg>
            Design &amp; styling
          </a>
          <a href="/admin/themes/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><path d="M2 10c0-4.4 3.6-8 8-8s8 3.6 8 8"/><path d="M2 10c0 4.4 3.6 8 8 8"/><circle cx="10" cy="18" r="0" fill="currentColor"/><path d="M10 10c0 0 4-4 8 0"/></svg>
            Temaer
          </a>
          <a href="/admin/header-footer/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><rect x="2" y="3" width="16" height="4" rx="1"/><rect x="2" y="13" width="16" height="4" rx="1"/><line x1="5" y1="9.5" x2="15" y2="9.5"/></svg>
            Header &amp; Footer
          </a>
          <a href="/admin/components/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><path d="M5 3l-3 5 8 9 8-9-3-5H5z"/></svg>
            Komponenter
          </a>
          <a href="/admin/components/custom/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="11" y="3" width="6" height="6" rx="1"/><rect x="3" y="11" width="6" height="6" rx="1"/><path d="M11 14h6M14 11v6"/></svg>
            Egne komponenter
          </a>
          <a href="/admin/media/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><rect x="2" y="4" width="16" height="12" rx="2"/><circle cx="7" cy="9" r="1.5"/><path d="M2 14l4-4 3 3 3-3 6 4"/></svg>
            Medier
          </a>
          <a href="/admin/assistant/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><path d="M18 10c0 4.4-3.6 8-8 8H3l2-2a8 8 0 1 1 13-6z"/></svg>
            Assistant
          </a>
          <a href="/admin/ai-assemble/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><polygon points="13 2 3 14 12 14 7 22 17 10 8 10"/></svg>
            AI-assembler
          </a>

          <div class="nav-section-label" style="margin-top:0.5rem;">Shop</div>

          <a href="/admin/shop/orders/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><path d="M2 3h2l2.5 9h9l2-6H6"/><circle cx="8.5" cy="16" r="1.5"/><circle cx="15.5" cy="16" r="1.5"/></svg>
            Ordrer
          </a>
          <a href="/admin/shop/products/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><rect x="2" y="7" width="16" height="11" rx="2"/><path d="M7 7V5a3 3 0 0 1 6 0v2"/></svg>
            Produkter
          </a>
          <a href="/admin/shop/settings/" class="nav-item">
            <svg width="13" height="13" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" style="flex-shrink:0;"><circle cx="10" cy="10" r="3"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.22 4.22l1.42 1.42M14.36 14.36l1.42 1.42M4.22 15.78l1.42-1.42M14.36 5.64l1.42-1.42"/></svg>
            Shop-indstillinger
          </a>
        </nav>

        <div style="padding: 0.75rem; border-top: 1px solid rgba(255,255,255,0.07);">
          <div id="sidebar-user" style="display:flex; align-items:center; gap:0.625rem; margin-bottom:0.5rem;">
            <div id="sidebar-avatar" style="width:1.75rem; height:1.75rem; border-radius:50%; background:rgba(255,255,255,0.12); display:flex; align-items:center; justify-content:center; font-size:0.7rem; font-weight:700; color:#e5e7eb; flex-shrink:0;"></div>
            <span id="admin-email" style="font-size:0.75rem; color:#9ca3af; truncate; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0;"></span>
          </div>
          <button id="logout-btn" style="width:100%; text-align:left; font-size:0.75rem; color:#6b7280; padding:0.25rem 0; background:none; border:none; cursor:pointer; transition:color 0.14s;">
            Log ud
          </button>
        </div>
      </aside>

      <!-- Main column -->
      <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
        <!-- Top bar -->
        <header id="admin-header" class="hidden">
          <button id="mobile-menu-btn" style="display:none; background:none; border:none; cursor:pointer; padding:0.25rem; color:#6b7280;">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="17" y2="6"/><line x1="3" y1="10" x2="17" y2="10"/><line x1="3" y1="14" x2="17" y2="14"/></svg>
          </button>
          <div style="flex:1;"></div>
          <div style="display:flex; align-items:center; gap:0.75rem;">
            <span id="header-role-badge" style="display:none; font-size:0.65rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:0.15rem 0.5rem; border-radius:9999px; background:#f3f0ff; color:#7c3aed;"></span>
            <span id="header-page-title" style="font-size:0.8125rem; font-weight:600; color:#374151;"></span>
          </div>
        </header>

        <!-- Page content -->
        <main class="admin-page-main">
          <slot />
        </main>
      </div>
    </div>

    <!-- Mobile overlay -->
    <div id="mobile-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:49;" onclick="closeMobileMenu()"></div>

    <script is:inline>
    (function() {
      var path = window.location.pathname.replace(/\/$/, '') || '/admin';
      if (path === '/admin') return;

      var sidebar = document.getElementById('admin-sidebar');
      var header = document.getElementById('admin-header');
      var mobileBtn = document.getElementById('mobile-menu-btn');

      if (sidebar) {
        sidebar.classList.remove('hidden');
        sidebar.classList.add('flex');
      }
      if (header) {
        header.classList.remove('hidden');
      }
      if (mobileBtn) {
        mobileBtn.style.display = 'block';
        if (window.innerWidth >= 1024) mobileBtn.style.display = 'none';
      }

      try {
        var token = localStorage.getItem('admin_token');
        if (token) {
          var payload = JSON.parse(atob(token.split('.')[1]));
          var emailEl = document.getElementById('admin-email');
          var avatarEl = document.getElementById('sidebar-avatar');
          var roleBadge = document.getElementById('header-role-badge');

          if (emailEl) emailEl.textContent = payload.email || '';
          if (avatarEl) {
            var initials = (payload.email || 'A').charAt(0).toUpperCase();
            avatarEl.textContent = initials;
          }

          var masterLink = document.getElementById('master-hub-link');
          if (masterLink && payload.role !== 'master') {
            masterLink.style.display = 'none';
          }
          if (roleBadge && payload.role === 'master') {
            roleBadge.style.display = 'inline-block';
            roleBadge.textContent = 'Master';
          }
        }
      } catch(e) {}

      var pageTitleEl = document.getElementById('header-page-title');
      if (pageTitleEl) {
        var title = document.title || '';
        pageTitleEl.textContent = title.replace(/\s*[—-]\s*Admin.*$/, '').trim();
      }

      var logoutBtn = document.getElementById('logout-btn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          localStorage.removeItem('admin_token');
          window.location.href = '/admin/';
        });
        logoutBtn.addEventListener('mouseenter', function() { this.style.color = '#f87171'; });
        logoutBtn.addEventListener('mouseleave', function() { this.style.color = '#6b7280'; });
      }

      var normalizedPath = path;
      if (sidebar) {
        var links = sidebar.querySelectorAll('nav a.nav-item');
        links.forEach(function(a) {
          var href = (a.getAttribute('href') || '').replace(/\/$/, '') || '/admin';
          if (normalizedPath === href) {
            a.classList.add('active');
          }
        });
      }

      if (mobileBtn && sidebar) {
        mobileBtn.addEventListener('click', function() {
          sidebar.classList.add('open');
          var overlay = document.getElementById('mobile-overlay');
          if (overlay) overlay.style.display = 'block';
        });
      }
    })();

    function closeMobileMenu() {
      var sidebar = document.getElementById('admin-sidebar');
      var overlay = document.getElementById('mobile-overlay');
      if (sidebar) sidebar.classList.remove('open');
      if (overlay) overlay.style.display = 'none';
    }
    window.closeMobileMenu = closeMobileMenu;
    </script>
  </body>
</html>
